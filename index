function PaginaDocumentos({clientes, processos}){
  const [clienteId,setClienteId]=useState("");
  const [tipoDoc,setTipoDoc]=useState("procuracao");
  const [objeto,setObjeto]=useState("");
  const [comReserva,setComReserva]=useState(false);
  const [procNum,setProcNum]=useState("");
  const [valorHon,setValorHon]=useState("");
  const [percExito,setPercExito]=useState("");
  const [formaPag,setFormaPag]=useState("");
  const [copiado,setCopiado]=useState(false);
  // IA
  const [promptIA,setPromptIA]=useState("");
  const [tipoPeca,setTipoPeca]=useState("");
  const [gerandoIA,setGerandoIA]=useState(false);
  const [textoIA,setTextoIA]=useState("");
  const [erroIA,setErroIA]=useState("");
  const [copiadoIA,setCopiadoIA]=useState(false);

  const cliente = clientes.find(c=>String(c.id)===clienteId);

  const textoGerado = useMemo(()=>{
    if(!cliente) return "";
    if(tipoDoc==="procuracao") return gerarTextoProcuracao(cliente, objeto);
    if(tipoDoc==="contrato") return gerarTextoContrato(cliente, objeto, percExito, valorHon, formaPag);
    if(tipoDoc==="hipossuficiencia") return gerarTextoHipossuficiencia(cliente);
    if(tipoDoc==="substabelecimento") return gerarTextoSubstabelecimento(cliente, comReserva, procNum);
    return "";
  },[cliente,tipoDoc,objeto,percExito,valorHon,formaPag,comReserva,procNum]);

  const copiar = (txt, setFlag) => {
    if(navigator.clipboard?.writeText){
      navigator.clipboard.writeText(txt).then(()=>{setFlag(true);setTimeout(()=>setFlag(false),2500);}).catch(()=>{});
    }
  };

  const gerarComIA = async () => {
    if(!promptIA.trim()){ setErroIA("Descreva o que a peça deve conter."); return; }
    setGerandoIA(true); setErroIA(""); setTextoIA("");
    try {
      const ctx = cliente ? `\n\nDADOS DO CLIENTE (use na qualificação):\n${qualificacaoCompleta(cliente)}` : "";
      const ctxProc = procNum ? `\nProcesso nº: ${procNum}` : "";
      const sys = `Você é assistente jurídico de uma advogada brasileira (OAB/RJ 155.134, Michelli Abreu Advocacia, Itaboraí/RJ). Redija a peça solicitada em português jurídico formal, com estrutura adequada (endereçamento ao juízo quando aplicável, qualificação das partes, fundamentação com dispositivos legais pertinentes, pedidos). Nunca invente números de processo, nomes, datas ou valores que não tenham sido fornecidos — use placeholders entre colchetes como [DADO] quando faltar informação.${ctx}${ctxProc}`;
      let res;
      try {
        res = await fetch(IA_PROXY_URL, {
          method:"POST", headers:{"Content-Type":"application/json","Authorization":"Bearer "+SUPABASE_KEY},
          body: JSON.stringify({ model:"claude-sonnet-4-6", max_tokens:3000, system:sys, messages:[{role:"user",content:`Tipo de peça: ${tipoPeca||"(não especificado)"}\n\nInstruções: ${promptIA}`}] })
        });
      } catch(e){ throw new Error("Sem conexão com o serviço de IA — verifique a internet."); }
      if(!res.ok){ let d="";try{const b=await res.json();d=b?.error?.message||"";}catch(_){}throw new Error(`Erro HTTP ${res.status}.${d?` ${d}`:""}`); }
      const data = await res.json();
      const txt = data.content?.find(b=>b.type==="text")?.text || "";
      if(!txt) throw new Error("A IA retornou resposta vazia.");
      setTextoIA(txt);
    } catch(e){ setErroIA(e.message || "Erro ao gerar a peça."); }
    setGerandoIA(false);
  };

  const TIPOS = [["procuracao","Procuração ad judicia"],["contrato","Contrato de honorários"],["hipossuficiencia","Declaração de hipossuficiência"],["substabelecimento","Substabelecimento"]];

  return (
    <div>
      <div style={{marginBottom:16}}>
        <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Documentos</h1>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Modelos preenchidos automaticamente e gerador de peças com IA</p>
      </div>

      {/* MODELOS FIXOS */}
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,padding:"1.25rem",marginBottom:16}}>
        <p style={{fontSize:13,fontWeight:700,color:"var(--text1)",margin:"0 0 14px"}}>📄 Modelos prontos</p>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:12}}>
          <div>
            <span style={lbl}>Cliente</span>
            <select value={clienteId} onChange={e=>setClienteId(e.target.value)} style={{...inp,padding:"7px 8px"}}>
              <option value="">Selecione um cliente…</option>
              {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}</option>)}
            </select>
          </div>
          <div>
            <span style={lbl}>Tipo de documento</span>
            <select value={tipoDoc} onChange={e=>setTipoDoc(e.target.value)} style={{...inp,padding:"7px 8px"}}>
              {TIPOS.map(([v,l])=><option key={v} value={v}>{l}</option>)}
            </select>
          </div>
        </div>

        {(tipoDoc==="procuracao"||tipoDoc==="contrato")&&(
          <div style={{marginBottom:10}}><span style={lbl}>Objeto / finalidade</span><input value={objeto} onChange={e=>setObjeto(e.target.value)} style={inp} placeholder="Ex: ação de cobrança contra…"/></div>
        )}
        {tipoDoc==="contrato"&&(
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10,marginBottom:10}}>
            <div><span style={lbl}>Valor honorários</span><input value={valorHon} onChange={e=>setValorHon(e.target.value)} style={inp} placeholder="3000"/></div>
            <div><span style={lbl}>% de êxito</span><input value={percExito} onChange={e=>setPercExito(e.target.value)} style={inp} placeholder="20"/></div>
            <div><span style={lbl}>Forma de pagamento</span><input value={formaPag} onChange={e=>setFormaPag(e.target.value)} style={inp} placeholder="à vista / 3x"/></div>
          </div>
        )}
        {tipoDoc==="substabelecimento"&&(
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
            <div><span style={lbl}>Processo nº (opcional)</span><input value={procNum} onChange={e=>setProcNum(e.target.value)} style={inp} placeholder="0000000-00.0000.0.00.0000"/></div>
            <div style={{display:"flex",alignItems:"flex-end"}}><label style={{display:"flex",alignItems:"center",gap:8,fontSize:12.5,color:"var(--text1)",cursor:"pointer",paddingBottom:8}}><input type="checkbox" checked={comReserva} onChange={e=>setComReserva(e.target.checked)} style={{width:15,height:15}}/>Com reserva de poderes</label></div>
          </div>
        )}

        {cliente ? (
          <div>
            <div style={{display:"flex",justifyContent:"flex-end",marginBottom:8}}>
              <button onClick={()=>copiar(textoGerado,setCopiado)} style={{...btnPri,fontSize:11.5,padding:"7px 14px"}}>{copiado?"✓ Copiado!":"📋 Copiar documento"}</button>
            </div>
            <pre style={{background:"var(--bg2)",borderRadius:8,padding:"16px",fontSize:12,lineHeight:1.6,color:"var(--text1)",whiteSpace:"pre-wrap",fontFamily:"Inter,sans-serif",margin:0,maxHeight:340,overflow:"auto"}}>{textoGerado}</pre>
          </div>
        ) : (
          <p style={{fontSize:12,color:"var(--text3)",margin:"8px 0 0"}}>Selecione um cliente para gerar o documento. Dados faltantes (RG, profissão, etc.) aparecem como [placeholder] — preencha-os no cadastro do cliente.</p>
        )}
      </div>

      {/* GERADOR COM IA */}
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,padding:"1.25rem"}}>
        <p style={{fontSize:13,fontWeight:700,color:"var(--text1)",margin:"0 0 4px"}}>✨ Gerar peça com IA</p>
        <div style={{background:"#FFF8E6",border:"1px solid #FDE68A",borderRadius:6,padding:"8px 12px",fontSize:11.5,color:"#78350F",margin:"0 0 14px",lineHeight:1.5}}>⚠️ A peça gerada é um <strong>rascunho</strong>. Revise integralmente — fundamentação, dispositivos legais citados e dados — antes de protocolar. A IA pode cometer erros jurídicos.</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10,marginBottom:10}}>
          <div>
            <span style={lbl}>Cliente (contexto, opcional)</span>
            <select value={clienteId} onChange={e=>setClienteId(e.target.value)} style={{...inp,padding:"7px 8px"}}>
              <option value="">Nenhum</option>
              {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}</option>)}
            </select>
          </div>
          <div><span style={lbl}>Tipo de peça</span><input value={tipoPeca} onChange={e=>setTipoPeca(e.target.value)} style={inp} placeholder="Ex: petição inicial, contestação…"/></div>
        </div>
        <div style={{marginBottom:10}}><span style={lbl}>Instruções / fatos</span><textarea value={promptIA} onChange={e=>setPromptIA(e.target.value)} style={{...inp,minHeight:90,resize:"vertical",fontFamily:"inherit"}} placeholder="Descreva os fatos, o pedido, fundamentos que deseja…"/></div>
        {erroIA&&<div style={{background:"var(--red-bg)",border:"1px solid #FCA5A5",borderRadius:6,padding:"8px 12px",fontSize:12,color:"var(--red)",marginBottom:10}}><strong>Erro:</strong> {erroIA}</div>}
        <div style={{display:"flex",justifyContent:"flex-end",marginBottom:textoIA?12:0}}>
          <button onClick={gerarComIA} disabled={gerandoIA} style={{...btnPri,fontSize:11.5,padding:"8px 16px",opacity:gerandoIA?.7:1}}>{gerandoIA?"Gerando…":"✨ Gerar rascunho"}</button>
        </div>
        {textoIA&&(
          <div>
            <div style={{display:"flex",justifyContent:"flex-end",marginBottom:8}}>
              <button onClick={()=>copiar(textoIA,setCopiadoIA)} style={{...btnSec,fontSize:11,padding:"6px 12px"}}>{copiadoIA?"✓ Copiado!":"📋 Copiar rascunho"}</button>
            </div>
            <pre style={{background:"var(--bg2)",borderRadius:8,padding:"16px",fontSize:12,lineHeight:1.6,color:"var(--text1)",whiteSpace:"pre-wrap",fontFamily:"Inter,sans-serif",margin:0,maxHeight:400,overflow:"auto"}}>{textoIA}</pre>
          </div>
        )}
      </div>
    </div>
  );
}

function PaginaImportacao({onImportar, uid, processos, clientes, setProcessos, setClientes}){
  const [texto,setTexto]=useState("");
  const [resultado,setResultado]=useState(null);
  const [loading,setLoading]=useState(false);
  const [erro,setErro]=useState("");
  const [restLoading,setRestLoading]=useState(false);
  const [restMsg,setRestMsg]=useState("");

  const restaurarProcessos = async () => {
    setRestLoading(true); setRestMsg("");
    try {
      const tryParse = (val, fb) => { try { return val ? (typeof val==="string"?JSON.parse(val):val) : fb; } catch(_){ return fb; } };
      // 1. Buscar o que já existe no banco
      const { data: procsBanco, error: e1 } = await sb.from("processos").select("id");
      const { data: cltsBanco, error: e2 } = await sb.from("clientes").select("id");
      if(e1) throw new Error("Erro ao ler processos: " + e1.message);
      if(e2) throw new Error("Erro ao ler clientes: " + e2.message);

      const idsProcsBanco = new Set((procsBanco||[]).map(r=>r.id));
      const idsCltsBanco = new Set((cltsBanco||[]).map(r=>r.id));

      // 2. Preparar clientes que faltam
      const cltsFaltando = CLIENTES0.filter(c=>!idsCltsBanco.has(c.id)).map(c=>({...c, user_id:uid}));
      let nClientes = 0;
      if(cltsFaltando.length>0){
        const { data: insC, error: ec } = await sb.from("clientes").insert(cltsFaltando).select();
        if(ec) throw new Error("Erro ao inserir clientes: " + ec.message);
        nClientes = (insC||cltsFaltando).length;
      }

      // 3. Preparar processos que faltam
      const procsFaltando = PROCS0.filter(p=>!idsProcsBanco.has(p.id)).map(p=>({
        ...p, status:normalizarStatus(p.status), user_id:uid,
        andamentos:JSON.stringify(p.andamentos||[]), partes:JSON.stringify(p.partes||[]),
        checklist:JSON.stringify(p.checklist||{}), exitos:JSON.stringify(p.exitos||[]),
        debito:JSON.stringify(p.debito||null), documentos:JSON.stringify(p.documentos||[]),
      }));
      let nProcs = 0;
      if(procsFaltando.length>0){
        const { data: insP, error: ep } = await sb.from("processos").insert(procsFaltando).select();
        if(ep) throw new Error("Erro ao inserir processos: " + ep.message);
        nProcs = (insP||procsFaltando).length;
      }

      // 4. Recarregar tudo do banco e atualizar a tela
      const { data: todosProcs } = await sb.from("processos").select("*");
      const { data: todosClts } = await sb.from("clientes").select("*");
      if(todosClts) setClientes(todosClts);
      if(todosProcs) setProcessos(todosProcs.map(p=>({...p, andamentos:tryParse(p.andamentos,[]), partes:tryParse(p.partes,[]), checklist:tryParse(p.checklist,{}), exitos:tryParse(p.exitos,[]), debito:tryParse(p.debito,null)})));

      setRestMsg(`✓ Pronto! ${nProcs} processo(s) e ${nClientes} cliente(s) restaurado(s). Vá para a tela de Processos para ver.`);
    } catch(e){
      setRestMsg("✗ " + (e.message || "Erro ao restaurar.") + " — Me envie esta mensagem para eu corrigir.");
    }
    setRestLoading(false);
  };
  const processar=async()=>{
    if(!texto.trim()){setErro("Cole o texto antes de processar.");return;}
    setErro("");setLoading(true);setResultado(null);
    try{
      const promptImport = "Você é um assistente jurídico. Extraia os dados do relatório abaixo e retorne SOMENTE um JSON válido, sem texto adicional.\n\nArray com esta estrutura:\n[{\"numero\":\"\",\"tipo\":\"judicial\",\"autor\":\"\",\"reu\":\"\",\"vara\":\"\",\"responsavel\":\"\",\"status\":\"ativo\",\"prazo\":\"YYYY-MM-DD\",\"andamentos\":[{\"data\":\"YYYY-MM-DD\",\"desc\":\"\"}],\"documentos\":[]}]\n\nRELATÓRIO:\n" + texto;
      let res;
      try{ res=await fetch(IA_PROXY_URL,{method:"POST",headers:{"Content-Type":"application/json","Authorization":"Bearer "+SUPABASE_KEY},body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,messages:[{role:"user",content:promptImport}]})});
      }catch(e){throw new Error("Sem conexão com o serviço de IA — verifique a internet.");}
      if(!res.ok){let d="";try{const b=await res.json();d=b?.error?.message||"";}catch(_){}throw new Error("Erro HTTP "+res.status+"."+(d?" "+d:""));}
      const data=await res.json();
      const txt=data.content?.find(b=>b.type==="text")?.text||"";
      if(!txt)throw new Error("A IA retornou resposta vazia.");
      let parsed;
      try{parsed=JSON.parse(txt.replace(/```json|```/g,"").trim());}catch(e){throw new Error("JSON inválido. Início: \""+txt.slice(0,120)+"\"");}
      if(!Array.isArray(parsed))throw new Error("Formato inválido — a IA não retornou uma lista de processos.");
      setResultado(parsed);
    }catch(e){setErro(e.message||"Não foi possível interpretar. Verifique o formato e tente novamente.");}
    setLoading(false);
  };
  const confirmar=()=>{if(!resultado)return;onImportar(resultado.map((p,i)=>({...p,id:Date.now()+i,andamentos:p.andamentos||[],documentos:p.documentos||[]})));setTexto("");setResultado(null);};
  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};
  return(
    <div>
      <div style={{marginBottom:16}}>
        <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Importar processos</h1>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Cole um relatório em texto livre e deixe a IA estruturar os dados</p>
      </div>

      <div style={{background:"#FFF8E6",border:"1px solid #FDE68A",borderRadius:8,padding:"1.25rem",marginBottom:14}}>
        <p style={{fontSize:13,fontWeight:700,color:"#92400E",margin:"0 0 6px"}}>🔄 Restaurar processos iniciais</p>
        <p style={{fontSize:12,color:"#78350F",margin:"0 0 12px",lineHeight:1.6}}>Se os 53 processos cadastrados não estão aparecendo, clique abaixo para reinseri-los no banco. Não duplica nada que você já tenha — insere só o que está faltando.</p>
        {restMsg && <p style={{fontSize:12,margin:"0 0 10px",padding:"8px 12px",borderRadius:5,background:restMsg.startsWith("✓")?"var(--green-bg)":"var(--red-bg)",color:restMsg.startsWith("✓")?"var(--green)":"var(--red)",lineHeight:1.5}}>{restMsg}</p>}
        <button onClick={restaurarProcessos} disabled={restLoading} style={{...btnPri,fontSize:12,background:"#B45309",opacity:restLoading?.7:1}}>{restLoading?"Restaurando…":"🔄 Restaurar 53 processos e 35 clientes"}</button>
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"1.25rem",marginBottom:14}}>
        <p style={{fontSize:12,color:"var(--text2)",margin:"0 0 14px",lineHeight:1.6}}>Cole o texto do relatório (qualquer formato). A IA identifica os dados automaticamente. <strong style={{color:"var(--text1)"}}>Os processos existentes serão substituídos.</strong> Vincule o cliente manualmente depois, na tela de Processos.</p>
        <textarea value={texto} onChange={e=>setTexto(e.target.value)} placeholder="Cole aqui o relatório de processos..." style={{width:"100%",minHeight:180,fontSize:12,padding:"10px",borderRadius:6,border:"1px solid var(--border2)",background:"#fff",color:"var(--text1)",resize:"vertical",lineHeight:1.6,boxSizing:"border-box"}}/>
        {erro&&<p style={{fontSize:12,color:"var(--red)",margin:"8px 0 0",background:"var(--red-bg)",padding:"8px 12px",borderRadius:5}}>{erro}</p>}
        <div style={{display:"flex",gap:8,marginTop:12,justifyContent:"flex-end"}}>
          <button onClick={()=>{setTexto("");setResultado(null);setErro("");}} style={{...btnSec,fontSize:11}}>Limpar</button>
          <button onClick={processar} disabled={loading} style={{...btnPri,fontSize:11,opacity:loading?.7:1}}>{loading?"Processando…":"⚡ Processar com IA"}</button>
        </div>
      </div>
      {resultado&&(
        <div>
          <div style={{background:"var(--green-bg)",borderLeft:"3px solid var(--green)",borderRadius:6,padding:"10px 14px",marginBottom:12,fontSize:12,color:"var(--green)",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <span><strong>{resultado.length} processo(s)</strong> identificado(s). Revise antes de confirmar.</span>
            <button onClick={confirmar} style={{...btnPri,background:"var(--green)",fontSize:11,padding:"6px 14px"}}>✓ Confirmar</button>
          </div>
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden"}}>
            <div style={{display:"grid",gridTemplateColumns:"2fr 1.2fr 1fr 1fr .9fr",padding:"8px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)"}}>{["Processo / Partes","Vara","Tipo","Prazo","Status"].map(h=><span key={h} style={hdr}>{h}</span>)}</div>
            {resultado.map((p,i)=>(
              <div key={i} style={{display:"grid",gridTemplateColumns:"2fr 1.2fr 1fr 1fr .9fr",padding:"10px 14px",alignItems:"center",borderBottom:i<resultado.length-1?"1px solid var(--border1)":"none"}}>
                <div><p style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 2px"}}>{p.numero||"—"}</p><p style={{fontSize:13,fontWeight:600,margin:"0 0 2px"}}>{p.autor||"—"}</p><p style={{fontSize:11,color:"var(--text2)",margin:0}}>vs. {p.reu||"—"}</p></div>
                <div><p style={{fontSize:12,margin:"0 0 2px"}}>{p.vara||"—"}</p></div>
                <div><Pill {...(TC[p.tipo]||TC.judicial)} sm/></div>
                <div style={{fontSize:12}}>{p.prazo?fmtData(p.prazo):"—"}</div>
                <div><Pill {...(SC[normalizarStatus(p.status)])} sm/></div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}
