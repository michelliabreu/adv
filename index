// ── Helpers de múltiplas partes (litisconsórcio) ───────────
// Um processo pode ter `partes: [{id, nome, polo:"autor"|"reu", clienteId}]`.
// Quando presente, tem prioridade sobre os campos legados `autor`/`reu` (texto único).
function temListaPartes(p){
  return Array.isArray(p.partes) && p.partes.length > 0;
}
function partesPorPolo(p, polo){
  if(temListaPartes(p)) return p.partes.filter(x=>x.polo===polo);
  const nomeTexto = polo==="autor" ? p.autor : p.reu;
  return nomeTexto ? [{id:`legado-${polo}`, nome:nomeTexto, polo, clienteId:null}] : [];
}
function nomesPorPolo(p, polo){
  return partesPorPolo(p, polo).map(x=>x.nome).filter(Boolean);
}
function autorTexto(p){
  return temListaPartes(p) ? nomesPorPolo(p,"autor").join(" e ") : (p.autor||"");
}
function reuTexto(p){
  return temListaPartes(p) ? nomesPorPolo(p,"reu").join(" e ") : (p.reu||"");
}
// Identifica qual nome de cliente deve aparecer em destaque e qual é a parte adversa,
// considerando que o cliente pode estar tanto no polo ativo quanto passivo.
function clientePrincipalEAdversa(p, clientes){
  if(temListaPartes(p)){
    const parteComCliente = p.partes.find(x=>x.clienteId);
    if(parteComCliente){
      const cli = clientes.find(c=>c.id===parteComCliente.clienteId);
      // Polo do cliente x polo oposto. Litisconsortes do mesmo polo viram "e outros".
      const poloCliente = parteComCliente.polo;
      const poloAdverso = poloCliente==="autor" ? "reu" : "autor";
      const mesmosPolo = p.partes.filter(x=>x.polo===poloCliente && x.nome).length;
      const adversos = p.partes.filter(x=>x.polo===poloAdverso).map(x=>x.nome).filter(Boolean);
      const nomeCli = cli ? cli.nome : parteComCliente.nome;
      const nomeClienteExib = mesmosPolo>1 ? `${nomeCli} e outros` : nomeCli;
      const adversaExib = adversos.length>1 ? `${adversos[0]} e outros` : (adversos[0]||"—");
      return { nomeCliente: nomeClienteExib, adversa: adversaExib, clienteObj: cli||null, nomeClienteSimples: nomeCli };
    }
    // sem cliente vinculado: usa autor x réu como referência
    const autores = nomesPorPolo(p,"autor"), reus = nomesPorPolo(p,"reu");
    const autorExib = autores.length>1 ? `${autores[0]} e outros` : (autores[0]||"—");
    const reuExib = reus.length>1 ? `${reus[0]} e outros` : (reus[0]||"—");
    return { nomeCliente: autorExib, adversa: reuExib, clienteObj: null, nomeClienteSimples: autores[0]||"" };
  }
  // formato legado (sem lista de partes)
  const cli = p.clienteId ? clientes.find(c=>c.id===p.clienteId) : null;
  const nomeCli = cli ? cli.nome : (p.autor||"—");
  const adversa = cli ? (cli.nome===p.autor ? (p.reu||"—") : (p.autor||"—")) : (p.reu||"—");
  return { nomeCliente: nomeCli, adversa, clienteObj: cli, nomeClienteSimples: nomeCli };
}

