        </div>
      </div>
    </div>
  );
}

function PaginaFichaAtendimento({clientes, setClientes, processos, setProcessos, demandas, setDemandas, tarefas, setTarefas, equipe, onConcluido}){
  const [cliente,setCliente] = useState(pessoaVazia());
  const [clienteExistenteId,setClienteExistenteId] = useState("");
  const [adversa,setAdversa] = useState(pessoaVazia());
  const [fatos,setFatos] = useState("");
  const [tipoDemanda,setTipoDemanda] = useState("Ação Judicial");
  const [assuntoTipo,setAssuntoTipo] = useState("");
  const [tipoExtraCustom,setTipoExtraCustom] = useState("");
  const [vara,setVara] = useState("");
  const [tarefaSugerida,setTarefaSugerida] = useState(TAREFAS_SUGERIDAS[0]);
  const [tarefaCustom,setTarefaCustom] = useState("");
  const [tarefaResponsavel,setTarefaResponsavel] = useState("");
  const [tarefaPrazo,setTarefaPrazo] = useState("");
  const [salvo,setSalvo] = useState(null);
  const [confirmandoDocs,setConfirmandoDocs] = useState(null);
  const [docsGerados,setDocsGerados] = useState(null);

  const onSelecionarClienteExistente = (id) => {
    setClienteExistenteId(id);
    if(!id) { setCliente(pessoaVazia()); return; }
    const c = clientes.find(x=>x.id===parseInt(id));
    if(c) setCliente({nome:c.nome, nacionalidade:c.nacionalidade||"brasileiro(a)", estadoCivil:c.estadoCivil||"", profissao:c.profissao||"", rg:c.rg||"", cpf:c.cpf||"", endereco:c.endereco||"", email:c.email||"", telefone:c.telefone||""});
  };

  const textoQualificacaoCliente = useMemo(()=>gerarTextoQualificacao(cliente,"REQUERENTE/AUTOR(A)"),[cliente]);
  const textoQualificacaoAdversa = useMemo(()=>gerarTextoQualificacao(adversa,"REQUERIDO(A)/RÉU(É)"),[adversa]);
  const [copiado,setCopiado] = useState("");
  const copiar = (texto, qual) => { navigator.clipboard?.writeText(texto); setCopiado(qual); setTimeout(()=>setCopiado(""),2000); };

  const finalizar = () => {
    if(!cliente.nome.trim()){ alert("Informe ao menos o nome do cliente."); return; }

    // 1. Cria ou reaproveita o cliente no CRM (com dados completos para gerar documentos)
    let clienteId = clienteExistenteId ? parseInt(clienteExistenteId) : null;
    let clienteCRM;
    if(!clienteId){
      clienteId = Date.now();
      clienteCRM = {
        id: clienteId, nome: cliente.nome, cpf: cliente.cpf, email: cliente.email,
        telefone: cliente.telefone, endereco: cliente.endereco,
        profissao: cliente.profissao, estadoCivil: cliente.estadoCivil, nacionalidade: cliente.nacionalidade, rg: cliente.rg,
        obs: "Cadastrado via Ficha de Atendimento.",
      };
      setClientes(cs=>[...cs, clienteCRM]);
    } else {
      clienteCRM = clientes.find(c=>c.id===clienteId);
    }

    // 2. Cria o processo (judicial sem número) ou a demanda extrajudicial
    let novoProcessoId = null, novaDemandaId = null;
    const assunto = assuntoTipo === "Outro" ? tipoExtraCustom : assuntoTipo;

    if(tipoDemanda === "Ação Judicial"){
      novoProcessoId = Date.now()+1;
      setProcessos(ps=>[...ps, {
        id: novoProcessoId, clienteId, numero: "", tipo:"judicial", classificacao:"",
        autor: cliente.nome, reu: adversa.nome || "—", vara: vara || "—",
        responsavel: tarefaResponsavel?(equipe.find(m=>m.id===parseInt(tarefaResponsavel))?.nome||""):"",
        status:"em_andamento", prazo:"", debito:null, assunto: assunto || "", valorCausa:"",
        andamentos: [{data: hoje.toISOString().slice(0,10), desc:"Atendimento inicial registrado — aguardando distribuição/numeração do processo.", fonte:"manual"}],
        documentos:[], checklist:{}, obs: fatos,
      }]);
    } else {
      novaDemandaId = Date.now()+1;
      setDemandas(ds=>[...ds, {
        id: novaDemandaId, clienteId, tipo: assunto || "Consulta",
        descricao: fatos, status:"em_andamento", responsavel: tarefaResponsavel?(equipe.find(m=>m.id===parseInt(tarefaResponsavel))?.nome||""):"",
        prazo:"", valorCausa:"", obs:`Parte adversa: ${adversa.nome||"—"}`,
      }]);
    }

    // 3. Cria a tarefa inicial
    const tituloTarefa = tarefaSugerida==="Outra (especificar)" ? tarefaCustom : tarefaSugerida;
    if(tituloTarefa && tituloTarefa.trim()){
      setTarefas(ts=>[...ts, {
        id: Date.now()+2, titulo: tituloTarefa.trim(),
        responsavelId: tarefaResponsavel?parseInt(tarefaResponsavel):"",
        procId: novoProcessoId || "", demandaId: novaDemandaId || "",
        clienteId, status:"pendente", prioridade:"alta", prazo: tarefaPrazo,
        desc: "Originada da Ficha de Atendimento.", arquivada:false,
      }]);
    }

    const objetoSugerido = tipoDemanda==="Ação Judicial"
      ? `${assunto || "Ação judicial"}${adversa.nome?` em face de ${adversa.nome}`:""}.`
      : `${assunto || "Demanda extrajudicial"}.`;

    setSalvo({clienteId, novoProcessoId, novaDemandaId, tipoDemanda});
    setConfirmandoDocs({pessoa: {...cliente}, objetoSugerido});
  };

  const novoAtendimento = () => {
    setCliente(pessoaVazia()); setClienteExistenteId(""); setAdversa(pessoaVazia());
    setFatos(""); setTipoDemanda("Ação Judicial"); setAssuntoTipo(""); setTipoExtraCustom(""); setVara("");
    setTarefaSugerida(TAREFAS_SUGERIDAS[0]); setTarefaCustom(""); setTarefaResponsavel(""); setTarefaPrazo("");
    setSalvo(null); setConfirmandoDocs(null); setDocsGerados(null);
  };

  if(confirmandoDocs){
    return <ModalConfirmarDocumentos
      pessoa={confirmandoDocs.pessoa}
      objetoSugerido={confirmandoDocs.objetoSugerido}
      onGerar={(dados)=>{ setDocsGerados({pessoa:confirmandoDocs.pessoa, dados}); setConfirmandoDocs(null); }}
      onPular={()=>setConfirmandoDocs(null)}
    />;
  }

  if(docsGerados){
    return (
      <>
        <ModalDocumentosGerados pessoa={docsGerados.pessoa} dados={docsGerados.dados} onClose={()=>setDocsGerados(null)}/>
      </>
    );
  }

  if(salvo){
    return (
      <div>
        <div style={{background:"#fff",borderRadius:8,border:"1px solid var(--border1)",padding:"2.5rem",textAlign:"center",maxWidth:480,margin:"3rem auto"}}>
          <div style={{fontSize:40,marginBottom:14}}>✅</div>
          <h2 style={{fontSize:18,fontWeight:700,color:"var(--navy)",margin:"0 0 8px"}}>Atendimento registrado</h2>
          <p style={{fontSize:13,color:"var(--text2)",margin:"0 0 20px",lineHeight:1.5}}>
            Cliente cadastrado no CRM, {salvo.tipoDemanda==="Ação Judicial"?"processo":"demanda extrajudicial"} criado(a) e tarefa inicial atribuída.
          </p>
          <div style={{display:"flex",gap:8,justifyContent:"center"}}>
            <button onClick={novoAtendimento} style={btnPri}>+ Novo atendimento</button>
            <button onClick={()=>onConcluido(salvo)} style={btnSec}>Ir para o registro criado</button>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div>
      <div style={{marginBottom:16}}>
        <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Ficha de Atendimento</h1>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Registre um novo atendimento — cliente, parte adversa, fatos e próxima tarefa</p>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16}}>
        <div>
          <div style={{marginBottom:10}}>
            <span style={lbl}>Cliente já cadastrado? (opcional)</span>
            <select value={clienteExistenteId} onChange={e=>onSelecionarClienteExistente(e.target.value)} style={{...inp,padding:"8px 8px"}}>
              <option value="">Novo cliente — preencher abaixo</option>
              {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}</option>)}
            </select>
          </div>
          <PessoaForm titulo="Dados do Cliente" pessoa={cliente} setPessoa={setCliente}/>
          {textoQualificacaoCliente && (
            <div style={{background:"var(--accent-light)",border:"1px solid #C5DCF2",borderRadius:6,padding:"10px 12px",marginBottom:14}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                <span style={{fontSize:10,fontWeight:700,color:"var(--navy2)",textTransform:"uppercase",letterSpacing:".4px"}}>Texto p/ qualificação</span>
                <button onClick={()=>copiar(textoQualificacaoCliente,"cliente")} style={{...btnSec,fontSize:10,padding:"3px 9px"}}>{copiado==="cliente"?"✓ Copiado":"📋 Copiar"}</button>
              </div>
              <p style={{fontSize:11.5,lineHeight:1.5,margin:0,color:"var(--text1)"}}>{textoQualificacaoCliente}</p>
            </div>
          )}

          <PessoaForm titulo="Dados da Parte Adversa" pessoa={adversa} setPessoa={setAdversa}/>
          {textoQualificacaoAdversa && (
            <div style={{background:"var(--accent-light)",border:"1px solid #C5DCF2",borderRadius:6,padding:"10px 12px"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                <span style={{fontSize:10,fontWeight:700,color:"var(--navy2)",textTransform:"uppercase",letterSpacing:".4px"}}>Texto p/ qualificação</span>
                <button onClick={()=>copiar(textoQualificacaoAdversa,"adversa")} style={{...btnSec,fontSize:10,padding:"3px 9px"}}>{copiado==="adversa"?"✓ Copiado":"📋 Copiar"}</button>
              </div>
              <p style={{fontSize:11.5,lineHeight:1.5,margin:0,color:"var(--text1)"}}>{textoQualificacaoAdversa}</p>
            </div>
          )}
        </div>

        <div>
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"16px",marginBottom:14}}>
            <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--navy)",margin:"0 0 12px"}}>Fatos</p>
