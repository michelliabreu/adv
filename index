function PaginaExtrajudicial({demandas, setDemandas, clientes, tarefas, setTarefas, tiposCustom, setTiposCustom, onNovoCliente}){
  const [busca,setBusca] = useState("");
  const [filtroStatus,setFiltroStatus] = useState("todos");
  const [novo,setNovo] = useState(false);
  const [editando,setEditando] = useState(null);
  const [selecionada,setSelecionada] = useState(null);

  const nomeCliente = id => clientes.find(c=>c.id===id)?.nome || "—";

  const lista = useMemo(()=>{
    const q = busca.toLowerCase();
    return demandas.filter(d=>{
      const matchBusca = !q || nomeCliente(d.clienteId).toLowerCase().includes(q) || d.tipo.toLowerCase().includes(q) || (d.descricao||"").toLowerCase().includes(q);
      const matchStatus = filtroStatus==="todos" || d.status===filtroStatus;
      return matchBusca && matchStatus;
    }).sort((a,b)=>(b.id||0)-(a.id||0));
  },[demandas,busca,filtroStatus,clientes]);

  const salvar = form => {
    setDemandas(ds=>form.id ? ds.map(d=>d.id===form.id?form:d) : [...ds, {...form, id:Date.now()}]);
    setEditando(null); setNovo(false);
  };

  const addTarefa = (demandaId, titulo) => {
    if(!titulo.trim()) return;
    const demanda = demandas.find(d=>d.id===demandaId);
    setTarefas(ts=>[...ts, {
      id: Date.now(), titulo: titulo.trim(), responsavelId:"", procId:"", demandaId,
      clienteId: demanda?.clienteId||"", status:"pendente", prioridade:"media", prazo:"", desc:"", arquivada:false,
    }]);
  };
  const concluirTarefa = id => setTarefas(ts=>ts.map(t=>t.id===id?{...t,status:"concluido"}:t));
  const arquivarTarefa = id => setTarefas(ts=>ts.map(t=>t.id===id?{...t,arquivada:true}:t));
  const novoTipo = (tipo) => { if(!tiposCustom.includes(tipo)) setTiposCustom(tc=>[...tc,tipo]); };

  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};
  const cnt = s => demandas.filter(d=>d.status===s).length;

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Demandas Extrajudiciais</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Consultas, pareceres, negociações e procedimentos fora do processo judicial</p>
        </div>
        <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Nova demanda</button>
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"8px 14px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:8,marginBottom:12}}>
        <div style={{display:"flex",gap:0,flexWrap:"wrap"}}>
          <button onClick={()=>setFiltroStatus("todos")} style={{background:"none",border:"none",borderBottom:filtroStatus==="todos"?"2px solid var(--navy2)":"2px solid transparent",color:filtroStatus==="todos"?"var(--navy2)":"var(--text2)",padding:"5px 10px 7px",fontSize:10.5,fontWeight:filtroStatus==="todos"?700:500,cursor:"pointer",textTransform:"uppercase",letterSpacing:".4px"}}>Todas ({demandas.length})</button>
          {Object.entries(STATUS_EXTRA_CFG).map(([k,v])=>(
            <button key={k} onClick={()=>setFiltroStatus(k)} style={{background:"none",border:"none",borderBottom:filtroStatus===k?"2px solid var(--navy2)":"2px solid transparent",color:filtroStatus===k?"var(--navy2)":"var(--text2)",padding:"5px 10px 7px",fontSize:10.5,fontWeight:filtroStatus===k?700:500,cursor:"pointer",textTransform:"uppercase",letterSpacing:".4px",whiteSpace:"nowrap"}}>{v.label} ({cnt(k)})</button>
          ))}
        </div>
        <input placeholder="Buscar…" value={busca} onChange={e=>setBusca(e.target.value)} style={{fontSize:12,padding:"6px 11px",borderRadius:5,border:"1px solid var(--border2)",background:"#fff",color:"var(--text1)",width:180}}/>
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden"}}>
        <div style={{display:"grid",gridTemplateColumns:"1.6fr 1.2fr 1fr 1fr .9fr",padding:"9px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)"}}>
          {["Cliente","Tipo / Descrição","Responsável","Prazo","Status"].map(h=><span key={h} style={hdr}>{h}</span>)}
        </div>
        {lista.length===0?<div style={{padding:"2.5rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhuma demanda encontrada.</div>:lista.map((d,i)=>{
          const cfg = STATUS_EXTRA_CFG[d.status] || STATUS_EXTRA_CFG.em_andamento;
          const urg = d.prazo && diasRest(d.prazo)<=3 && d.status!=="concluido" && d.status!=="arquivado";
          return (
            <div key={d.id} onClick={()=>setSelecionada(d)} style={{display:"grid",gridTemplateColumns:"1.6fr 1.2fr 1fr 1fr .9fr",padding:"11px 14px",alignItems:"center",borderBottom:i<lista.length-1?"1px solid var(--border1)":"none",cursor:"pointer",background:urg?"rgba(185,28,28,.03)":"transparent"}}>
              <p style={{fontSize:13,fontWeight:600,margin:0}}>{nomeCliente(d.clienteId)}</p>
              <div><Pill bg="var(--purple-bg)" color="var(--purple)" label={d.tipo} sm/><p style={{fontSize:11,color:"var(--text2)",margin:"4px 0 0",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{d.descricao}</p></div>
              <p style={{fontSize:12,color:"var(--text2)",margin:0}}>{d.responsavel||"—"}</p>
              <p style={{fontSize:12,margin:0,color:urg?"var(--red)":"var(--text1)",fontWeight:urg?700:400}}>{d.prazo?fmtData(d.prazo):"—"}</p>
              <div style={{display:"flex",alignItems:"center"}}><span style={{width:7,height:7,borderRadius:"50%",background:cfg.dot,marginRight:5,flexShrink:0}}/><span style={{fontSize:10,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".4px",fontWeight:600}}>{cfg.label}</span></div>
            </div>
          );
        })}
      </div>
      <p style={{fontSize:11,color:"var(--text2)",marginTop:8,textAlign:"right"}}>{lista.length} demanda(s)</p>

      {(novo||editando)&&<ModalFormExtrajudicial demanda={editando} clientes={clientes} tiposCustom={tiposCustom} onSave={salvar} onClose={()=>{setNovo(false);setEditando(null);}} onNovoCliente={onNovoCliente} onNovoTipo={novoTipo}/>}
      {selecionada&&!editando&&<ModalDetalheExtrajudicial demanda={selecionada} cliente={clientes.find(c=>c.id===selecionada.clienteId)} tarefasDaDemanda={tarefas.filter(t=>t.demandaId===selecionada.id)} onClose={()=>setSelecionada(null)} onEdit={d=>{setEditando(d);setSelecionada(null);}} onAddTarefa={addTarefa} onConcluirTarefa={concluirTarefa} onArquivarTarefa={arquivarTarefa}/>}
    </div>
  );
}

