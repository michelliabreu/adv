          {[["procuracao","Procuração"],["contrato","Contrato de Honorários"]].map(([k,l])=>(
            <button key={k} onClick={()=>setAba(k)} style={{padding:"7px 16px",fontSize:11.5,fontWeight:600,border:"none",borderRadius:5,cursor:"pointer",background:aba===k?"#fff":"transparent",color:aba===k?"var(--navy2)":"var(--text2)",boxShadow:aba===k?"0 1px 3px rgba(0,0,0,.1)":"none"}}>{l}</button>
          ))}
