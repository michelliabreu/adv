function tentarAcharProcessoPorTexto(texto, processos){
  const matchNum = texto.match(/\d{7}-?\d{0,2}\.?\d{0,4}\.?\d\.?\d{2}\.?\d{4}/);
  if(!matchNum) return null;
  const num = matchNum[0].replace(/\D/g,"");
  return processos.find(p=>{
    const pNum = p.numero.replace(/\D/g,"");
    return pNum && (pNum===num || pNum.slice(0,15)===num.slice(0,15));
  }) || null;
}

function ColarProcessoIA({processos, clientes, setProcessos, setClientes, onAbrirProcesso}){
  const [aberto, setAberto] = useState(false);
  const [texto, setTexto] = useState("");
  const [carregando, setCarregando] = useState(false);
  const [erro, setErro] = useState("");
  const [resultado, setResultado] = useState(null); // {tipo:"existente"|"novo", ...}
  const [novoProcEditavel, setNovoProcEditavel] = useState(null);
  const [clienteEscolhidoId, setClienteEscolhidoId] = useState("");

  const resetar = () => { setTexto(""); setResultado(null); setNovoProcEditavel(null); setErro(""); setClienteEscolhidoId(""); };

  const processar = async () => {
    if(!texto.trim()){ setErro("Cole o texto com as informações do processo."); return; }
    setErro(""); setCarregando(true); setResultado(null);

    const procExistente = tentarAcharProcessoPorTexto(texto, processos);

    try {
      const chamarIA = async (systemPrompt, userContent, maxTokens=1500) => {
        let res;
        try {
          res = await fetch(IA_PROXY_URL, {
            method:"POST", headers:{"Content-Type":"application/json","Authorization":"Bearer "+SUPABASE_KEY},
            body: JSON.stringify({ model:"claude-sonnet-4-6", max_tokens:maxTokens, system:systemPrompt, messages:[{role:"user",content:userContent}] })
          });
        } catch(e){ throw new Error("Sem conexão com o serviço de IA — verifique a internet."); }
        if(!res.ok){
          let d=""; try{const b=await res.json();d=b?.error?.message||"";}catch(_){}
          throw new Error(`Erro HTTP ${res.status}.${d?` ${d}`:""}`);
        }
        const data = await res.json();
        const txt = data.content?.find(b=>b.type==="text")?.text||"";
        if(!txt) throw new Error("A IA retornou resposta vazia.");
        try{ return JSON.parse(txt.replace(/```json|```/g,"").trim()); }
        catch(e){ throw new Error(`JSON inválido na resposta da IA. Início: "${txt.slice(0,120)}"`); }
      };

      if(procExistente){
        const parsed = await chamarIA(
          `Você extrai movimentações/andamentos processuais de um texto colado. Retorne SOMENTE um JSON array, sem texto adicional:\n[{"data":"YYYY-MM-DD","desc":"texto do andamento"}]\nSe não houver data identificável, use string vazia. Não invente conteúdo.`,
          texto
        );
        setResultado({tipo:"existente", proc:procExistente, andamentos: Array.isArray(parsed)?parsed:[]});
      } else {
        const parsed = await chamarIA(
          `Você é um assistente jurídico. Extraia dados estruturados de processo a partir de um texto colado (pode ser intimação, consulta de tribunal, e-mail, relatório etc). Retorne SOMENTE um JSON válido, sem texto adicional:\n{"numero":"","autor":"","reu":"","vara":"","assunto":"","classificacao":"","valorCausa":"","andamento":{"data":"YYYY-MM-DD","desc":""}}\nUse string vazia quando não houver informação. Nunca invente dados não presentes no texto.`,
          texto
        );
        setResultado({tipo:"novo"});
        setNovoProcEditavel(parsed);
      }
    } catch(e){
      setErro(e.message || "Não foi possível interpretar o texto. Tente novamente ou cole um trecho mais claro.");
    }
    setCarregando(false);
  };

  const confirmarAndamentosExistente = () => {
    const { proc, andamentos } = resultado;
    const novos = andamentos.filter(a=>a.desc).map(a=>({data: a.data || hoje.toISOString().slice(0,10), desc: a.desc, fonte:"manual"}));
    if(novos.length===0){ setAberto(false); resetar(); return; }
    setProcessos(ps=>ps.map(p=>{
      if(p.id!==proc.id) return p;
      const mesclados = [...(p.andamentos||[]), ...novos].sort((a,b)=>(a.data||"").localeCompare(b.data||""));
      return {...p, andamentos: mesclados};
    }));
    setAberto(false); resetar();
    onAbrirProcesso(proc);
  };

  const confirmarNovoProcesso = () => {
    if(!novoProcEditavel.autor && !novoProcEditavel.numero){ alert("Preencha ao menos o autor ou o número do processo."); return; }
    let clienteId = clienteEscolhidoId ? parseInt(clienteEscolhidoId) : null;
    if(!clienteId && novoProcEditavel.autor){
      clienteId = Date.now();
      setClientes(cs=>[...cs, {id:clienteId, nome:novoProcEditavel.autor, cpf:"", email:"", telefone:"", endereco:"", obs:"Criado via colagem de texto na Visão Geral."}]);
    }
    const novoId = Date.now()+1;
    const andamentos = novoProcEditavel.andamento?.desc ? [{data: novoProcEditavel.andamento.data || hoje.toISOString().slice(0,10), desc: novoProcEditavel.andamento.desc, fonte:"manual"}] : [];
    setProcessos(ps=>[...ps, {
      id: novoId, clienteId, numero: novoProcEditavel.numero||"", tipo:"judicial",
      classificacao: novoProcEditavel.classificacao||"", autor: novoProcEditavel.autor||"", reu: novoProcEditavel.reu||"",
      vara: novoProcEditavel.vara||"", responsavel:"", status:"em_andamento", prazo:"", debito:null,
      assunto: novoProcEditavel.assunto||"", valorCausa: novoProcEditavel.valorCausa||"",
      andamentos, documentos:[], checklist:{}, obs:"Criado via colagem de texto na Visão Geral.",
    }]);
    setAberto(false); resetar();
    onAbrirProcesso({id:novoId});
  };

  if(!aberto){
    return (
      <button onClick={()=>setAberto(true)} style={{
        width:"100%", textAlign:"left", background:"#fff", border:"1px dashed var(--border2)", borderRadius:10,
        padding:"13px 16px", cursor:"pointer", marginBottom:14, display:"flex", alignItems:"center", gap:10,
        color:"var(--text2)", fontSize:12.5,
      }}>
        <span style={{fontSize:16}}>✨</span>
        <span>Colar informações de um processo (a IA identifica e cria, ou lança o andamento se já existir)…</span>
      </button>
    );
  }

  return (
    <div style={{background:"#fff", border:"1px solid var(--border1)", borderRadius:10, padding:"16px 18px", marginBottom:14}}>
      <div style={{display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10}}>
        <p style={{fontSize:12.5, fontWeight:700, color:"var(--text1)", margin:0}}>✨ Colar e processar com IA</p>
        <button onClick={()=>{setAberto(false);resetar();}} style={{background:"none",border:"none",cursor:"pointer",fontSize:18,color:"var(--text3)",padding:0,lineHeight:1}}>×</button>
      </div>

      {!resultado && (
        <>
          <textarea value={texto} onChange={e=>setTexto(e.target.value)} placeholder="Cole aqui o texto de uma intimação, consulta processual, e-mail, ou qualquer informação sobre um processo…" style={{width:"100%",minHeight:120,fontSize:12,padding:"10px",borderRadius:7,border:"1px solid var(--border2)",resize:"vertical",boxSizing:"border-box",fontFamily:"inherit",marginBottom:10}}/>
          {erro && <p style={{fontSize:12,color:"var(--red)",marginBottom:10}}>{erro}</p>}
          <button onClick={processar} disabled={carregando} style={{...btnPri, opacity:carregando?.7:1}}>{carregando?"Analisando…":"✨ Processar"}</button>
        </>
      )}

      {resultado?.tipo==="existente" && (
        <div>
          <div style={{background:"var(--green-bg)", border:"1px solid #A8DDB8", borderRadius:7, padding:"10px 13px", marginBottom:12, fontSize:12.5, color:"var(--green)"}}>
            ✓ Processo já cadastrado encontrado: <strong>{resultado.proc.numero}</strong> — {resultado.proc.autor}
          </div>
          {resultado.andamentos.length===0 ? (
            <p style={{fontSize:12,color:"var(--text2)"}}>Nenhum andamento novo foi identificado no texto colado.</p>
          ) : (
            <div style={{display:"flex", flexDirection:"column", gap:6, marginBottom:12}}>
              {resultado.andamentos.map((a,i)=>(
                <div key={i} style={{border:"1px solid var(--border1)", borderRadius:6, padding:"8px 11px", fontSize:12}}>
                  <span style={{color:"var(--text2)", marginRight:8}}>{a.data?fmtData(a.data):"sem data"}</span>{a.desc}
                </div>
              ))}
            </div>
          )}
          <div style={{display:"flex", gap:8, justifyContent:"flex-end"}}>
            <button onClick={()=>{setAberto(false);resetar();}} style={btnSec}>Cancelar</button>
            <button onClick={confirmarAndamentosExistente} style={btnPri}>+ Lançar no processo</button>
          </div>
        </div>
      )}

      {resultado?.tipo==="novo" && novoProcEditavel && (
        <div>
          <div style={{background:"var(--accent-light)", border:"1px solid #C5DCF2", borderRadius:7, padding:"10px 13px", marginBottom:12, fontSize:12.5, color:"var(--accent)"}}>
            Não encontrei esse processo no sistema — revise os dados extraídos e confirme para criar.
          </div>
          <div style={{display:"flex", flexDirection:"column", gap:8, marginBottom:12}}>
            <div><span style={lbl}>Número do processo</span><input value={novoProcEditavel.numero||""} onChange={e=>setNovoProcEditavel(x=>({...x,numero:e.target.value}))} style={inp}/></div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
              <div><span style={lbl}>Autor</span><input value={novoProcEditavel.autor||""} onChange={e=>setNovoProcEditavel(x=>({...x,autor:e.target.value}))} style={inp}/></div>
              <div><span style={lbl}>Réu</span><input value={novoProcEditavel.reu||""} onChange={e=>setNovoProcEditavel(x=>({...x,reu:e.target.value}))} style={inp}/></div>
            </div>
            <div><span style={lbl}>Vara</span><input value={novoProcEditavel.vara||""} onChange={e=>setNovoProcEditavel(x=>({...x,vara:e.target.value}))} style={inp}/></div>
