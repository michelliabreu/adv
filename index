                  <div style={{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
                    <span style={{fontSize:12.5,fontWeight:500,color:"var(--text2)",letterSpacing:".2px"}}>{p.numero}</span>
                    {p.sistema&&<span style={{fontSize:9,fontWeight:600,color:"var(--text3)",textTransform:"uppercase",letterSpacing:".3px"}}>{p.sistema}</span>}
                    {p.arquivado&&<span style={{fontSize:9,fontWeight:600,color:"var(--text3)",textTransform:"uppercase",letterSpacing:".3px"}}>· Arquivado</span>}
                  </div>
                  {p.assunto&&<p style={{fontSize:11,color:"var(--text2)",margin:"4px 0 0",lineHeight:1.3}}>{p.assunto}</p>}
                </div>

                {/* Coluna 2: Cliente */}
                <div style={{minWidth:0}}>
                  <p style={{fontSize:12.5,color:"var(--text1)",margin:0,lineHeight:1.4,overflow:"hidden",textOverflow:"ellipsis",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical"}}>{cli?cli.nome:"—"}</p>
                </div>

                {/* Coluna 3: Ação / Foro */}
                <div style={{minWidth:0}}>
                  {p.classificacao&&<p style={{fontSize:12,color:"var(--text1)",margin:"0 0 2px",lineHeight:1.3}}>{CC[p.classificacao]?.label||p.classificacao}</p>}
                  <p style={{fontSize:11,color:"var(--text2)",margin:0,lineHeight:1.35,overflow:"hidden",textOverflow:"ellipsis",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical"}}>{p.vara||"—"}</p>
                  {p.responsavel&&<p style={{fontSize:10.5,color:"var(--text3)",margin:"2px 0 0"}}>👤 {p.responsavel}</p>}
                </div>

                {/* Coluna 4: Última movimentação */}
                <div style={{minWidth:0}}>
                  {ultimoAto?(
                    <React.Fragment>
                      <p style={{fontSize:11.5,color:"var(--text1)",margin:0,fontWeight:500}}>{fmtData(ultimoAto.data)}</p>
                      <p style={{fontSize:10,color:"var(--text3)",margin:"2px 0 0",lineHeight:1.3,overflow:"hidden",textOverflow:"ellipsis",display:"-webkit-box",WebkitLineClamp:2,WebkitBoxOrient:"vertical"}}>{ultimoAto.desc}</p>
                    </React.Fragment>
                  ):<span style={{fontSize:11,color:"var(--text3)"}}>—</span>}
                  {p.prazo&&<p style={{fontSize:10.5,color:urg?"var(--red)":"var(--text2)",margin:"4px 0 0",fontWeight:urg?700:400}}>⏱ Prazo: {fmtData(p.prazo)}</p>}
                </div>

                {/* Coluna 5: Status */}
                <div style={{display:"flex",alignItems:"center"}}>
                  {(()=>{
                    const prazoUrgente = pp?.ativo && pp.vencimento && diasRest(pp.vencimento)<=3;
                    if(prazoUrgente){
                      const vencido = diasRest(pp.vencimento)<0;
                      return <span style={{display:"inline-flex",alignItems:"center",gap:4,fontSize:9.5,fontWeight:700,padding:"3px 8px",borderRadius:20,background:vencido?"var(--red-bg)":"var(--amber-bg)",color:vencido?"var(--red)":"var(--amber)",textTransform:"uppercase",letterSpacing:".3px",whiteSpace:"nowrap"}}>⚠ Prazo</span>;
                    }
                    return (
                      <span style={{display:"inline-flex",alignItems:"center",gap:5}}>
                        <span style={{width:7,height:7,borderRadius:"50%",background:SC[normalizarStatus(p.status)]?.dot,display:"inline-block",flexShrink:0}}/>
                        <span style={{fontSize:10,color:"var(--text2)",fontWeight:500}}>{SC[normalizarStatus(p.status)]?.label}</span>
                      </span>
                    );
                  })()}
                </div>
              </div>

              {/* Ações — aparecem ao passar o mouse */}
              <div className="proc-actions" style={{position:"absolute",right:14,top:"50%",transform:"translateY(-50%)",display:"flex",gap:4,background:"#fff",boxShadow:"-8px 0 12px rgba(255,255,255,.9)",paddingLeft:8}}>
                <button onClick={e=>{e.stopPropagation();setColandoMovPara(p);}} title="Colar movimentação" style={btnIcon}>📋</button>
                <button onClick={e=>{e.stopPropagation();abrirAnalisePrazo(p);}} title="Analisar prazo com IA" style={btnIcon}>⏱</button>
                <button onClick={e=>{e.stopPropagation();setMapaProc(p);}} title="Mapa do processo" style={btnIcon}>🗺</button>
                {us.erro&&<button onClick={e=>{e.stopPropagation();setErroDetalheAberto({proc:p, erro:us.erro});}} title="Ver erro" style={{...btnIcon,color:"var(--red)"}}>⚠</button>}
                {us.done&&us.novos>0&&<button onClick={e=>{e.stopPropagation();atualizarProcesso(p.id);}} title={`${us.novos} novo(s)`} style={{...btnIcon,color:"var(--accent)"}}>↻</button>}
                <button onClick={e=>{e.stopPropagation();excluirProcesso(p.id);}} title="Excluir" style={{...btnIcon,color:"var(--red)"}}>🗑</button>
              </div>
            </div>
          );
        })}
      </div>
      <p style={{fontSize:11,color:"var(--text2)",marginTop:8,textAlign:"right"}}>{lista.length} registro(s)</p>
      {acaoLote&&<ModalAcaoLote tipo={acaoLote} qtd={selecionados.size} clientes={clientes} classificacoes={[...CLASSIFICACOES_VALIDAS,...(classificacoesCustom||[])]} onAplicar={aplicarLote} onClose={()=>setAcaoLote(null)}/>}
      {selected&&!editando&&<ModalDetalhe p={selected} cliente={clienteDe(selected)} clientes={clientes} processos={processos} onClose={()=>setSelected(null)} onEdit={p=>{setEditando(p);setSelected(null);}} onChecklistUpdate={updateChecklist} onSavePrazo={abrirAnalisePrazo} onSaveDebito={saveDebito} onCumprirPrazo={cumprirPrazo} onToggleArquivado={toggleArquivado} onAddAndamento={addAndamento} onSaveAssunto={saveAssunto} onAddTarefaProcesso={addTarefaProcesso} onSaveDriveLink={saveDriveLink} tarefasDoProcesso={(tarefas||[]).filter(t=>t.procId===selected.id)} onConcluirTarefaProc={concluirTarefaProc} onArquivarTarefaProc={arquivarTarefaProc} onSaveVinculo={saveVinculo} onRemoverVinculo={removerVinculo} onAbrirOutroProcesso={proc=>setSelected(proc)} onRegistrarExito={registrarExito} onSaveAudiencia={saveAudiencia} onExcluir={excluirProcesso} onSaveCampo={(id,campo,valor)=>{setProcessos(ps=>ps.map(x=>x.id===id?{...x,[campo]:valor}:x));setSelected(s=>s&&s.id===id?{...s,[campo]:valor}:s);}} onSavePrazoComTarefa={salvarPrazoComTarefa}/>}
      {(editando||novo)&&<ModalFormProc processo={editando} clientes={clientes} onSave={salvar} onClose={()=>{setEditando(null);setNovo(false);}} onNovoCliente={onNovoCliente} classificacoesCustom={classificacoesCustom||[]} onNovaClassificacao={nova=>{ if(setClassificacoesCustom) setClassificacoesCustom(cs=>cs.includes(nova)?cs:[...cs,nova]); }}/>}
      {mapaProc&&<ModalMapa proc={mapaProc} mapaData={mapas[mapaProc.id]||defaultMap()} onChange={data=>setMapas(m=>({...m,[mapaProc.id]:data}))} onClose={()=>setMapaProc(null)}/>}
      {analisandoPrazo&&<ModalConfirmarPrazo proc={analisandoPrazo} sugestao={sugestaoPrazo} dataAndamento={[...(analisandoPrazo.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data))[0]?.data||""} onConfirm={salvarPrazo} onClose={()=>{setAnalisandoPrazo(null);setSugestaoPrazo(null);}}/>}
      {erroDetalheAberto&&(
        <div onClick={e=>e.target===e.currentTarget&&setErroDetalheAberto(null)} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.5)",zIndex:600,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
          <div style={{background:"#fff",width:460,maxWidth:"100%",borderRadius:10,padding:"1.5rem",boxShadow:"0 20px 50px rgba(0,0,0,.25)"}}>
            <p style={{fontSize:10,color:"var(--red)",textTransform:"uppercase",letterSpacing:".7px",margin:"0 0 8px",fontWeight:700}}>⚠ Falha ao atualizar via DataJud</p>
            <p style={{fontSize:12,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 12px"}}>{erroDetalheAberto.proc.numero}</p>
            <div style={{background:"var(--red-bg)",border:"1px solid #F3B8B8",borderRadius:6,padding:"12px 14px",fontSize:13,color:"var(--red)",lineHeight:1.5,marginBottom:16}}>
              {erroDetalheAberto.erro || "Erro desconhecido — nenhuma mensagem foi capturada."}
            </div>
            <p style={{fontSize:11,color:"var(--text2)",lineHeight:1.5,marginBottom:16}}>
              Se a mensagem mencionar bloqueio de conexão/CORS, isso é uma restrição do navegador ao acessar a API do governo diretamente — não há solução simples do nosso lado. Se mencionar erro 401/403, a chave de API pode precisar ser renovada em datajud.cnj.jus.br.
            </p>
            <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
              <button onClick={()=>setErroDetalheAberto(null)} style={btnPri}>Fechar</button>
