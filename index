        <p style={{fontSize:13,color:"#374151",lineHeight:1.6,margin:"0 0 16px"}}>{sbErroInicial || "A conexão com o banco de dados não pôde ser iniciada."}</p>
        <p style={{fontSize:12,color:"#6B7280",lineHeight:1.6,margin:"0 0 16px"}}>O sistema precisa de internet para carregar alguns componentes. Verifique sua conexão e recarregue. Se estiver abrindo o arquivo direto do seu computador (file://), isso é normal e esperado — basta ter internet ativa.</p>
        <button onClick={()=>window.location.reload()} style={{width:"100%",padding:"10px",fontSize:13,fontWeight:600,borderRadius:7,border:"none",background:"#5B5BD6",color:"#fff",cursor:"pointer"}}>Recarregar página</button>
      </div>
    </div>
  );

  if(verificando) return <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",fontFamily:"Inter,sans-serif",color:"#6B7280",fontSize:13}}>Verificando acesso…</div>;
  if(!sessao) return <TelaLogin/>;

  return <AppPrincipal sessao={sessao} setSincStatus={setSincStatus} sincStatus={sincStatus}/>;
}

function AppPrincipal({sessao, setSincStatus, sincStatus}){
  const [pagina,setPagina]=useState("dashboard");
  const [carregandoDados,setCarregandoDados]=useState(true);
  const [processos,setProcessos]=useState([]);
  const [parcelas,setParcelas]=useState([]);
  const [clientes,setClientes]=useState([]);
  const [mapas,setMapas]=useState({});
  const [abrirProcessoId,setAbrirProcessoId]=useState(null);
  const [pedirNovoCliente,setPedirNovoCliente]=useState(false);
  const [equipe,setEquipe]=useState(EQUIPE0);
  const [tarefas,setTarefas]=useState([]);
  const [publicacoes,setPublicacoes]=useState([]);
  const [agenda,setAgenda]=useState([]);
  const [demandas,setDemandas]=useState([]);
  const [tiposExtraCustom,setTiposExtraCustom]=useState([]);
  const [classificacoesCustom,setClassificacoesCustom]=useState([]);
  const [abrirDemandaId,setAbrirDemandaId]=useState(null);
  const uid = sessao?.user?.id;
  const [erroCarga,setErroCarga]=useState("");
  const [erroSalvar,setErroSalvar]=useState("");
  const tryParse = (val, fallback) => { try { return val ? (typeof val==="string" ? JSON.parse(val) : val) : fallback; } catch(_){ return fallback; } };
  const prevIds = React.useRef({}); // snapshot dos IDs conhecidos de cada tabela (para exclusão segura)
  const carregandoRef = React.useRef(true); // sempre reflete o valor atual de carregandoDados
  const alertouErro = React.useRef(false); // garante que o alerta de erro apareça só uma vez
  const snapshots = React.useRef({}); // assinatura do último estado salvo de cada registro (salva só o que mudou)
  React.useEffect(()=>{ carregandoRef.current = carregandoDados; },[carregandoDados]);

  // ── Carregar dados do Supabase na inicialização ──────────
  React.useEffect(()=>{
    if(!uid) return;
    (async()=>{
      setCarregandoDados(true);
      setErroCarga("");
      try {
        const carregarSeguro = async (tabela) => {
          const { data, error } = await sb.from(tabela).select("*");
          if(error) throw new Error(`Tabela "${tabela}": ${error.message}`);
          return data;
        };
        const [procs, clts, parcRows, tarefRows, agRows, demRows, cfg] = await Promise.all([
          carregarSeguro("processos"),
          carregarSeguro("clientes"),
          carregarSeguro("parcelas"),
          carregarSeguro("tarefas"),
          carregarSeguro("agenda"),
          carregarSeguro("demandas"),
          carregarSeguro("configuracoes"),
        ]);
        // Merge inteligente: insere os registros iniciais (por ID) que ainda não existem no banco,
        // e retorna a lista COMPLETA (o que já existia + os recém-inseridos) para exibir na hora.
        const mergeInserir = async (tabela, registrosLocais, registrosRemoto, preparar) => {
          const remoto = registrosRemoto || [];
          const idsRemoto = new Set(remoto.map(r=>r.id));
          const novos = registrosLocais.filter(r=>!idsRemoto.has(r.id));
          let resultado;
          if(novos.length>0){
            const preparados = novos.map(r=>preparar ? preparar(r) : {...r, user_id:uid});
            const {data:inseridos, error} = await sb.from(tabela).insert(preparados).select();
            if(error){
              console.error("Erro seed", tabela, error.message);
              resultado = [...remoto, ...preparados];
            } else {
              resultado = [...remoto, ...(inseridos||preparados)];
            }
          } else {
            resultado = remoto;
          }
          // Garante que não haja duplicatas por id (à prova de falhas)
          const vistos = new Set();
          return resultado.filter(r=>{
            if(!r || r.id===undefined || vistos.has(r.id)) return false;
            vistos.add(r.id);
            return true;
          });
        };

        const cltsFinais = await mergeInserir("clientes", CLIENTES0, clts, c=>({...c, user_id:uid}));
        setClientes(cltsFinais.length ? cltsFinais : CLIENTES0);

        const procsPreparar = p=>({...p, status:normalizarStatus(p.status), user_id:uid,
          andamentos:JSON.stringify(p.andamentos||[]), partes:JSON.stringify(p.partes||[]),
          checklist:JSON.stringify(p.checklist||{}), exitos:JSON.stringify(p.exitos||[]),
          debito:JSON.stringify(p.debito||null)});
        const procsFinais = await mergeInserir("processos", PROCS0, procs, procsPreparar);
        if(procsFinais && procsFinais.length) {
          setProcessos(procsFinais.map(p=>({...p, andamentos:tryParse(p.andamentos,[]), partes:tryParse(p.partes,[]), checklist:tryParse(p.checklist,{}), exitos:tryParse(p.exitos,[]), debito:tryParse(p.debito,null)})));
        } else {
          setProcessos(PROCS0.map(p=>({...p, status:normalizarStatus(p.status)})));
        }

        if(parcRows) setParcelas(parcRows);
        if(tarefRows) setTarefas(tarefRows.map(t=>({...t})));
        if(agRows) setAgenda(agRows.map(a=>({...a})));
        if(demRows) setDemandas(demRows.map(d=>({...d})));
        if(cfg && cfg.length>0){
          const c = cfg[0];
          if(c.tipos_extra) setTiposExtraCustom(tryParse(c.tipos_extra,[]));
          if(c.classificacoes_custom) setClassificacoesCustom(tryParse(c.classificacoes_custom,[]));
        }

        // Inicializa o snapshot de IDs conhecidos (para exclusão segura no auto-save)
        const setIds = arr => new Set((arr||[]).map(r=>r.id).filter(Boolean));
        prevIds.current = {
          processos: setIds(procsFinais),
          clientes: setIds(cltsFinais),
          parcelas: setIds(parcRows),
          tarefas: setIds(tarefRows),
          agenda: setIds(agRows),
          demandas: setIds(demRows),
        };
      } catch(e){
        console.error("Erro ao carregar dados:", e);
        setErroCarga(e.message || "Erro desconhecido ao carregar os dados.");
      }
      setCarregandoDados(false);
    })();
  },[uid]);

  // ── Auto-save: salva no Supabase quando dados mudam ─────
  // SEGURO: nunca apaga em massa. Apenas insere/atualiza (upsert).
  // Exclusões são feitas explicitamente pela função excluirDoBanco.
  const saveTimer = React.useRef({});
  // Colunas válidas por tabela — envia só o que existe no banco, evitando que um campo
  // extra (ex: coluna não criada) faça o upsert inteiro falhar e nada ser salvo.
  const COLUNAS = {
    processos: ["id","clienteId","numero","sistema","tipo","assunto","autor","reu","partes","vara","responsavel","valorCausa","classificacao","status","prazo","prazoProcessual","obs","arquivado","situacaoArquivo","audiencia","andamentos","checklist","exitos","debito","documentos","driveLink","vinculo"],
    clientes: ["id","nome","cpf","rg","profissao","estadoCivil","nacionalidade","telefone","email","endereco","obs"],
    parcelas: ["id","procId","cliente","totalContrato","parcela","totalParcelas","valor","vencimento","pago"],
    tarefas: ["id","titulo","responsavelId","procId","demandaId","clienteId","status","prioridade","prazo","desc","arquivada"],
    agenda: ["id","titulo","tipo","dataHora","procId","clienteId","responsavelId","local","confirmado","obs","_origemAudiencia","_origemPrazo"],
    demandas: ["id","clienteId","tipo","descricao","status","responsavel","prazo","valorCausa","obs"],
  };
  const JSON_FIELDS = ["andamentos","partes","checklist","exitos","debito","documentos","audiencia","vinculo"];
  const autoSave = React.useCallback((tabela, dados, delay=1200) => {
    if(carregandoRef.current) return;
    if(!Array.isArray(dados)) return;
    clearTimeout(saveTimer.current[tabela]);
    Promise.resolve().then(()=>setSincStatus("salvando"));
    saveTimer.current[tabela] = setTimeout(async()=>{
      try {
        const cols = COLUNAS[tabela];
        const prepararRegistro = (d) => {
          const obj = { user_id: uid };
          (cols||Object.keys(d)).forEach(c=>{
            if(d[c]===undefined) return;
            obj[c] = JSON_FIELDS.includes(c) ? JSON.stringify(d[c]) : d[c];
          });
          return obj;
        };

        // Salva só os registros que MUDARAM desde o último salvamento (comparação por snapshot).
        if(dados.length>0){
          const snap = snapshots.current[tabela] || {};
          const alterados = dados.filter(d=>{
            if(!d.id) return false;
            const assinatura = JSON.stringify(prepararRegistro(d));
            return snap[d.id] !== assinatura;
          });

          if(alterados.length>0){
            // Salva um por um, isolando qualquer registro problemático
            const novoSnap = {...snap};
            let primeiroErro = null;
            for(const d of alterados){
              const registro = prepararRegistro(d);
              const { error } = await sb.from(tabela).upsert(registro, {onConflict:"id"});
              if(error){
                if(!primeiroErro) primeiroErro = {error, id:d.id};
                console.error(`Erro ao salvar ${tabela} id=${d.id}:`, error.message);
              } else {
                novoSnap[d.id] = JSON.stringify(registro); // só marca como salvo se deu certo
              }
            }
            snapshots.current[tabela] = novoSnap;
            if(primeiroErro) throw primeiroErro.error;
          }
        }

        // Exclusão SEGURA: só remove do banco itens removidos pelo usuário (remoção parcial).
        const idsAtuais = new Set(dados.map(d=>d.id).filter(Boolean));
        const idsAnteriores = prevIds.current[tabela];
        if(idsAnteriores && idsAnteriores.size>0){
          const removidos = [...idsAnteriores].filter(id=>!idsAtuais.has(id));
          if(removidos.length>0 && removidos.length < idsAnteriores.size){
            await sb.from(tabela).delete().eq("user_id",uid).in("id",removidos);
          }
        }
        prevIds.current[tabela] = idsAtuais;

        setSincStatus("salvo");
        setErroSalvar("");
        setTimeout(()=>setSincStatus(""),2500);
      } catch(e){
        setSincStatus("erro");
        const partes = [];
        if(e.message) partes.push(e.message);
        if(e.code) partes.push(`código ${e.code}`);
        if(e.details) partes.push(e.details);
        if(e.hint) partes.push("Dica: "+e.hint);
        const msg = `Falha ao salvar em "${tabela}": ${partes.join(" — ")||"erro desconhecido"}`;
        setErroSalvar(msg);
        console.error("Erro ao salvar:", tabela, JSON.stringify(e));
        // Mostra o erro completo numa janela na primeira falha, para diagnóstico
        if(!alertouErro.current){
          alertouErro.current = true;
          alert("ERRO DE SALVAMENTO (copie este texto e envie):\n\n"+msg+"\n\nuser_id atual: "+(uid||"(vazio!)"));
        }
      }
    }, delay);
  },[uid]);

  // Wraps de setXxx que disparam auto-save
  const setProcessosSaved = React.useCallback(v=>{ setProcessos(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("processos",n); return n; }); },[autoSave]);
  const setClientesSaved = React.useCallback(v=>{ setClientes(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("clientes",n); return n; }); },[autoSave]);
  const setParcelasSaved = React.useCallback(v=>{ setParcelas(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("parcelas",n); return n; }); },[autoSave]);
  const setTarefasSaved = React.useCallback(v=>{ setTarefas(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("tarefas",n); return n; }); },[autoSave]);
  const setAgendaSaved = React.useCallback(v=>{ setAgenda(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("agenda",n); return n; }); },[autoSave]);
  const setDemandasSaved = React.useCallback(v=>{ setDemandas(prev=>{ const n=typeof v==="function"?v(prev):v; autoSave("demandas",n); return n; }); },[autoSave]);

  if(erroCarga) return (
    <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",fontFamily:"Inter,sans-serif",padding:20}}>
      <div style={{background:"#fff",border:"1px solid #E8E9ED",borderRadius:12,padding:"2rem",maxWidth:460,boxShadow:"0 4px 24px rgba(15,17,23,.07)"}}>
        <p style={{fontSize:30,margin:"0 0 12px"}}>⚠️</p>
        <h2 style={{fontSize:18,fontWeight:700,color:"#0F1117",margin:"0 0 10px"}}>Não foi possível carregar os dados</h2>
        <div style={{background:"#FDECEE",border:"1px solid #FCA5A5",borderRadius:6,padding:"10px 12px",fontSize:12,color:"#B91C1C",marginBottom:14,fontFamily:"monospace",wordBreak:"break-word"}}>{erroCarga}</div>
        <p style={{fontSize:13,color:"#374151",lineHeight:1.6,margin:"0 0 8px"}}>
          {erroCarga.includes("does not exist")||erroCarga.includes("schema")||erroCarga.includes("relation")
            ? "Parece que as tabelas ainda não foram criadas no Supabase. Execute o script SQL de configuração (supabase_setup.sql) no SQL Editor do Supabase e recarregue esta página."
            : erroCarga.includes("JWT")||erroCarga.includes("apikey")||erroCarga.includes("Invalid")
            ? "Pode ser um problema com a chave de API ou a sessão. Tente sair e entrar novamente."
            : "Verifique sua conexão com a internet e se o script SQL foi executado no Supabase."}
        </p>
        <div style={{display:"flex",gap:8,marginTop:18}}>
          <button onClick={()=>window.location.reload()} style={{flex:1,padding:"10px",fontSize:13,fontWeight:600,borderRadius:7,border:"none",background:"#5B5BD6",color:"#fff",cursor:"pointer"}}>Recarregar página</button>
          <button onClick={async()=>{ await sb.auth.signOut(); window.location.reload(); }} style={{padding:"10px 16px",fontSize:13,fontWeight:600,borderRadius:7,border:"1px solid #DCDEE3",background:"#fff",color:"#374151",cursor:"pointer"}}>Sair</button>
        </div>
      </div>
    </div>
  );

  if(carregandoDados) return (
    <div style={{minHeight:"100vh",display:"flex",alignItems:"center",justifyContent:"center",fontFamily:"Inter,sans-serif",flexDirection:"column",gap:12}}>
      <div style={{width:36,height:36,border:"3px solid #E8E9ED",borderTop:"3px solid #5B5BD6",borderRadius:"50%",animation:"spin 1s linear infinite"}}/>
      <p style={{fontSize:13,color:"#6B7280"}}>Carregando seus dados…</p>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
    </div>
  );

  const importar=novos=>{setProcessos(novos);setPagina("processos");};

  const irParaProcesso = proc => {
    setAbrirProcessoId(proc.id);
    setPagina("processos");
  };

  const aoConcluirFicha = (salvo) => {
    if(salvo.tipoDemanda==="Ação Judicial" && salvo.novoProcessoId){
      setAbrirProcessoId(salvo.novoProcessoId);
      setPagina("processos");
    } else if(salvo.novaDemandaId){
      setAbrirDemandaId(salvo.novaDemandaId);
      setPagina("extrajudicial");
    }
  };

  const NAV = [
    {id:"dashboard",label:"Dashboard",icon:"▦"},
    {id:"ficha",label:"Ficha de Atendimento",icon:"📝"},
    {id:"processos",label:"Processos",icon:"📂"},
    {id:"extrajudicial",label:"Extrajudicial",icon:"🤝"},
    {id:"intimacoes",label:"Intimações",icon:"📨"},
    {id:"clientes",label:"Clientes",icon:"👤"},
    {id:"documentos",label:"Documentos",icon:"📄"},
    {id:"financeiro",label:"Financeiro",icon:"💰"},
    {id:"agenda",label:"Agenda",icon:"📅"},
    {id:"tarefas",label:"Tarefas",icon:"✅"},
    {id:"equipe",label:"Equipe",icon:"🧑‍💼"},
    {id:"relatorios",label:"Relatórios",icon:"📊"},
    {id:"importar",label:"Importar",icon:"⚡"},
  ];

  const urgentesCount = processos.filter(isUrgProc).length;
  const tarefasPendentesCount = tarefas.filter(t=>t.status!=="concluido").length;
  const hojeStr = hoje.toISOString().slice(0,10);
  const compromissosHojeCount = agenda.filter(c=>c.dataHora&&c.dataHora.slice(0,10)===hojeStr).length;

  const badgeFor = id => {
    if(id==="processos"&&urgentesCount>0) return urgentesCount;
    if(id==="tarefas"&&tarefasPendentesCount>0) return tarefasPendentesCount;
    if(id==="agenda"&&compromissosHojeCount>0) return compromissosHojeCount;
    return 0;
  };

  return (
    <div style={{display:"flex",minHeight:"100vh"}}>
      {/* Sidebar */}
      <div style={{width:232,background:"var(--navy)",flexShrink:0,display:"flex",flexDirection:"column",position:"sticky",top:0,height:"100vh",borderRight:"1px solid rgba(255,255,255,.06)"}}>
        <div style={{padding:"22px 20px 18px",borderBottom:"1px solid rgba(255,255,255,.08)"}}>
          <p style={{fontSize:9,color:"rgba(255,255,255,.4)",textTransform:"uppercase",letterSpacing:"1.2px",margin:"0 0 6px",fontWeight:600}}>Escritório</p>
          <p style={{fontSize:15,fontWeight:700,color:"#fff",margin:0,lineHeight:1.3,letterSpacing:"-.01em"}}>Michelli Abreu<br/>Advocacia</p>
        </div>
        <div style={{flex:1,padding:"12px 10px",overflowY:"auto"}}>
          {NAV.map(n=>{
            const badge = badgeFor(n.id);
            return (
              <button key={n.id} onClick={()=>setPagina(n.id)} style={{
                width:"100%",display:"flex",alignItems:"center",gap:11,padding:"9px 12px",marginBottom:2,
                background:pagina===n.id?"var(--accent)":"transparent",
                border:"none",borderRadius:7,cursor:"pointer",
                color:pagina===n.id?"#fff":"rgba(255,255,255,.6)",
                fontSize:12.5,fontWeight:pagina===n.id?600:500,textAlign:"left",
                transition:"background .12s, color .12s",
              }}>
                <span style={{fontSize:14,width:18,textAlign:"center",opacity:pagina===n.id?1:.75}}>{n.icon}</span>
                <span style={{flex:1}}>{n.label}</span>
                {badge>0&&<span style={{background:pagina===n.id?"rgba(255,255,255,.25)":"var(--red)",color:"#fff",borderRadius:9,padding:"1px 7px",fontSize:9.5,fontWeight:700}}>{badge}</span>}
              </button>
            );
          })}
        </div>
        <div style={{padding:"14px 20px",borderTop:"1px solid rgba(255,255,255,.08)"}}>
          <p style={{fontSize:9.5,color:"rgba(255,255,255,.4)",margin:"0 0 8px"}}>OAB/RJ 155.134 · v2025-06-29-prazo</p>
          <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",gap:8}}>
            <span style={{fontSize:10,color:sincStatus==="erro"?"#FCA5A5":sincStatus==="salvando"?"rgba(255,255,255,.5)":"rgba(255,255,255,.35)"}}>
              {sincStatus==="salvando"?"⏳ Salvando…":sincStatus==="salvo"?"✓ Salvo":sincStatus==="erro"?"⚠ Erro ao salvar":"☁ Sincronizado"}
            </span>
            <button onClick={async()=>{ if(confirm("Sair da conta?")) await sb.auth.signOut(); }} style={{fontSize:10,padding:"3px 9px",cursor:"pointer",borderRadius:4,border:"1px solid rgba(255,255,255,.2)",background:"none",color:"rgba(255,255,255,.5)",fontWeight:500}}>Sair</button>
          </div>
          <button onClick={async()=>{
            try {
              const { data:{session} } = await sb.auth.getSession();
              if(!session){ alert("DIAGNÓSTICO:\n\n❌ Você não está autenticado (sem sessão). O banco recusa salvar sem login válido. Saia e entre de novo."); return; }
              const meuId = session.user.id;
              // tenta gravar e ler de volta uma config simples
              const teste = { user_id: meuId, tipos_extra: JSON.stringify(["__teste__"]) };
              const { error: errUp } = await sb.from("configuracoes").upsert(teste, {onConflict:"user_id"});
              if(errUp){ alert("DIAGNÓSTICO:\n\n❌ Erro ao SALVAR no banco:\n\n"+(errUp.message||"")+"\n\nCódigo: "+(errUp.code||"?")+"\nDetalhe: "+(errUp.details||"-")+"\nDica: "+(errUp.hint||"-")+"\n\nMe envie este texto."); return; }
              const { data, error: errSel } = await sb.from("processos").select("id,user_id").limit(3);
              if(errSel){ alert("DIAGNÓSTICO:\n\n⚠ Salvou config, mas erro ao LER processos:\n\n"+errSel.message); return; }
              const meus = (data||[]).filter(r=>r.user_id===meuId).length;
              const outros = (data||[]).filter(r=>r.user_id!==meuId).length;
              alert("DIAGNÓSTICO:\n\n✅ Salvamento no banco FUNCIONA (gravou e leu com sucesso).\n\nSeu ID de usuário: "+meuId+"\n\nProcessos visíveis (amostra de 3): "+(data||[]).length+"\n- Com SEU user_id: "+meus+"\n- Com user_id DIFERENTE: "+outros+"\n\nSe há processos com user_id diferente, eles não podem ser editados/excluídos por você (regra de segurança). Me envie este texto.");
            } catch(e){ alert("DIAGNÓSTICO:\n\n❌ Exceção: "+(e.message||e)); }
          }} style={{width:"100%",marginTop:10,fontSize:10,padding:"6px 9px",cursor:"pointer",borderRadius:4,border:"1px solid rgba(255,255,255,.2)",background:"rgba(255,255,255,.06)",color:"rgba(255,255,255,.6)",fontWeight:500}}>🔧 Testar salvamento</button>
        </div>
      </div>

      {/* Conteúdo */}
      <div style={{flex:1,background:"var(--bg3)",minHeight:"100vh"}}>
        <div style={{maxWidth:1280,margin:"0 auto",padding:"1.75rem 2rem"}}>
          {erroSalvar&&(
            <div style={{background:"var(--red-bg)",border:"1px solid #FCA5A5",borderRadius:8,padding:"12px 16px",marginBottom:16,display:"flex",justifyContent:"space-between",alignItems:"flex-start",gap:12}}>
              <div>
                <p style={{fontSize:12.5,fontWeight:700,color:"var(--red)",margin:"0 0 3px"}}>⚠ Suas alterações NÃO foram salvas no banco</p>
                <p style={{fontSize:11.5,color:"#7F1D1D",margin:0,lineHeight:1.5}}>{erroSalvar}</p>
                <p style={{fontSize:11,color:"#991B1B",margin:"5px 0 0",lineHeight:1.5}}>Provável causa: falta rodar o <strong>supabase_setup.sql</strong> atualizado (alguma coluna não existe no banco). Rode-o no SQL Editor do Supabase e recarregue. Me envie esta mensagem se persistir.</p>
              </div>
              <button onClick={()=>setErroSalvar("")} style={{background:"none",border:"none",cursor:"pointer",fontSize:18,color:"var(--red)",padding:0,lineHeight:1,flexShrink:0}}>×</button>
            </div>
          )}
          {pagina==="dashboard"&&<PaginaDashboard processos={processos} parcelas={parcelas} clientes={clientes} tarefas={tarefas} agenda={agenda} equipe={equipe} onAbrirProcesso={irParaProcesso} onIrPara={setPagina} setProcessos={setProcessosSaved} setClientes={setClientesSaved}/>}
          {pagina==="ficha"&&<PaginaFichaAtendimento clientes={clientes} setClientes={setClientesSaved} processos={processos} setProcessos={setProcessosSaved} demandas={demandas} setDemandas={setDemandasSaved} tarefas={tarefas} setTarefas={setTarefasSaved} equipe={equipe} onConcluido={aoConcluirFicha}/>}
          {pagina==="extrajudicial"&&<PaginaExtrajudicial demandas={demandas} setDemandas={setDemandasSaved} clientes={clientes} tarefas={tarefas} setTarefas={setTarefasSaved} tiposCustom={tiposExtraCustom} setTiposCustom={setTiposExtraCustom} onNovoCliente={()=>setPedirNovoCliente(true)}/>}
          {pagina==="processos"&&<PaginaProcessos processos={processos} setProcessos={setProcessosSaved} clientes={clientes} setClientes={setClientesSaved} mapas={mapas} setMapas={setMapas} onNovoCliente={()=>setPedirNovoCliente(true)} abrirProcessoId={abrirProcessoId} onProcessoAberto={()=>setAbrirProcessoId(null)} tarefas={tarefas} setTarefas={setTarefasSaved} setAgenda={setAgendaSaved} setParcelas={setParcelasSaved} classificacoesCustom={classificacoesCustom} setClassificacoesCustom={setClassificacoesCustom}/>}
          {pagina==="intimacoes"&&<PaginaIntimacoes processos={processos} clientes={clientes} equipe={equipe} setProcessos={setProcessosSaved} setTarefas={setTarefasSaved} publicacoes={publicacoes} setPublicacoes={setPublicacoes}/>}
          {pagina==="clientes"&&<PaginaClientes clientes={clientes} setClientes={setClientesSaved} processos={processos} onAbrirProcesso={irParaProcesso} clienteParaAbrir={pedirNovoCliente} onClienteAberto={()=>setPedirNovoCliente(false)}/>}
          {pagina==="financeiro"&&<PaginaFinanceiro parcelas={parcelas} setParcelas={setParcelasSaved} processos={processos}/>}
          {pagina==="agenda"&&<PaginaAgenda agenda={agenda} setAgenda={setAgendaSaved} equipe={equipe} processos={processos} clientes={clientes}/>}
          {pagina==="tarefas"&&<PaginaTarefas tarefas={tarefas} setTarefas={setTarefasSaved} equipe={equipe} processos={processos} clientes={clientes}/>}
          {pagina==="equipe"&&<PaginaEquipe equipe={equipe} setEquipe={setEquipe} tarefas={tarefas} agenda={agenda}/>}
          {pagina==="relatorios"&&<PaginaRelatorios processos={processos} parcelas={parcelas} clientes={clientes}/>}
          {pagina==="importar"&&<PaginaImportacao onImportar={importar} uid={uid} processos={processos} clientes={clientes} setProcessos={setProcessosSaved} setClientes={setClientesSaved}/>}
          {pagina==="documentos"&&<PaginaDocumentos clientes={clientes} processos={processos}/>}
        </div>
      </div>

      <AssistenteIA processos={processos} clientes={clientes}/>
    </div>
  );
}
ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>
