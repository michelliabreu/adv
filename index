  partes.push(`portador(a) da Cédula de Identidade RG nº ${pessoa.rg||"[RG]"}`);
  partes.push(`inscrito(a) no CPF sob o nº ${pessoa.cpf||"[CPF]"}`);
  partes.push(`residente e domiciliado(a) na ${pessoa.endereco||"[endereço completo]"}`);
  if(pessoa.email) partes.push(`e-mail ${pessoa.email}`);
  return partes.join(", ");
}

