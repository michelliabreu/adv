        </div>
      )}
      {colandoMovPara&&<ModalColarMovimentacoes proc={colandoMovPara} onConfirm={confirmarMovColadas} onClose={()=>setColandoMovPara(null)}/>}
    </div>
  );
}
function PaginaClientes({clientes, setClientes, processos, onAbrirProcesso, clienteParaAbrir, onClienteAberto}){
  const [busca,setBusca]=useState("");
  const [editando,setEditando]=useState(null);
  const [novo,setNovo]=useState(false);
  const [selecionado,setSelecionado]=useState(null);
  const [qualifCopiada,setQualifCopiada]=useState(null);

  React.useEffect(()=>{
    if(clienteParaAbrir){ setNovo(true); onClienteAberto(); }
  },[clienteParaAbrir]);

  const lista = useMemo(()=>{
    const q=busca.toLowerCase();
    return clientes.filter(c=>!q||c.nome.toLowerCase().includes(q)||c.cpf.includes(q)||c.email.toLowerCase().includes(q));
  },[clientes,busca]);

  const procsDe = clienteId => processos.filter(p=>p.clienteId===clienteId);

  const salvar = form => {
    setClientes(cs=>form.id?cs.map(c=>c.id===form.id?form:c):[...cs,{...form,id:Date.now()}]);
    setEditando(null);setNovo(false);
  };

  // Monta a qualificação formal da parte para uso em petições
  const montarQualificacao = (c) => {
    const partes = [];
    partes.push(c.nome ? c.nome.toUpperCase() : "[NOME]");
    if(c.nacionalidade) partes.push(c.nacionalidade.toLowerCase());
    if(c.estadoCivil) partes.push(c.estadoCivil.toLowerCase());
    if(c.profissao) partes.push(c.profissao.toLowerCase());
    let texto = partes.join(", ");
    const docs = [];
    if(c.rg) docs.push(`portador(a) da cédula de identidade RG nº ${c.rg}`);
    if(c.cpf) docs.push(`inscrito(a) no CPF sob o nº ${c.cpf}`);
    if(docs.length) texto += ", " + docs.join(", ");
    if(c.endereco) texto += `, residente e domiciliado(a) em ${c.endereco}`;
    if(c.email) texto += `, e-mail: ${c.email}`;
    texto += ".";
    return texto;
  };

  const copiarQualificacao = (c) => {
    const txt = montarQualificacao(c);
    if(navigator.clipboard && navigator.clipboard.writeText){
      navigator.clipboard.writeText(txt).then(()=>{setQualifCopiada(c.id);setTimeout(()=>setQualifCopiada(null), 2500);}).catch(()=>{});
    }
  };

  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Clientes</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>{clientes.length} cliente(s) cadastrados — CRM do escritório</p>
        </div>
        <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Novo cliente</button>
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"8px 14px",marginBottom:12}}>
        <input placeholder="Buscar por nome, CPF ou e-mail…" value={busca} onChange={e=>setBusca(e.target.value)} style={{fontSize:12,padding:"6px 11px",borderRadius:5,border:"1px solid var(--border2)",background:"#fff",color:"var(--text1)",width:280}}/>
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden"}}>
        <div style={{display:"grid",gridTemplateColumns:"2fr 1.2fr 1.2fr .8fr .9fr",padding:"9px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)"}}>
          {["Nome","CPF","Contato","Processos","Débito total"].map(h=><span key={h} style={hdr}>{h}</span>)}
        </div>
        {lista.length===0?<div style={{padding:"2.5rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhum cliente encontrado.</div>:lista.map((c,i)=>{
          const procs = procsDe(c.id);
          const debitoTotal = procs.reduce((s,p)=>s+(p.debito?.valor||0),0);
          return (
            <div key={c.id} onClick={()=>setSelecionado(c)} style={{display:"grid",gridTemplateColumns:"2fr 1.2fr 1.2fr .8fr .9fr",padding:"12px 14px",alignItems:"center",borderBottom:i<lista.length-1?"1px solid var(--border1)":"none",cursor:"pointer"}}>
              <div style={{display:"flex",alignItems:"center",gap:10}}>
                <div style={{width:34,height:34,borderRadius:"50%",background:"var(--navy)",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13,fontWeight:700,flexShrink:0}}>{c.nome.charAt(0).toUpperCase()}</div>
                <span style={{fontSize:13,fontWeight:600}}>{c.nome}</span>
              </div>
              <div style={{fontSize:12,color:"var(--text2)"}}>{c.cpf||"—"}</div>
              <div>
                <p style={{fontSize:11.5,margin:"0 0 2px"}}>{c.email||"—"}</p>
                <p style={{fontSize:11,color:"var(--text2)",margin:0}}>{c.telefone||"—"}</p>
              </div>
              <div><Pill bg="var(--accent-light)" color="var(--navy2)" label={`${procs.length} proc.`} sm/></div>
              <div style={{fontSize:13,fontWeight:700,color:debitoTotal>0?"var(--navy2)":"var(--text3)"}}>{debitoTotal>0?fmtBRL(debitoTotal):"—"}</div>
            </div>
          );
        })}
      </div>

      {(editando||novo)&&<ModalFormCliente cliente={editando} onSave={salvar} onClose={()=>{setEditando(null);setNovo(false);}}/>}

      {selecionado&&(
        <div onClick={e=>e.target===e.currentTarget&&setSelecionado(null)} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.45)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
          <div style={{background:"#fff",width:600,maxWidth:"100%",maxHeight:"90vh",overflow:"auto",borderRadius:10,padding:"1.75rem",boxShadow:"0 25px 60px rgba(0,0,0,.3)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:18}}>
              <div style={{display:"flex",alignItems:"center",gap:12}}>
                <div style={{width:48,height:48,borderRadius:"50%",background:"var(--navy)",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontSize:18,fontWeight:700}}>{selecionado.nome.charAt(0).toUpperCase()}</div>
                <div>
                  <p style={{fontSize:16,fontWeight:700,margin:"0 0 2px",color:"var(--navy)"}}>{selecionado.nome}</p>
                  <p style={{fontSize:11.5,color:"var(--text2)",margin:0}}>{selecionado.cpf||"CPF não informado"}</p>
                </div>
              </div>
              <button onClick={()=>setSelecionado(null)} style={{background:"none",border:"none",cursor:"pointer",fontSize:22,color:"var(--text2)",padding:0,lineHeight:1}}>×</button>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"10px 20px",marginBottom:16}}>
              {[["E-mail",selecionado.email||"—"],["Telefone",selecionado.telefone||"—"],["Endereço",selecionado.endereco||"—"]].map(([k,v])=>(
                <div key={k}><p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>{k}</p><p style={{fontSize:13,margin:0}}>{v}</p></div>
              ))}
            </div>
            {selecionado.obs&&<div style={{background:"var(--bg2)",borderRadius:6,padding:"10px 12px",fontSize:12,color:"var(--text2)",marginBottom:16}}>{selecionado.obs}</div>}
            <div style={{borderTop:"1px solid var(--border1)",paddingTop:14}}>
              <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"0 0 10px"}}>Processos vinculados ({procsDe(selecionado.id).length})</p>
              <div style={{display:"flex",flexDirection:"column",gap:8}}>
                {procsDe(selecionado.id).map(p=>(
                  <div key={p.id} onClick={()=>{onAbrirProcesso(p);setSelecionado(null);}} style={{border:"1px solid var(--border1)",borderRadius:6,padding:"10px 12px",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center",gap:10}}>
                    <div>
                      <p style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 2px"}}>{p.numero}</p>
                      <p style={{fontSize:12,margin:0}}>vs. {p.reu}</p>
                    </div>
                    <div style={{display:"flex",gap:8,alignItems:"center"}}>
                      {p.debito?.valor&&<span style={{fontSize:12,fontWeight:700,color:"var(--navy2)"}}>{fmtBRL(p.debito.valor)}</span>}
                      <Pill {...SC[normalizarStatus(p.status)]} sm/>
                    </div>
                  </div>
                ))}
                {procsDe(selecionado.id).length===0&&<p style={{fontSize:12,color:"var(--text2)"}}>Nenhum processo vinculado a este cliente ainda.</p>}
              </div>
            </div>
            {/* Qualificação para petição */}
            <div style={{marginTop:16,borderTop:"1px solid var(--border1)",paddingTop:14}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
