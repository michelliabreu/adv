// ── Modal: Colar movimentações (substitui busca automática DataJud, bloqueada por CORS) ──
function ModalColarMovimentacoes({proc, onConfirm, onClose}){
  const [texto, setTexto] = useState("");
  const [interpretando, setInterpretando] = useState(false);
  const [erro, setErro] = useState("");
  const [resultado, setResultado] = useState(null);
  const [selecionados, setSelecionados] = useState({});

  const abrirConsultaPublica = () => {
    window.open(`https://www.tjrj.jus.br/consultaProcessual`, "_blank");
  };

  const interpretar = async () => {
    if(!texto.trim()){ setErro("Cole a lista de movimentações antes de interpretar."); return; }
    setErro(""); setInterpretando(true); setResultado(null);
    try {
      let res;
      try {
        res = await fetch(IA_PROXY_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Authorization": "Bearer " + SUPABASE_KEY },
          body: JSON.stringify({
            model: "claude-sonnet-4-6",
            max_tokens: 3000,
            system: `Você extrai uma lista de andamentos/movimentações processuais de um texto colado, copiado da consulta pública de um tribunal (formatação pode estar irregular, com quebras de linha, tabelas mal formatadas, datas em formatos variados).

Retorne SOMENTE um JSON válido (array), sem texto adicional, sem markdown. Cada item representa UM andamento distinto:
[{"data":"YYYY-MM-DD","desc":"descrição do andamento, mantendo o texto original ou levemente limpo, sem inventar conteúdo"}]

Ordene do mais antigo para o mais recente. Se uma data não puder ser identificada com confiança, use string vazia no campo data, mas ainda inclua o item. Nunca invente andamentos que não estejam no texto.`,
            messages: [{role:"user", content: texto}]
          })
        });
      } catch(networkErr) {
        throw new Error("Não foi possível conectar ao serviço de IA — verifique sua conexão com a internet.");
      }
      if(!res.ok){
        let detalhe = "";
        try { const errBody = await res.json(); detalhe = errBody?.error?.message || ""; } catch(_){}
        throw new Error(`Erro HTTP ${res.status} ao chamar a IA.${detalhe?` Detalhe: ${detalhe}`:""}`);
      }
      const data = await res.json();
      const txt = data.content?.find(b=>b.type==="text")?.text || "";
      if(!txt) throw new Error("A IA retornou uma resposta vazia.");
      let parsed;
      try {
        parsed = JSON.parse(txt.replace(/```json|```/g,"").trim());
      } catch(parseErr) {
        throw new Error(`A resposta da IA não veio em formato JSON válido. Início: "${txt.slice(0,150)}"`);
      }
      if(!Array.isArray(parsed)) throw new Error("Formato inesperado — a IA não retornou uma lista de andamentos.");

      // marca quais já existem no processo (mesma data + descrição muito parecida) para não duplicar
      const existentes = new Set((proc.andamentos||[]).map(a=>(a.data||"")+"|"+(a.desc||"").toLowerCase().trim().slice(0,40)));
      const comFlag = parsed.map((item,i)=>({
        ...item,
        _id: i,
        _duplicado: existentes.has((item.data||"")+"|"+(item.desc||"").toLowerCase().trim().slice(0,40)),
      }));
      setResultado(comFlag);
      const sel = {};
      comFlag.forEach(item=>{ if(!item._duplicado) sel[item._id] = true; });
      setSelecionados(sel);
    } catch(e) {
      setErro(e.message || "Não foi possível interpretar o texto colado. Verifique se copiou a lista de movimentações corretamente.");
    }
    setInterpretando(false);
  };

  const confirmar = () => {
    const escolhidos = resultado.filter(item=>selecionados[item._id]).map(item=>({
      data: item.data || hoje.toISOString().slice(0,10),
      desc: item.desc,
      fonte: "manual",
    }));
    onConfirm(escolhidos);
  };

  return (
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.5)",zIndex:550,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:560,maxWidth:"100%",maxHeight:"90vh",overflow:"auto",borderRadius:10,padding:"1.5rem",boxShadow:"0 20px 50px rgba(0,0,0,.25)"}}>
        <p style={{fontSize:10,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".7px",margin:"0 0 4px",fontWeight:600}}>Colar movimentações do processo</p>
        <p style={{fontSize:13,fontWeight:600,fontFamily:"monospace",margin:"0 0 14px"}}>{proc.numero}</p>

        {!resultado && (
          <>
            <div style={{background:"var(--accent-light)",border:"1px solid #C5DCF2",borderRadius:6,padding:"10px 12px",marginBottom:14,fontSize:11.5,color:"var(--navy2)",lineHeight:1.5}}>
              ℹ️ A consulta automática ao DataJud é bloqueada pelo navegador (CORS). Abra a consulta pública do tribunal, copie a lista de movimentações do processo e cole abaixo — a IA organiza automaticamente.
            </div>
            <button onClick={abrirConsultaPublica} style={{...btnSec,width:"100%",padding:"9px",marginBottom:14}}>🔗 Abrir consulta pública do TJRJ</button>
            <textarea value={texto} onChange={e=>setTexto(e.target.value)} placeholder="Cole aqui a lista de movimentações copiada do site do tribunal…" style={{width:"100%",minHeight:160,fontSize:12,padding:"10px",borderRadius:6,border:"1px solid var(--border2)",resize:"vertical",boxSizing:"border-box",fontFamily:"inherit",marginBottom:10}}/>
            {erro && <p style={{fontSize:12,color:"var(--red)",marginBottom:10}}>{erro}</p>}
            <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
              <button onClick={onClose} style={btnSec}>Cancelar</button>
              <button onClick={interpretar} disabled={interpretando} style={{...btnPri,opacity:interpretando?.7:1}}>{interpretando?"Interpretando…":"✨ Interpretar com IA"}</button>
            </div>
          </>
        )}

        {resultado && (
          <>
