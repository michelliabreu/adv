      )}

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,overflow:"hidden"}}>
        <div style={{display:"grid",gridTemplateColumns:"2.4fr 1.4fr 1.4fr .8fr .5fr",padding:"11px 18px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)",gap:14}}>
          {[{label:"Processo",col:"numero"},{label:"Cliente",col:"clienteId"},{label:"Ação / Foro",col:"vara"},{label:"Últ. mov.",col:"ultimoAto"},{label:"Status",col:"status"}].map(h=>(
            <span key={h.col} onClick={()=>ordenar(h.col)} style={{...hdr,cursor:"pointer",userSelect:"none",display:"flex",alignItems:"center",gap:4}}>
              {h.label}
              {ordenarPor===h.col && <span style={{fontSize:11,fontWeight:700}}>{direcao==="asc"?"▲":"▼"}</span>}
            </span>
          ))}
        </div>
        {lista.length===0?<div style={{padding:"2.5rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhum processo encontrado.</div>:lista.map((p,i)=>{
          const urg=isUrgProc(p),dias=p.prazo?diasRest(p.prazo):0;
          const andOrd=[...(p.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data));
          const ultimoAto=andOrd[0];
          const ultimaDecisao=andOrd.find(a=>a.decisao===true || (a.fonte==="cnj" && PALAVRAS_DECISAO.some(w=>a.desc?.toLowerCase().includes(w))));
          const us=updateState[p.id]||{};
          const pp=p.prazoProcessual;
          const cli = clienteDe(p);
          return(
            <div key={p.id} className="proc-row" style={{borderBottom:i<lista.length-1?"1px solid var(--border1)":"none",background:selecionados.has(p.id)?"var(--accent-light)":"transparent",display:"flex",alignItems:"stretch",position:"relative",transition:"background .12s"}}>
              {modoSelecao&&(
                <div style={{display:"flex",alignItems:"center",padding:"0 2px 0 16px"}}>
                  <input type="checkbox" checked={selecionados.has(p.id)} onChange={()=>toggleSelecionado(p.id)} style={{width:16,height:16,cursor:"pointer"}}/>
                </div>
              )}
              <div style={{flex:1,display:"grid",gridTemplateColumns:"2.4fr 1.4fr 1.4fr .8fr .5fr",padding:"14px 18px",alignItems:"center",gap:14,cursor:"pointer"}} onClick={()=>setSelected(p)}>

                {/* Coluna 1: Partes + número */}
                <div style={{minWidth:0}}>
                  {(()=>{
                    const {nomeCliente, adversa} = clientePrincipalEAdversa(p, clientes);
                    return (
                      <p style={{fontSize:13.5,fontWeight:600,color:"var(--text1)",margin:"0 0 3px",lineHeight:1.35}}>
                        {nomeCliente} <span style={{color:"var(--text3)",fontWeight:400}}>×</span> {adversa}
