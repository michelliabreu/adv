// ── Modal Form Tarefa ──────────────────────────────────────
function ModalFormTarefa({tarefa, equipe, processos, clientes, onSave, onClose}){
  const e0={titulo:"",responsavelId:"",procId:"",clienteId:"",status:"pendente",prioridade:"media",prazo:"",desc:""};
  const [f,setF]=useState(tarefa||e0);
  const s=(k,v)=>setF(x=>({...x,[k]:v}));
  return (
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.45)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:480,maxWidth:"100%",borderRadius:10,padding:"1.75rem",boxShadow:"0 25px 60px rgba(0,0,0,.3)"}}>
        <p style={{fontSize:15,fontWeight:700,margin:"0 0 18px",color:"var(--navy)"}}>{tarefa?"Editar tarefa":"Nova tarefa"}</p>
        <div style={{display:"flex",flexDirection:"column",gap:12}}>
          <div><span style={lbl}>Título da tarefa</span><input value={f.titulo} onChange={e=>s("titulo",e.target.value)} style={inp}/></div>
          <div><span style={lbl}>Descrição</span><textarea value={f.desc} onChange={e=>s("desc",e.target.value)} style={{...inp,minHeight:60,resize:"vertical"}}/></div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Responsável</span>
              <select value={f.responsavelId} onChange={e=>s("responsavelId",e.target.value?parseInt(e.target.value):"")} style={{...inp,padding:"7px 8px"}}>
                <option value="">Selecione…</option>
                {equipe.map(m=><option key={m.id} value={m.id}>{m.nome}</option>)}
              </select>
            </div>
            <div><span style={lbl}>Prioridade</span>
              <select value={f.prioridade} onChange={e=>s("prioridade",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                <option value="alta">Alta</option><option value="media">Média</option><option value="baixa">Baixa</option>
              </select>
            </div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Cliente <span style={{color:"var(--text3)",fontWeight:400,textTransform:"none"}}>(opcional)</span></span>
              <select value={f.clienteId} onChange={e=>{
                const novoClienteId = e.target.value?parseInt(e.target.value):"";
                s("clienteId",novoClienteId);
                if(novoClienteId && f.procId){
                  const procAtual = processos.find(p=>p.id===f.procId);
                  if(procAtual && procAtual.clienteId !== novoClienteId) s("procId","");
                }
              }} style={{...inp,padding:"7px 8px"}}>
                <option value="">— Nenhum —</option>
                {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}</option>)}
              </select>
            </div>
            <div><span style={lbl}>Processo <span style={{color:"var(--text3)",fontWeight:400,textTransform:"none"}}>(opcional)</span></span>
              <select value={f.procId} onChange={e=>{
                const novoProcId = e.target.value?parseInt(e.target.value):"";
                s("procId",novoProcId);
                if(novoProcId && !f.clienteId){
                  const proc = processos.find(p=>p.id===novoProcId);
                  if(proc && proc.clienteId) s("clienteId",proc.clienteId);
                }
              }} style={{...inp,padding:"7px 8px"}}>
                <option value="">— Nenhum —</option>
                {(f.clienteId ? processos.filter(p=>p.clienteId===f.clienteId) : processos).map(p=><option key={p.id} value={p.id}>{p.numero.slice(0,18)}… {p.assunto?`— ${p.assunto.slice(0,20)}`:""}</option>)}
              </select>
              {f.clienteId && processos.filter(p=>p.clienteId===f.clienteId).length===0 && <p style={{fontSize:10,color:"var(--text3)",margin:"4px 0 0"}}>Este cliente não tem processos cadastrados.</p>}
            </div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Status</span>
              <select value={f.status} onChange={e=>s("status",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                <option value="pendente">Pendente</option><option value="em_andamento">Em Andamento</option><option value="concluido">Concluído</option>
              </select>
            </div>
            <div><span style={lbl}>Prazo</span><input type="date" value={f.prazo} onChange={e=>s("prazo",e.target.value)} style={{...inp,padding:"7px 8px"}}/></div>
          </div>
        </div>
        <div style={{marginTop:20,display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={()=>{if(!f.titulo.trim()){alert("Informe o título da tarefa.");return;}onSave(f);}} style={btnPri}>Salvar</button>
        </div>
      </div>
    </div>
  );
}

// ── Página Tarefas ─────────────────────────────────────────
function PaginaTarefas({tarefas, setTarefas, equipe, processos, clientes}){
  const [editando, setEditando] = useState(null);
  const [novo, setNovo] = useState(false);
  const [filtroResp, setFiltroResp] = useState("");
  const [dragId, setDragId] = useState(null);
  const [dragOverCol, setDragOverCol] = useState(null);
  const [verArquivadas, setVerArquivadas] = useState(false);

  const salvar = form => {
    setTarefas(ts => form.id ? ts.map(t=>t.id===form.id?form:t) : [...ts, {...form, id:Date.now()}]);
    setEditando(null); setNovo(false);
  };
  const nomeResp = id => equipe.find(m=>m.id===id)?.nome || "—";
  const nomeCliente = id => clientes.find(c=>c.id===id)?.nome || "—";
  const numProc = id => processos.find(p=>p.id===id)?.numero || "";

  const moverStatus = (id, novoStatus) => {
    setTarefas(ts => ts.map(t => t.id===id ? {...t, status:novoStatus} : t));
  };
  const arquivarTarefa = id => {
    setTarefas(ts => ts.map(t => t.id===id ? {...t, arquivada:true} : t));
  };
  const desarquivarTarefa = id => {
    setTarefas(ts => ts.map(t => t.id===id ? {...t, arquivada:false} : t));
  };
  const reabrirTarefa = id => {
    setTarefas(ts => ts.map(t => t.id===id ? {...t, status:"pendente", arquivada:false} : t));
  };

  const colunas = [
    {key:"pendente", label:"Pendente"},
    {key:"em_andamento", label:"Em Andamento"},
    {key:"concluido", label:"Concluído"},
  ];
  const baseLista = filtroResp ? tarefas.filter(t=>t.responsavelId===parseInt(filtroResp)) : tarefas;
  const lista = baseLista.filter(t=>!t.arquivada);
  const arquivadas = baseLista.filter(t=>t.arquivada);

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Tarefas e Atividades</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>{lista.length} tarefa(s) ativa(s) — arraste os cards para mudar o status</p>
        </div>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <select value={filtroResp} onChange={e=>setFiltroResp(e.target.value)} style={{...inp,padding:"7px 10px",width:170}}>
            <option value="">Todos responsáveis</option>
            {equipe.map(m=><option key={m.id} value={m.id}>{m.nome}</option>)}
          </select>
          <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Nova tarefa</button>
        </div>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:14}}>
        {colunas.map(col=>{
          const itens = lista.filter(t=>t.status===col.key);
          const cfg = STATUS_TAREFA_CFG[col.key];
          const isOver = dragOverCol === col.key;
          return (
            <div
              key={col.key}
              onDragOver={e=>{ e.preventDefault(); setDragOverCol(col.key); }}
              onDragLeave={()=>setDragOverCol(c=>c===col.key?null:c)}
              onDrop={e=>{
                e.preventDefault();
                if(dragId!=null) moverStatus(dragId, col.key);
                setDragId(null); setDragOverCol(null);
              }}
              style={{
                background: isOver ? "var(--accent-light)" : "var(--bg2)",
                borderRadius:10, padding:"12px",
                border: isOver ? "2px dashed var(--accent)" : "2px dashed transparent",
                transition:"background .15s, border-color .15s",
                minHeight:120,
              }}
            >
              <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:12}}>
                <span style={{width:8,height:8,borderRadius:"50%",background:cfg.dot}}/>
                <span style={{fontSize:12,fontWeight:700,color:"var(--text1)",textTransform:"uppercase",letterSpacing:".4px"}}>{col.label}</span>
                <span style={{fontSize:11,color:"var(--text2)",marginLeft:"auto"}}>{itens.length}</span>
              </div>
              <div style={{display:"flex",flexDirection:"column",gap:8}}>
                {itens.map(t=>{
                  const pCfg = PRIORIDADE_CFG[t.prioridade];
                  const venceLogo = t.prazo && diasRest(t.prazo) <= 3 && t.status !== "concluido";
                  return (
                    <div
                      key={t.id}
                      draggable
                      onDragStart={()=>setDragId(t.id)}
                      onDragEnd={()=>{setDragId(null);setDragOverCol(null);}}
                      onClick={()=>setEditando(t)}
                      style={{background:"#fff",borderRadius:7,padding:"10px 12px",cursor:"grab",border:"1px solid var(--border1)",borderLeft:`3px solid ${pCfg.color}`,opacity:dragId===t.id?.4:1}}
                    >
                      <p style={{fontSize:12.5,fontWeight:600,margin:"0 0 6px"}}>{t.titulo}</p>
                      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:6}}>
                        <Pill bg={pCfg.bg} color={pCfg.color} label={pCfg.label} sm/>
                        {t.prazo && <span style={{fontSize:10,color:venceLogo?"var(--red)":"var(--text2)",fontWeight:venceLogo?700:400}}>{fmtData(t.prazo)}</span>}
                      </div>
                      {t.clienteId && <p style={{fontSize:10.5,color:"var(--accent)",margin:"0 0 2px"}}>👤 {nomeCliente(t.clienteId)}</p>}
                      {t.procId && <p style={{fontSize:10,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 4px"}}>{numProc(t.procId).slice(0,20)}…</p>}
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:6}}>
                        <p style={{fontSize:10.5,color:"var(--text2)",margin:0,whiteSpace:"nowrap",overflow:"hidden",textOverflow:"ellipsis"}}>👷 {nomeResp(t.responsavelId)}</p>
                        <div style={{display:"flex",gap:4,flexShrink:0}}>
                          {col.key==="concluido" && (
                            <button onClick={e=>{e.stopPropagation();reabrirTarefa(t.id);}} title="Reabrir tarefa (voltar para pendente)" style={{fontSize:9,padding:"2px 7px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>↩ Reabrir</button>
                          )}
                          <button onClick={e=>{e.stopPropagation();arquivarTarefa(t.id);}} title="Arquivar tarefa" style={{fontSize:9,padding:"2px 7px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--text2)",fontWeight:600,whiteSpace:"nowrap"}}>📦</button>
                        </div>
                      </div>
                    </div>
                  );
                })}
                {itens.length===0 && <p style={{fontSize:11,color:"var(--text3)",textAlign:"center",padding:"10px 0"}}>Arraste um card aqui</p>}
              </div>
            </div>
          );
        })}
      </div>

      {arquivadas.length>0 && (
        <div style={{marginTop:18}}>
          <button onClick={()=>setVerArquivadas(v=>!v)} style={{background:"none",border:"none",cursor:"pointer",fontSize:11.5,color:"var(--text2)",fontWeight:600,padding:0}}>
            {verArquivadas?"▾":"▸"} {arquivadas.length} tarefa(s) arquivada(s)
          </button>
          {verArquivadas && (
            <div style={{display:"flex",flexDirection:"column",gap:6,marginTop:10}}>
              {arquivadas.map(t=>(
                <div key={t.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",gap:8,fontSize:12,padding:"8px 12px",background:"#fff",border:"1px solid var(--border1)",borderRadius:6}}>
                  <span style={{color:"var(--text2)",textDecoration:"line-through",flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{t.titulo}</span>
                  <span style={{fontSize:10.5,color:"var(--text3)",whiteSpace:"nowrap"}}>{numProc(t.procId)?.slice(0,18)}{t.procId?"…":""}</span>
                  <div style={{display:"flex",gap:4,flexShrink:0}}>
                    <button onClick={()=>reabrirTarefa(t.id)} title="Reabrir (voltar para pendente)" style={{fontSize:9,padding:"3px 8px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>↩ Reabrir</button>
                    <button onClick={()=>desarquivarTarefa(t.id)} title="Desarquivar (manter status, tirar do arquivo)" style={{fontSize:9,padding:"3px 8px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--text2)",fontWeight:600,whiteSpace:"nowrap"}}>📤 Desarquivar</button>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {(editando||novo) && <ModalFormTarefa tarefa={editando} equipe={equipe} processos={processos} clientes={clientes} onSave={salvar} onClose={()=>{setEditando(null);setNovo(false);}}/>}
    </div>
  );
}

