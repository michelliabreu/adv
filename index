function gerarTextoQualificacao(pessoa, rotulo){
  if(!pessoa.nome.trim()) return "";
  const partes = [pessoa.nome.trim()];
  if(pessoa.nacionalidade) partes.push(pessoa.nacionalidade);
  if(pessoa.estadoCivil) partes.push(pessoa.estadoCivil.toLowerCase());
  if(pessoa.profissao) partes.push(pessoa.profissao);
  if(pessoa.rg) partes.push(`portador(a) da Cédula de Identidade RG nº ${pessoa.rg}`);
  if(pessoa.cpf) partes.push(`inscrito(a) no CPF sob o nº ${pessoa.cpf}`);
  if(pessoa.endereco) partes.push(`residente e domiciliado(a) na ${pessoa.endereco}`);
  if(pessoa.email) partes.push(`e-mail ${pessoa.email}`);
  let texto = partes.join(", ") + ".";
  return rotulo ? `${rotulo}: ${texto}` : texto;
}

