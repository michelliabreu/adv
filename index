        <div style={{flex:1,overflow:"auto",background:"var(--bg2)",border:"1px solid var(--border1)",borderRadius:6,padding:16}}>
          <pre style={{fontSize:11.5,lineHeight:1.7,whiteSpace:"pre-wrap",fontFamily:"inherit",margin:0,color:"var(--text1)"}}>{textoAtual}</pre>
