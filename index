                const txt = e.target.value;
                const achado = clientes.find(c=>c.nome.toLowerCase()===txt.toLowerCase().trim());
                setF(x=>({...x, clienteNome:txt, clienteId: achado?achado.id:""}));
              }}
              placeholder="Digite o nome do cliente…"
              style={inp}
            />
            <datalist id="lista-clientes-proc">
              {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.nome}>{c.cpf?c.cpf:""}</option>)}
            </datalist>
            {f.clienteNome && !f.clienteId && f.clienteNome.trim() && (
              <p style={{fontSize:10.5,color:"var(--accent)",margin:"5px 0 0"}}>✨ "{f.clienteNome.trim()}" será cadastrado como novo cliente ao salvar.</p>
