// ── Mapa Mental ───────────────────────────────────────────
const NW=160,NH=52,HGAP=80,VGAP=18;
const defaultMap=()=>({nodes:[{id:"root",label:"Evento / Decisão Principal",type:"decisao",children:[]}]});
function buildLayout(nodes){
  const byId={}; nodes.forEach(n=>byId[n.id]={...n,_ch:[]});
  const childSet=new Set();
  nodes.forEach(n=>(n.children||[]).forEach(c=>{if(byId[c]){byId[n.id]._ch.push(byId[c]);childSet.add(c);}}));
  const roots=nodes.filter(n=>!childSet.has(n.id)).map(n=>byId[n.id]);
  const pos={};
  function measure(n){if(!n._ch.length){n._h=NH+VGAP;return;}n._ch.forEach(measure);n._h=n._ch.reduce((s,c)=>s+c._h,0);}
  function place(n,x,y){pos[n.id]={x,y:y+n._h/2-NH/2};let cy=y;n._ch.forEach(c=>{place(c,x+NW+HGAP,cy);cy+=c._h;});}
  let gy=0;roots.forEach(r=>{measure(r);place(r,40,gy);gy+=r._h+VGAP*2;});
  return pos;
}
function MapaMental({mapaData,onChange}){
  const [nodes,setNodes]=useState(mapaData?.nodes||defaultMap().nodes);
  const [addingTo,setAddingTo]=useState(null);
  const [editingId,setEditingId]=useState(null);
  const [addForm,setAddForm]=useState({label:"",type:"acao"});
  const [editForm,setEditForm]=useState({label:"",type:"acao"});
  const [zoom,setZoom]=useState(1);
  const sync=ns=>{setNodes(ns);onChange({nodes:ns});};
  const pos=useMemo(()=>buildLayout(nodes.map(n=>({...n}))),[nodes]);
  const maxX=Math.max(...Object.values(pos).map(p=>p.x))+NW+60;
  const maxY=Math.max(...Object.values(pos).map(p=>p.y))+NH+80;
  const addChild=()=>{if(!addForm.label.trim())return;const nn={id:uid(),label:addForm.label.trim(),type:addForm.type,children:[]};sync([...nodes.map(n=>n.id===addingTo?{...n,children:[...(n.children||[]),nn.id]}:n),nn]);setAddingTo(null);setAddForm({label:"",type:"acao"});};
  const saveEdit=()=>{sync(nodes.map(n=>n.id===editingId?{...n,...editForm}:n));setEditingId(null);};
