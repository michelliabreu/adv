function ModalAcaoLote({tipo, qtd, clientes, classificacoes, onAplicar, onClose}){
  const [valor,setValor]=useState("");
  const cfg = {
    arquivar: {titulo:"Arquivar processos", label:"Situação do arquivamento", opcoes:[["baixado_definitivo","Baixado definitivamente"],["ag_prescricao","Aguardando prescrição"],["arquivado","Outro motivo"]]},
    status: {titulo:"Mudar status", label:"Novo status", opcoes:STATUS_VALIDOS.map(k=>[k,SC[k].label])},
    classificacao: {titulo:"Mudar classificação", label:"Nova classificação", opcoes:classificacoes.map(k=>[k,CC[k]?.label||k])},
    responsavel: {titulo:"Atribuir responsável", label:"Responsável (digite o nome)", texto:true},
    cliente: {titulo:"Vincular a cliente", label:"Cliente", opcoes:[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=>[String(c.id),c.nome])},
  }[tipo];
  if(!cfg) return null;

  const aplicar = () => {
    if(tipo==="arquivar") onAplicar({tipo:"arquivar",valor:valor||"arquivado"});
    else if(tipo==="status") onAplicar({tipo:"status",valor});
    else if(tipo==="classificacao") onAplicar({tipo:"classificacao",valor});
    else if(tipo==="responsavel") onAplicar({tipo:"responsavel",valor});
    else if(tipo==="cliente") onAplicar({tipo:"cliente",valor});
  };

  return (
    <div onClick={onClose} style={{position:"fixed",inset:0,background:"rgba(15,17,23,.5)",display:"flex",alignItems:"center",justifyContent:"center",zIndex:1000,padding:20}}>
      <div onClick={e=>e.stopPropagation()} style={{background:"#fff",borderRadius:12,padding:"1.5rem",width:420,maxWidth:"90vw"}}>
        <h3 style={{fontSize:16,fontWeight:700,color:"var(--text1)",margin:"0 0 4px"}}>{cfg.titulo}</h3>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:"0 0 16px"}}>Aplicar a <strong>{qtd}</strong> processo(s) selecionado(s).</p>
        <label style={{fontSize:11,fontWeight:600,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".5px",display:"block",marginBottom:6}}>{cfg.label}</label>
        {cfg.texto ? (
          <input autoFocus value={valor} onChange={e=>setValor(e.target.value)} placeholder="Ex: Beatriz" style={{...inp,marginBottom:18}}/>
        ) : (
          <select autoFocus value={valor} onChange={e=>setValor(e.target.value)} style={{...inp,marginBottom:18}}>
            <option value="">{tipo==="cliente"?"Nenhum (desvincular)":"Selecione…"}</option>
            {cfg.opcoes.map(([v,l])=><option key={v} value={v}>{l}</option>)}
          </select>
        )}
        <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={aplicar} disabled={!cfg.texto && tipo!=="cliente" && tipo!=="arquivar" && !valor} style={{...btnPri,opacity:(!cfg.texto && tipo!=="cliente" && tipo!=="arquivar" && !valor)?.5:1}}>Aplicar a {qtd}</button>
        </div>
      </div>
    </div>
  );
}

function PaginaProcessos({processos,setProcessos,clientes,setClientes,mapas,setMapas,onNovoCliente,abrirProcessoId,onProcessoAberto,tarefas,setTarefas,setAgenda,setParcelas,classificacoesCustom,setClassificacoesCustom}){
  const [aba,setAba]=useState("em_andamento");
  const [busca,setBusca]=useState("");
  const [filtrosAbertos,setFiltrosAbertos]=useState(false);
  const [filtroCliente,setFiltroCliente]=useState("");
  const [filtroAno,setFiltroAno]=useState("");
  const [filtroClassificacao,setFiltroClassificacao]=useState("");
  const [filtroSistema,setFiltroSistema]=useState("");
  const [filtroVara,setFiltroVara]=useState("");
  const [filtroResponsavel,setFiltroResponsavel]=useState("");
  const [selected,setSelected]=useState(null);
  const [editando,setEditando]=useState(null);
  const [novo,setNovo]=useState(false);
  const [mapaProc,setMapaProc]=useState(null);
  const [analisandoPrazo,setAnalisandoPrazo]=useState(null);
  const [sugestaoPrazo,setSugestaoPrazo]=useState(null);
  const [updateState,setUpdateState]=useState({});
  const [erroDetalheAberto,setErroDetalheAberto]=useState(null);
  const [colandoMovPara,setColandoMovPara]=useState(null);
  const [selecionados,setSelecionados]=useState(new Set());
  const [modoSelecao,setModoSelecao]=useState(false);
  const [acaoLote,setAcaoLote]=useState(null); // qual modal de ação em lote está aberto
  const [ordenarPor,setOrdenarPor]=useState("numero"); // coluna padrão: número
  const [direcao,setDirecao]=useState("asc"); // "asc" ou "desc"

  React.useEffect(()=>{
    if(abrirProcessoId){
      const p = processos.find(x=>x.id===abrirProcessoId);
      if(p){ setSelected(p); setAba(p.status); }
      onProcessoAberto();
    }
  },[abrirProcessoId]);

  const clienteDe = p => clientes.find(c=>c.id===p.clienteId);

  // Ordena processos por coluna clicada. Se clica na mesma coluna, inverte a direção.
  const ordenar = (coluna) => {
    if(ordenarPor===coluna){
      setDirecao(direcao==="asc" ? "desc" : "asc");
    } else {
      setOrdenarPor(coluna);
      setDirecao("asc");
    }
  };

  // Comparador genérico para ordenar arrays de processos

  // ── Exclusão e ações em lote ──────────────────────────────
  const excluirProcesso = (id) => {
    const p = processos.find(x=>x.id===id);
    const nome = p ? (p.numero || p.autor || "este processo") : "este processo";
    if(!confirm(`Excluir ${nome}? Esta ação não pode ser desfeita.`)) return;
    setProcessos(ps=>ps.filter(x=>x.id!==id));
    sbDeletar("processos", id); // apaga do banco imediatamente, sem depender do auto-save
    setSelected(null);
  };

  const toggleSelecionado = (id) => {
    setSelecionados(prev=>{
      const n = new Set(prev);
      if(n.has(id)) n.delete(id); else n.add(id);
      return n;
    });
  };

  const limparSelecao = () => { setSelecionados(new Set()); setModoSelecao(false); setAcaoLote(null); };

  const aplicarLote = (mudanca) => {
    const ids = selecionados;
    if(mudanca === "excluir"){
      if(!confirm(`Excluir ${ids.size} processo(s) selecionado(s)? Esta ação não pode ser desfeita.`)) return;
      setProcessos(ps=>ps.filter(p=>!ids.has(p.id)));
      ids.forEach(id=>sbDeletar("processos", id)); // apaga do banco imediatamente
      limparSelecao();
      return;
    }
    setProcessos(ps=>ps.map(p=>{
      if(!ids.has(p.id)) return p;
      if(mudanca.tipo==="arquivar") return {...p, arquivado:true, situacaoArquivo: mudanca.valor||"arquivado"};
      if(mudanca.tipo==="desarquivar") return {...p, arquivado:false, situacaoArquivo:null};
      if(mudanca.tipo==="status") return {...p, status: mudanca.valor};
      if(mudanca.tipo==="classificacao") return {...p, classificacao: mudanca.valor};
      if(mudanca.tipo==="responsavel") return {...p, responsavel: mudanca.valor};
      if(mudanca.tipo==="cliente") return {...p, clienteId: mudanca.valor?parseInt(mudanca.valor):"" };
      return p;
    }));
    limparSelecao();
  };

  const updateChecklist=updated=>{setProcessos(ps=>ps.map(p=>p.id===updated.id?updated:p));setSelected(updated);};
  const saveDebito=(id,info,parcelasGeradas)=>{
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,debito:info}:p));
    setSelected(s=>s&&s.id===id?{...s,debito:info}:s);
    if(parcelasGeradas && parcelasGeradas.length && setParcelas){
      setParcelas(ps=>[...ps, ...parcelasGeradas]);
    }
  };

  const registrarExito = (id, registro) => {
    setProcessos(ps=>ps.map(p=>{
      if(p.id!==id) return p;
      return {...p, exitos: [...(p.exitos||[]), registro], debito: null};
    }));
    setSelected(s=>{
      if(!s||s.id!==id) return s;
      return {...s, exitos: [...(s.exitos||[]), registro], debito: null};
    });
  };

  const saveAssunto=(id,assunto)=>{
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,assunto}:p));
    setSelected(s=>s&&s.id===id?{...s,assunto}:s);
  };

  const addAndamento=(id, andamento)=>{
    setProcessos(ps=>ps.map(p=>{
      if(p.id!==id) return p;
      const novos=[...(p.andamentos||[]), andamento].sort((a,b)=>a.data.localeCompare(b.data));
      return {...p, andamentos:novos};
    }));
    setSelected(s=>{
      if(!s||s.id!==id) return s;
      const novos=[...(s.andamentos||[]), andamento].sort((a,b)=>a.data.localeCompare(b.data));
      return {...s, andamentos:novos};
    });
  };

  const addTarefaProcesso = (procId, titulo) => {
    if(!setTarefas || !titulo.trim()) return;
    const proc = processos.find(p=>p.id===procId);
    setTarefas(ts=>[...ts, {
      id: Date.now(),
      titulo: titulo.trim(),
      responsavelId: "",
      procId: procId,
      clienteId: proc?.clienteId || "",
      status: "pendente",
      prioridade: "media",
      prazo: "",
      desc: "",
      arquivada: false,
    }]);
  };

  // Identifica a tarefa de prazo de um processo (gerada automaticamente).
  // Usa o título padrão para que a identificação persista após recarregar do banco.
  const ehTarefaDePrazo = (t, procId) => t.procId===procId && typeof t.titulo==="string" && t.titulo.startsWith("Cumprir prazo");

  // Salva o prazo do processo E sincroniza a tarefa de prazo correspondente
  const salvarPrazoComTarefa = (procId, novoPrazo) => {
    // 1. Atualiza o prazo do processo (na lista e no modal aberto)
    setProcessos(ps=>ps.map(x=>x.id===procId?{...x, prazo:novoPrazo}:x));
    setSelected(s=>s&&s.id===procId?{...s, prazo:novoPrazo}:s);
    if(!setTarefas) return;
    const proc = processos.find(p=>p.id===procId);
    const numero = proc?.numero || "";
    const tituloTarefa = `Cumprir prazo${numero?` — proc. ${numero}`:""}`;

    setTarefas(ts=>{
      const existentePrazo = ts.find(t=>ehTarefaDePrazo(t,procId) && t.status!=="concluido" && !t.arquivada);
      if(novoPrazo){
        if(existentePrazo){
          // PRORROGAÇÃO: atualiza a data da tarefa existente em vez de criar outra
          return ts.map(t=>t===existentePrazo ? {...t, prazo:novoPrazo, titulo:tituloTarefa} : t);
        }
        // Cria nova tarefa de prazo
        return [...ts, {
          id: Date.now()+Math.floor(Math.random()*1000),
          titulo: tituloTarefa,
          responsavelId: "",
          procId: procId,
          clienteId: proc?.clienteId || "",
          status: "pendente",
          prioridade: "alta",
          prazo: novoPrazo,
          desc: "Tarefa gerada automaticamente ao definir o prazo do processo.",
          arquivada: false,
        }];
      } else {
        // Prazo REMOVIDO: arquiva a tarefa de prazo pendente (não fica órfã)
        if(existentePrazo){
          return ts.map(t=>t===existentePrazo ? {...t, arquivada:true} : t);
        }
        return ts;
      }
    });
  };

  // VICE-VERSA: quando uma tarefa COM prazo é criada/editada no processo, atualiza o prazo do processo
  const sincronizarPrazoDaTarefa = (tarefa) => {
    if(!tarefa || !tarefa.procId || !tarefa.prazo) return;
    setProcessos(ps=>ps.map(x=>x.id===tarefa.procId ? {...x, prazo:tarefa.prazo} : x));
    setSelected(s=>s&&s.id===tarefa.procId ? {...s, prazo:tarefa.prazo} : s);
  };

  const concluirTarefaProc = tarefaId => {
    if(!setTarefas) return;
    // Ao concluir uma tarefa de prazo, limpa o prazo do processo correspondente
    const tarefa = (tarefas||[]).find(t=>t.id===tarefaId);
    if(tarefa && tarefa.procId && ehTarefaDePrazo(tarefa, tarefa.procId)){
      setProcessos(ps=>ps.map(x=>x.id===tarefa.procId ? {...x, prazo:null} : x));
      setSelected(s=>s&&s.id===tarefa.procId ? {...s, prazo:null} : s);
    }
    setTarefas(ts=>ts.map(t=>t.id===tarefaId?{...t,status:"concluido"}:t));
  };
  const arquivarTarefaProc = tarefaId => {
    if(!setTarefas) return;
    setTarefas(ts=>ts.map(t=>t.id===tarefaId?{...t,arquivada:true}:t));
  };

  const saveDriveLink = (clienteId, link) => {
    if(!setClientes || !clienteId) return;
    setClientes(cs=>cs.map(c=>c.id===clienteId?{...c,driveLink:link}:c));
  };

  const saveVinculo = (id, vinculo) => {
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,vinculo}:p));
    setSelected(s=>s&&s.id===id?{...s,vinculo}:s);
  };
  const removerVinculo = (id) => {
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,vinculo:null}:p));
    setSelected(s=>s&&s.id===id?{...s,vinculo:null}:s);
  };

  const abrirAnalisePrazo=proc=>{
    const ult=[...(proc.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data))[0];
    setSugestaoPrazo(detectarPrazo(ult));
    setAnalisandoPrazo(proc);
    setSelected(null);
  };
  const salvarPrazo=info=>{
    const procId = analisandoPrazo.id;
    setProcessos(ps=>ps.map(p=>p.id===procId?{...p,prazoProcessual:info}:p));
    if(setAgenda && info.vencimento){
      setAgenda(ag=>{
        // remove compromisso de prazo anterior deste processo (evita duplicar ao reanalisar)
        const semAntigo = ag.filter(c=>!(c.procId===procId && c._origemPrazo));
        const novoCompromisso = {
          id: Date.now(),
          titulo: `Prazo: ${info.proximoAto}`,
          tipo: "prazo",
          dataHora: `${info.vencimento}T23:59`,
          procId: procId,
          clienteId: analisandoPrazo.clienteId || "",
          responsavelId: "",
          local: "",
          confirmado: true,
          obs: `Parte responsável: ${info.parte}${info.base?` · Base legal: ${info.base}`:""}`,
          _origemPrazo: true,
        };
        return [...semAntigo, novoCompromisso];
      });
    }
    setAnalisandoPrazo(null); setSugestaoPrazo(null);
  };
  const cumprirPrazo=id=>{
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,prazoProcessual:null,status:"em_andamento"}:p));
    setSelected(s=>s&&s.id===id?{...s,prazoProcessual:null,status:"em_andamento"}:s);
    if(setAgenda) setAgenda(ag=>ag.filter(c=>!(c.procId===id && c._origemPrazo)));
  };
  const saveAudiencia=(id, info)=>{
    setProcessos(ps=>ps.map(p=>p.id===id?{...p,audiencia:info}:p));
    setSelected(s=>s&&s.id===id?{...s,audiencia:info}:s);
    if(setAgenda){
      setAgenda(ag=>{
        const semAntiga = ag.filter(c=>!(c.procId===id && c._origemAudiencia));
        if(!info || !info.data) return semAntiga;
        const proc = processos.find(x=>x.id===id);
        const novoCompromisso = {
          id: Date.now(),
          titulo: `Audiência — ${proc?.numero||""}`,
          tipo: "audiencia",
          dataHora: `${info.data}T${info.hora||"00:00"}`,
          procId: id,
          clienteId: proc?.clienteId || "",
          responsavelId: "",
          local: info.local || "",
          confirmado: true,
          obs: "",
          _origemAudiencia: true,
        };
        return [...semAntiga, novoCompromisso];
      });
    }
  };
  const toggleArquivado=(id, arquivado, situacao)=>{
    setProcessos(ps=>ps.map(p=>{
      if(p.id!==id) return p;
      if(!arquivado) return {...p, arquivado:false, situacaoArquivo:null};
      const novaSituacao = situacao || p.situacaoArquivo || null;
      const novoStatus = novaSituacao==="baixado_definitivo" ? "encerrado" : p.status;
      return {...p, arquivado:true, situacaoArquivo: novaSituacao, status: novoStatus};
    }));
    setSelected(s=>{
      if(!s||s.id!==id) return s;
      if(!arquivado) return {...s, arquivado:false, situacaoArquivo:null};
      const novaSituacao = situacao || s.situacaoArquivo || null;
      const novoStatus = novaSituacao==="baixado_definitivo" ? "encerrado" : s.status;
      return {...s, arquivado:true, situacaoArquivo: novaSituacao, status: novoStatus};
    });
  };

  const atualizarProcesso=async id=>{
    const proc=processos.find(p=>p.id===id);if(!proc)return;
    setUpdateState(s=>({...s,[id]:{loading:true,done:false,novos:0,erro:null}}));
    try{
      const hit=await buscarDataJud(proc.numero);
      const movsCNJ=parsarMovimentos(hit);
      const manuais=(proc.andamentos||[]).filter(a=>a.fonte!=="cnj");
      const datasExist=new Set((proc.andamentos||[]).filter(a=>a.fonte==="cnj").map(a=>a.data+a.desc));
      const novos=movsCNJ.filter(m=>!datasExist.has(m.data+m.desc)).length;
      const andamentosMesclados=[...manuais,...movsCNJ].sort((a,b)=>a.data.localeCompare(b.data));
      setProcessos(ps=>ps.map(p=>p.id===id?{...p,andamentos:andamentosMesclados}:p));
      setSelected(s=>s&&s.id===id?{...s,andamentos:andamentosMesclados}:s);
      setUpdateState(s=>({...s,[id]:{loading:false,done:true,novos,erro:null,ultimaVez:new Date()}}));
    }catch(e){
      const msg = (e && e.message) ? e.message : `Erro inesperado: ${String(e)}`;
      setUpdateState(s=>({...s,[id]:{loading:false,done:false,novos:0,erro:msg}}));
    }
  };

  const confirmarMovColadas = (novosAndamentos) => {
    if(!colandoMovPara || novosAndamentos.length===0){ setColandoMovPara(null); return; }
    const id = colandoMovPara.id;
    setProcessos(ps=>ps.map(p=>{
      if(p.id!==id) return p;
      const mesclados = [...(p.andamentos||[]), ...novosAndamentos].sort((a,b)=>(a.data||"").localeCompare(b.data||""));
      return {...p, andamentos: mesclados};
    }));
    setSelected(s=>{
      if(!s||s.id!==id) return s;
      const mesclados = [...(s.andamentos||[]), ...novosAndamentos].sort((a,b)=>(a.data||"").localeCompare(b.data||""));
      return {...s, andamentos: mesclados};
    });
    setColandoMovPara(null);
  };


  const urgentes=processos.filter(isUrgProc);
  const prazosVencidos=processos.filter(p=>p.prazoProcessual?.ativo&&p.prazoProcessual?.vencimento&&diasRest(p.prazoProcessual.vencimento)<0);
  const prazosUrgentes=processos.filter(p=>p.prazoProcessual?.ativo&&p.prazoProcessual?.vencimento&&diasRest(p.prazoProcessual.vencimento)>=0&&diasRest(p.prazoProcessual.vencimento)<=3);

  const statusGrupos=STATUS_VALIDOS.map(k=>({key:k,label:SC[k].label}));
  const cnt=s=>processos.filter(p=>normalizarStatus(p.status)===s).length;

  // Opções disponíveis para os filtros, derivadas dos dados existentes
  const anosDisponiveis = useMemo(()=>{
    const anos = new Set();
    processos.forEach(p=>{ const m=(p.numero||"").match(/\.(\d{4})\./); if(m) anos.add(m[1]); });
    return Array.from(anos).sort((a,b)=>b.localeCompare(a));
  },[processos]);
  const varasDisponiveis = useMemo(()=>{
    const varas = new Set();
    processos.forEach(p=>{ if(p.vara) varas.add(p.vara); });
    return Array.from(varas).sort();
  },[processos]);
  const responsaveisDisponiveis = useMemo(()=>{
    const resp = new Set();
    processos.forEach(p=>{ if(p.responsavel) resp.add(p.responsavel); });
    return Array.from(resp).sort();
  },[processos]);
  const todasClassificacoes = [...CLASSIFICACOES_VALIDAS, ...(classificacoesCustom||[])];

  const filtrosAtivos = [filtroCliente,filtroAno,filtroClassificacao,filtroSistema,filtroVara,filtroResponsavel].filter(Boolean).length;
  const limparFiltros = () => { setFiltroCliente("");setFiltroAno("");setFiltroClassificacao("");setFiltroSistema("");setFiltroVara("");setFiltroResponsavel(""); };

  const lista=useMemo(()=>{
    const q=busca.toLowerCase();
    let filtrada = processos.filter(p=>{
      if(normalizarStatus(p.status)!==aba) return false;
      if(q && !(p.numero.includes(q)||p.autor.toLowerCase().includes(q)||p.reu.toLowerCase().includes(q)||(p.responsavel||"").toLowerCase().includes(q))) return false;
      if(filtroCliente && String(p.clienteId)!==filtroCliente) return false;
      if(filtroAno){ const m=(p.numero||"").match(/\.(\d{4})\./); if(!m || m[1]!==filtroAno) return false; }
      if(filtroClassificacao && p.classificacao!==filtroClassificacao) return false;
      if(filtroSistema && p.sistema!==filtroSistema) return false;
      if(filtroVara && p.vara!==filtroVara) return false;
      if(filtroResponsavel && p.responsavel!==filtroResponsavel) return false;
      return true;
    });
    // Ordena a lista filtrada pela coluna selecionada
    filtrada.sort((a,b)=>{
      let vA = a[ordenarPor];
      let vB = b[ordenarPor];
      if(vA==null && vB==null) return 0;
      if(vA==null) return 1;
      if(vB==null) return -1;
      if(typeof vA==="number" && typeof vB==="number") return vA-vB;
      if(typeof vA==="string" && typeof vB==="string") return vA.localeCompare(vB, "pt-BR");
      return 0;
    });
    if(direcao==="desc") filtrada.reverse();
    return filtrada;
  },[processos,aba,busca,filtroCliente,filtroAno,filtroClassificacao,filtroSistema,filtroVara,filtroResponsavel,ordenarPor,direcao]);
  const salvar=form=>{
    let dados = {...form};
    // Se digitou um nome de cliente que não existe, cria o cliente automaticamente (só com o nome)
    const nomeDigitado = (form.clienteNome||"").trim();
    if(nomeDigitado && !form.clienteId){
      const existente = clientes.find(c=>c.nome.toLowerCase()===nomeDigitado.toLowerCase());
      if(existente){
        dados.clienteId = existente.id;
      } else {
        const novoId = Date.now() + Math.floor(Math.random()*1000);
        const novoCliente = {id:novoId, nome:nomeDigitado, cpf:"", rg:"", profissao:"", estadoCivil:"", nacionalidade:"", telefone:"", email:"", endereco:"", obs:""};
        setClientes(cs=>[...cs, novoCliente]);
        dados.clienteId = novoId;
      }
    }
    delete dados.clienteNome; // campo auxiliar, não vai para o banco
    setProcessos(ps=>dados.id?ps.map(p=>p.id===dados.id?dados:p):[...ps,{...dados,id:Date.now(),andamentos:[],documentos:[]}]);
    setEditando(null);setNovo(false);
  };
  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};
  const btnLote={fontSize:11,fontWeight:600,padding:"6px 11px",borderRadius:5,border:"none",background:"rgba(255,255,255,.15)",color:"#fff",cursor:"pointer",whiteSpace:"nowrap"};
  const btnIcon={fontSize:13,width:30,height:30,display:"flex",alignItems:"center",justifyContent:"center",cursor:"pointer",borderRadius:6,border:"1px solid var(--border1)",background:"#fff",padding:0,lineHeight:1};

  return(
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Processos</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>{processos.length} processo(s) cadastrados</p>
        </div>
        <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Novo processo</button>
      </div>

      {prazosVencidos.length>0&&<div style={{background:"var(--red-bg)",borderLeft:"3px solid var(--red)",borderRadius:6,padding:"9px 14px",marginBottom:8,fontSize:12,color:"var(--red)"}}><strong style={{textTransform:"uppercase",letterSpacing:".5px",marginRight:8}}>⚠ Prazos processuais vencidos:</strong>{prazosVencidos.map(p=><span key={p.id} style={{marginRight:12}}>{p.numero.split("-")[0]}… — {p.prazoProcessual.proximoAto} ({Math.abs(diasRest(p.prazoProcessual.vencimento))}d atraso)</span>)}</div>}
      {prazosUrgentes.length>0&&<div style={{background:"var(--amber-bg)",borderLeft:"3px solid var(--amber)",borderRadius:6,padding:"9px 14px",marginBottom:8,fontSize:12,color:"var(--amber)"}}><strong style={{textTransform:"uppercase",letterSpacing:".5px",marginRight:8}}>⏱ Prazos processuais próximos:</strong>{prazosUrgentes.map(p=><span key={p.id} style={{marginRight:12}}>{p.numero.split("-")[0]}… — {p.prazoProcessual.proximoAto} ({diasRest(p.prazoProcessual.vencimento)}d)</span>)}</div>}

      <div style={{background:"var(--accent-light)",border:"1px solid #C5DCF2",borderRadius:6,padding:"9px 14px",marginBottom:12,fontSize:12,color:"var(--navy2)",lineHeight:1.5}}>
        ℹ️ A consulta automática ao DataJud é bloqueada pelo navegador (CORS). Use o botão <strong>"📋 Colar mov."</strong> em cada processo para atualizar manualmente colando o conteúdo copiado do site do tribunal.
      </div>

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"8px 14px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:8,marginBottom:filtrosAbertos?0:12}}>
        <div style={{display:"flex",gap:0,flexWrap:"wrap",borderRight:"1px solid var(--border1)",paddingRight:12}}>
          {statusGrupos.map(({key,label})=>(
            <button key={key} onClick={()=>setAba(key)} style={{background:"none",border:"none",borderBottom:aba===key?"2px solid var(--navy2)":"2px solid transparent",color:aba===key?"var(--navy2)":"var(--text2)",padding:"5px 9px 7px",fontSize:10.5,fontWeight:aba===key?700:500,cursor:"pointer",textTransform:"uppercase",letterSpacing:".4px",whiteSpace:"nowrap"}}>{label} ({cnt(key)})</button>
          ))}
        </div>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <input placeholder="Buscar…" value={busca} onChange={e=>setBusca(e.target.value)} style={{fontSize:12,padding:"6px 11px",borderRadius:5,border:"1px solid var(--border2)",background:"#fff",color:"var(--text1)",width:170}}/>
          <button onClick={()=>setFiltrosAbertos(v=>!v)} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:`1px solid ${filtrosAtivos>0?"var(--accent)":"var(--border2)"}`,background:filtrosAtivos>0?"var(--accent-light)":"#fff",color:filtrosAtivos>0?"var(--accent)":"var(--text2)",fontWeight:600,whiteSpace:"nowrap",display:"flex",alignItems:"center",gap:5}}>
            ⚙ Filtros{filtrosAtivos>0&&<span style={{background:"var(--accent)",color:"#fff",borderRadius:8,padding:"0 6px",fontSize:9.5}}>{filtrosAtivos}</span>}
          </button>
          <button onClick={()=>{ if(modoSelecao) limparSelecao(); else setModoSelecao(true); }} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:`1px solid ${modoSelecao?"var(--accent)":"var(--border2)"}`,background:modoSelecao?"var(--accent-light)":"#fff",color:modoSelecao?"var(--accent)":"var(--text2)",fontWeight:600,whiteSpace:"nowrap"}}>
            {modoSelecao?"✕ Cancelar":"☑ Selecionar"}
          </button>
        </div>
      </div>

      {modoSelecao && selecionados.size>0 && (
        <div style={{background:"var(--navy)",borderRadius:8,padding:"10px 16px",marginBottom:12,display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:10}}>
          <span style={{fontSize:12.5,fontWeight:600,color:"#fff"}}>{selecionados.size} processo(s) selecionado(s)</span>
          <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
            <button onClick={()=>setAcaoLote("arquivar")} style={btnLote}>📦 Arquivar</button>
            <button onClick={()=>aplicarLote({tipo:"desarquivar"})} style={btnLote}>📂 Desarquivar</button>
            <button onClick={()=>setAcaoLote("status")} style={btnLote}>🔄 Status</button>
            <button onClick={()=>setAcaoLote("classificacao")} style={btnLote}>🏷 Classificação</button>
            <button onClick={()=>setAcaoLote("responsavel")} style={btnLote}>👤 Responsável</button>
            <button onClick={()=>setAcaoLote("cliente")} style={btnLote}>🔗 Cliente</button>
            <button onClick={()=>aplicarLote("excluir")} style={{...btnLote,background:"#DC2626",color:"#fff"}}>🗑 Excluir</button>
          </div>
        </div>
      )}

      {filtrosAbertos&&(
        <div style={{background:"#fff",border:"1px solid var(--border1)",borderTop:"none",borderRadius:"0 0 8px 8px",padding:"14px",marginBottom:12}}>
          <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:10,marginBottom:10}}>
            <div>
              <span style={lbl}>Cliente</span>
              <select value={filtroCliente} onChange={e=>setFiltroCliente(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Todos</option>
                {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}</option>)}
              </select>
            </div>
            <div>
              <span style={lbl}>Ano</span>
              <select value={filtroAno} onChange={e=>setFiltroAno(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Todos</option>
                {anosDisponiveis.map(a=><option key={a} value={a}>{a}</option>)}
              </select>
            </div>
            <div>
              <span style={lbl}>Classificação</span>
              <select value={filtroClassificacao} onChange={e=>setFiltroClassificacao(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Todas</option>
