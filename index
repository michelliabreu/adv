}
async function sbCarregar(tabela){
  const { data, error } = await sb.from(tabela).select("*");
  if(error){ console.error("Supabase carregar erro:", tabela, error.message); return null; }
  return data;
}
async function sbDeletar(tabela, id){
  const { error } = await sb.from(tabela).delete().eq("id", id);
  if(error) console.error("Supabase deletar erro:", tabela, error.message);
}

