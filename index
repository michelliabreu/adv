  const [vinculoTipo,setVinculoTipo]=useState(p.vinculo?.tipo||"Apensado a");
  const [vinculoProcId,setVinculoProcId]=useState(p.vinculo?.procId||"");
  const [registrandoExito,setRegistrandoExito]=useState(false);
  const [enviandoCobranca,setEnviandoCobranca]=useState(null);
  const [editandoAudiencia,setEditandoAudiencia]=useState(false);
  const [editandoPrazo,setEditandoPrazo]=useState(false);
  const [prazoForm,setPrazoForm]=useState(p.prazo||"");
  const [editandoPartes,setEditandoPartes]=useState(false);
  const [partesForm,setPartesForm]=useState([]);
  const [audienciaData,setAudienciaData]=useState(p.audiencia?.data||"");
  const [audienciaHora,setAudienciaHora]=useState(p.audiencia?.hora||"");
  const [audienciaLocal,setAudienciaLocal]=useState(p.audiencia?.local||"");
  const urg=isUrgProc(p),dias=p.prazo?diasRest(p.prazo):0;
  const cfg=CC[p.classificacao];
  const andOrd=[...(p.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data));
  const ultimaDecisao=andOrd.find(a=>a.decisao===true || (a.fonte==="cnj" && PALAVRAS_DECISAO.some(w=>a.desc?.toLowerCase().includes(w))));
  return(
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.45)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:680,maxWidth:"100%",maxHeight:"90vh",overflow:"auto",borderRadius:10,padding:"1.75rem",boxShadow:"0 25px 60px rgba(0,0,0,.3)"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:16}}>
          <div>
            {cliente && <p style={{fontSize:17,fontWeight:700,margin:"0 0 4px",color:"var(--navy)"}}>👤 {cliente.nome}</p>}
            <p style={{fontSize:10,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".8px",margin:"0 0 5px",fontWeight:600}}>Número do processo</p>
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <p style={{fontSize:18,fontWeight:700,margin:0,color:"var(--navy)",letterSpacing:".3px"}}>{p.numero}</p>
              {p.sistema&&<span style={{fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:4,background:"var(--accent-light)",color:"var(--accent)",textTransform:"uppercase",letterSpacing:".4px"}}>{p.sistema}</span>}
            </div>
            {cliente&&cliente.cpf&&<p style={{fontSize:11,color:"var(--text2)",margin:"4px 0 0"}}>CPF/CNPJ {cliente.cpf}</p>}
          </div>
          <button onClick={onClose} style={{background:"none",border:"none",cursor:"pointer",fontSize:22,color:"var(--text2)",padding:0,lineHeight:1}}>×</button>
        </div>

        {/* Assunto */}
        <div style={{marginBottom:14}}>
          {editandoAssunto ? (
            <div style={{display:"flex",gap:8}}>
              <input autoFocus value={assuntoForm} onChange={e=>setAssuntoForm(e.target.value)} placeholder="Ex: Inventário — Espólio de Álvaro Augusto Lopes" style={{...inp,flex:1}} onKeyDown={e=>{if(e.key==="Enter"){onSaveAssunto(p.id,assuntoForm);setEditandoAssunto(false);}}}/>
              <button onClick={()=>{onSaveAssunto(p.id,assuntoForm);setEditandoAssunto(false);}} style={{...btnPri,fontSize:11,padding:"7px 14px"}}>Salvar</button>
            </div>
          ) : (
            <div onClick={()=>setEditandoAssunto(true)} style={{cursor:"pointer",display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:14,fontWeight:600,color:p.assunto?"var(--navy)":"var(--text3)"}}>{p.assunto || "+ Adicionar assunto do processo"}</span>
              <span style={{fontSize:11,color:"var(--text3)"}}>✎</span>
            </div>
          )}
        </div>

        {/* Partes — editável inline */}
        <div style={{marginBottom:14}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
            <p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:0,fontWeight:600}}>Partes do processo</p>
            {!editandoPartes ? (
              <button onClick={()=>{
                // Prepara a lista de partes para edição (converte formato legado se necessário)
                if(temListaPartes(p)){ setPartesForm(p.partes.map(x=>({...x}))); }
                else {
                  const lista=[];
                  if(p.autor) lista.push({id:uid(),nome:p.autor,polo:"autor",clienteId:p.clienteId&&cliente&&cliente.nome===p.autor?p.clienteId:null});
                  if(p.reu) lista.push({id:uid(),nome:p.reu,polo:"reu",clienteId:p.clienteId&&cliente&&cliente.nome===p.reu?p.clienteId:null});
                  setPartesForm(lista);
                }
                setEditandoPartes(true);
              }} style={{...btnSec,fontSize:10,padding:"3px 10px"}}>✎ Editar partes</button>
            ) : (
              <div style={{display:"flex",gap:6}}>
                <button onClick={()=>setEditandoPartes(false)} style={{...btnSec,fontSize:10,padding:"3px 10px"}}>Cancelar</button>
                <button onClick={()=>{
                  const limpas=partesForm.filter(x=>x.nome&&x.nome.trim());
                  const autorTxt=limpas.filter(x=>x.polo==="autor").map(x=>x.nome).join(" e ");
                  const reuTxt=limpas.filter(x=>x.polo==="reu").map(x=>x.nome).join(" e ");
                  onSaveCampo(p.id,"partes",limpas);
                  onSaveCampo(p.id,"autor",autorTxt);
                  onSaveCampo(p.id,"reu",reuTxt);
                  setEditandoPartes(false);
                }} style={{...btnPri,fontSize:10,padding:"3px 12px"}}>Salvar partes</button>
              </div>
            )}
          </div>
          {editandoPartes ? (
            <div style={{border:"1px solid var(--border1)",borderRadius:7,padding:"12px 14px",background:"var(--bg2)"}}>
              <PartesEditor partes={partesForm} setPartes={setPartesForm} clientes={clientes||[]}/>
            </div>
          ) : temListaPartes(p) ? (
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14}}>
              <div>
                <p style={{fontSize:9.5,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text3)",margin:"0 0 5px",fontWeight:600}}>Polo ativo</p>
                {partesPorPolo(p,"autor").map(parte=>(
                  <div key={parte.id} style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <span style={{fontSize:13,fontWeight:parte.clienteId?700:500,color:parte.clienteId?"var(--accent)":"var(--text1)"}}>{parte.nome}</span>
                    {parte.clienteId&&<span style={{fontSize:9,fontWeight:700,padding:"1px 6px",borderRadius:3,background:"var(--accent-light)",color:"var(--accent)",textTransform:"uppercase",letterSpacing:".3px"}}>cliente</span>}
                  </div>
                ))}
              </div>
              <div>
                <p style={{fontSize:9.5,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text3)",margin:"0 0 5px",fontWeight:600}}>Polo passivo</p>
                {partesPorPolo(p,"reu").map(parte=>(
                  <div key={parte.id} style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
                    <span style={{fontSize:13,fontWeight:parte.clienteId?700:500,color:parte.clienteId?"var(--accent)":"var(--text1)"}}>{parte.nome}</span>
                    {parte.clienteId&&<span style={{fontSize:9,fontWeight:700,padding:"1px 6px",borderRadius:3,background:"var(--accent-light)",color:"var(--accent)",textTransform:"uppercase",letterSpacing:".3px"}}>cliente</span>}
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"12px 24px"}}>
              {[["Autor",p.autor],["Réu",p.reu]].map(([k,v])=>(
                <div key={k}><p style={{fontSize:9.5,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text3)",margin:"0 0 3px",fontWeight:600}}>{k}</p><p style={{fontSize:13,fontWeight:600,margin:0}}>{v||"—"}</p></div>
              ))}
            </div>
          )}
        </div>

        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"12px 24px",marginBottom:14}}>
          <div><p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>Vara</p><p style={{fontSize:13,fontWeight:600,margin:0}}>{p.vara}</p></div>
          <div><p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>Responsável</p><p style={{fontSize:13,fontWeight:600,margin:0}}>{p.responsavel||"—"}</p></div>
          <div>
            <p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>Prazo do processo</p>
            {editandoPrazo ? (
              <div style={{display:"flex",gap:5,alignItems:"center",flexWrap:"wrap"}}>
                <input type="date" autoFocus value={prazoForm||""} onChange={e=>setPrazoForm(e.target.value)} style={{...inp,padding:"4px 7px",fontSize:12,flex:1,minWidth:130}}/>
                <button onClick={()=>{
                  if(onSavePrazoComTarefa) onSavePrazoComTarefa(p.id, prazoForm||null);
                  else onSaveCampo(p.id,"prazo",prazoForm||null);
                  setEditandoPrazo(false);
                }} style={{...btnPri,fontSize:10,padding:"4px 9px"}}>OK</button>
                <button onClick={()=>{setPrazoForm("");onSaveCampo(p.id,"prazo",null);setEditandoPrazo(false);}} title="Deixar sem prazo" style={{...btnSec,fontSize:10,padding:"4px 8px"}}>Sem prazo</button>
                <button onClick={()=>setEditandoPrazo(false)} style={{...btnSec,fontSize:10,padding:"4px 8px"}}>Cancelar</button>
              </div>
            ) : (
              <p onClick={()=>{setPrazoForm(p.prazo||"");setEditandoPrazo(true);}} style={{fontSize:13,fontWeight:600,margin:0,cursor:"pointer",display:"inline-flex",alignItems:"center",gap:6}}>{p.prazo?fmtData(p.prazo):<span style={{color:"var(--text3)",fontWeight:400}}>Sem prazo</span>} <span style={{fontSize:10,color:"var(--text3)"}}>✎</span></p>
            )}
          </div>
          <div><p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>Valor da causa</p><p style={{fontSize:13,fontWeight:600,margin:0}}>{p.valorCausa?fmtBRL(parseFloat(p.valorCausa)):"—"}</p></div>
        </div>

        {/* Débito */}
        <div>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",fontWeight:600}}>Situação financeira do débito</span>
            <div style={{display:"flex",gap:6}}>
              <button onClick={()=>setEditandoDebito(true)} style={{...btnSec,fontSize:10.5,padding:"4px 11px"}}>{p.debito?.valor?"✎ Atualizar valor":"+ Lançar valor"}</button>
              {p.debito?.valor>0&&<button onClick={()=>setRegistrandoExito(true)} style={{...btnSec,fontSize:10.5,padding:"4px 11px",borderColor:"#A8DDB8",color:"var(--green)",background:"var(--green-bg)"}}>🏆 Débito baixado</button>}
            </div>
          </div>
          <DebitoBadge debito={p.debito} compact={false}/>

          {p.exitos&&p.exitos.length>0&&(
            <div style={{marginTop:10}}>
              <p style={{fontSize:10,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--green)",margin:"0 0 8px"}}>🏆 Histórico de êxitos</p>
              {p.exitos.map((ex,i)=>(
                <div key={i} style={{background:"var(--green-bg)",border:"1px solid #A8DDB8",borderRadius:6,padding:"10px 12px",marginBottom:8}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",gap:8,marginBottom:4}}>
                    <span style={{fontSize:12,fontWeight:700,color:"var(--green)"}}>{fmtBRL(ex.valorBaixado)} baixado</span>
                    <span style={{fontSize:10.5,color:"var(--text2)"}}>{fmtData(ex.data)}</span>
                  </div>
                  <p style={{fontSize:11.5,color:"var(--text1)",margin:"0 0 6px"}}>Honorários de êxito ({ex.percentual}%): <strong>{fmtBRL(ex.valorHonorarios)}</strong></p>
                  {ex.observacao&&<p style={{fontSize:11,color:"var(--text2)",margin:"0 0 8px"}}>{ex.observacao}</p>}
                  <button onClick={()=>setEnviandoCobranca(ex)} style={{fontSize:10.5,padding:"4px 11px",cursor:"pointer",borderRadius:4,border:"1px solid var(--navy2)",background:"var(--navy2)",color:"#fff",fontWeight:600}}>📤 Gerar cobrança</button>
                </div>
              ))}
            </div>
          )}
        </div>

        {p.prazoProcessual?.ativo&&<div>
          <PrazoBadge prazoInfo={p.prazoProcessual} compact={false}/>
          <button onClick={()=>{if(confirm(`Marcar o prazo "${p.prazoProcessual.proximoAto}" como cumprido?\n\nO status do processo mudará para "Em Andamento".`)) onCumprirPrazo(p.id);}} style={{...btnSec,fontSize:10.5,padding:"5px 12px",marginTop:6,borderColor:"#A8DDB8",color:"var(--green)",background:"var(--green-bg)"}}>✓ Marcar prazo como cumprido</button>
        </div>}

        {/* Audiência — só aparece quando agendada ou ao adicionar */}
        {(p.audiencia?.data || editandoAudiencia) ? (
          <div style={{marginTop:14,padding:"12px 14px",background:"var(--bg2)",borderRadius:6,border:"1px solid var(--border1)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:editandoAudiencia?10:0}}>
              <span style={{fontSize:11,fontWeight:600,color:"var(--text1)"}}>⚖️ Audiência</span>
              {!editandoAudiencia&&<button onClick={()=>setEditandoAudiencia(true)} style={{...btnSec,fontSize:10,padding:"3px 10px"}}>✎ Editar</button>}
            </div>
            {editandoAudiencia ? (
              <div style={{display:"flex",flexDirection:"column",gap:8}}>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                  <div><span style={{...lbl,margin:"0 0 3px"}}>Data</span><input type="date" value={audienciaData} onChange={e=>setAudienciaData(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}/></div>
                  <div><span style={{...lbl,margin:"0 0 3px"}}>Hora</span><input type="time" value={audienciaHora} onChange={e=>setAudienciaHora(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}/></div>
                </div>
                <div><span style={{...lbl,margin:"0 0 3px"}}>Local</span><input value={audienciaLocal} onChange={e=>setAudienciaLocal(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}} placeholder="Ex: Vara, sala, link da videoconferência…"/></div>
                <div style={{display:"flex",gap:6,justifyContent:"flex-end"}}>
                  {p.audiencia?.data&&<button onClick={()=>{onSaveAudiencia(p.id,null);setEditandoAudiencia(false);}} style={{...btnSec,fontSize:10.5,padding:"5px 10px",color:"var(--red)"}}>Remover</button>}
                  <button onClick={()=>setEditandoAudiencia(false)} style={{...btnSec,fontSize:10.5,padding:"5px 10px"}}>Cancelar</button>
                  <button onClick={()=>{
                    if(!audienciaData) return;
                    onSaveAudiencia(p.id, {data:audienciaData, hora:audienciaHora, local:audienciaLocal});
                    setEditandoAudiencia(false);
                  }} style={{...btnPri,fontSize:10.5,padding:"5px 12px"}}>Salvar</button>
                </div>
              </div>
            ) : (
              <div>
                <p style={{fontSize:13,fontWeight:700,color:"var(--navy)",margin:"0 0 2px"}}>{fmtData(p.audiencia.data)}{p.audiencia.hora?` às ${p.audiencia.hora}`:""}</p>
                {p.audiencia.local&&<p style={{fontSize:11.5,color:"var(--text2)",margin:0}}>{p.audiencia.local}</p>}
              </div>
            )}
          </div>
        ) : (
          <div style={{marginTop:14}}>
            <button onClick={()=>setEditandoAudiencia(true)} style={{...btnSec,fontSize:11,padding:"6px 12px",color:"var(--text2)"}}>⚖️ + Agendar audiência</button>
          </div>
        )}

        {/* Vínculo com outro processo */}
        <div style={{marginTop:10,padding:"10px 12px",background:"var(--bg2)",borderRadius:6,border:"1px solid var(--border1)"}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <span style={{fontSize:11,fontWeight:600,color:"var(--text1)"}}>🔗 Processo relacionado</span>
            {!editandoVinculo&&<button onClick={()=>setEditandoVinculo(true)} style={{...btnSec,fontSize:10,padding:"3px 10px"}}>{p.vinculo?"✎ Editar":"+ Vincular"}</button>}
          </div>
          {editandoVinculo ? (
            <div style={{marginTop:8,display:"flex",flexDirection:"column",gap:8}}>
              <select value={vinculoTipo} onChange={e=>setVinculoTipo(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                {["Apensado a","Incidente de","Dependência de","Conexo a"].map(t=><option key={t} value={t}>{t}</option>)}
              </select>
              <select value={vinculoProcId} onChange={e=>setVinculoProcId(e.target.value?parseInt(e.target.value):"")} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Selecione o processo…</option>
                {processos.filter(x=>x.id!==p.id).map(x=><option key={x.id} value={x.id}>{x.numero} — {x.autor.slice(0,30)}</option>)}
              </select>
              <div style={{display:"flex",gap:6,justifyContent:"flex-end"}}>
                <button onClick={()=>setEditandoVinculo(false)} style={{...btnSec,fontSize:10.5,padding:"4px 10px"}}>Cancelar</button>
                <button onClick={()=>{ if(!vinculoProcId) return; onSaveVinculo(p.id, {tipo:vinculoTipo, procId:vinculoProcId}); setEditandoVinculo(false); }} style={{...btnPri,fontSize:10.5,padding:"4px 10px"}}>Salvar</button>
              </div>
            </div>
          ) : p.vinculo ? (
            <div onClick={()=>{ const proc = processos.find(x=>x.id===p.vinculo.procId); if(proc) onAbrirOutroProcesso(proc); }} style={{marginTop:6,fontSize:12,color:"var(--accent)",cursor:"pointer"}}>
              {p.vinculo.tipo} <strong>{processos.find(x=>x.id===p.vinculo.procId)?.numero || "processo removido"}</strong>
              <button onClick={e=>{e.stopPropagation(); onRemoverVinculo(p.id);}} style={{marginLeft:8,background:"none",border:"none",color:"var(--text3)",cursor:"pointer",fontSize:13}}>×</button>
            </div>
          ) : (
            <p style={{fontSize:11,color:"var(--text3)",margin:"4px 0 0"}}>Nenhum vínculo cadastrado.</p>
          )}
        </div>

        <div style={{borderTop:"1px solid var(--border1)",paddingTop:14,marginTop:16}}>
          <div style={{display:"flex",gap:0,marginBottom:14,borderBottom:"1px solid var(--border1)"}}>
            {["andamentos","tarefas","documentacao","checklist"].map(t=><button key={t} onClick={()=>setTab(t)} style={{background:"none",border:"none",borderBottom:tab===t?"2px solid var(--navy2)":"2px solid transparent",color:tab===t?"var(--navy2)":"var(--text2)",padding:"6px 18px 8px",fontSize:12,fontWeight:tab===t?600:500,cursor:"pointer",textTransform:"uppercase",letterSpacing:".6px",marginBottom:-1,whiteSpace:"nowrap"}}>{t==="documentacao"?"Documentação":t==="checklist"?"Obs / Checklist":t.charAt(0).toUpperCase()+t.slice(1)}</button>)}
          </div>
          {tab==="andamentos"&&<div>
            <div style={{display:"flex",gap:8,marginBottom:14}}>
              <input value={novoAndDesc} onChange={e=>setNovoAndDesc(e.target.value)} placeholder="Descrever novo andamento…" style={{...inp,flex:1}}/>
              <input type="date" value={novoAndData} onChange={e=>setNovoAndData(e.target.value)} style={{...inp,width:140}}/>
            </div>
            <label style={{display:"flex",alignItems:"center",gap:7,fontSize:11.5,color:"var(--text2)",cursor:"pointer",marginBottom:10}}>
              <input type="checkbox" checked={novoAndDecisao} onChange={e=>setNovoAndDecisao(e.target.checked)} style={{width:14,height:14}}/>
              Marcar como decisão/despacho importante
            </label>
            <button onClick={()=>{
              if(!novoAndDesc.trim()||!novoAndData) return;
              onAddAndamento(p.id, {data:novoAndData, desc:novoAndDesc.trim(), fonte:"manual", decisao:novoAndDecisao});
              setNovoAndDesc(""); setNovoAndDecisao(false);
            }} style={{...btnSec, fontSize:11.5, marginBottom:16}}>+ Adicionar andamento</button>

            {andOrd.length===0?<div style={{fontSize:13,color:"var(--text2)"}}>Sem andamentos.</div>:andOrd.map((a,i)=>(
              <div key={i} style={{display:"flex",gap:14,fontSize:13,marginBottom:8,alignItems:"flex-start"}}>
                <span style={{color:"var(--text2)",fontSize:11,whiteSpace:"nowrap",minWidth:80,marginTop:2}}>{fmtData(a.data)}</span>
                <span style={{flex:1}}>{a.desc}
                  {a.decisao===true&&<span style={{marginLeft:6,background:"var(--amber-bg)",color:"var(--amber)",borderRadius:3,padding:"0 5px",fontSize:10,fontWeight:600}}>decisão</span>}
                  {a.fonte==="cnj"&&<span style={{marginLeft:4,background:"var(--accent-light)",color:"var(--navy2)",borderRadius:3,padding:"0 5px",fontSize:10,fontWeight:600}}>CNJ</span>}
                  {a.fonte==="manual"&&<span style={{marginLeft:4,background:"var(--bg2)",color:"var(--text2)",borderRadius:3,padding:"0 5px",fontSize:10,fontWeight:600}}>Manual</span>}
                </span>
              </div>
            ))}
          </div>}
          {tab==="tarefas"&&<div>
            <div style={{display:"flex",gap:8,marginBottom:14}}>
              <input value={novaTarefaTitulo} onChange={e=>setNovaTarefaTitulo(e.target.value)} onKeyDown={e=>{if(e.key==="Enter"){onAddTarefaProcesso(p.id,novaTarefaTitulo);setNovaTarefaTitulo("");}}} placeholder="Ex: Elaborar substabelecimento…" style={{...inp,flex:1}}/>
              <button onClick={()=>{onAddTarefaProcesso(p.id,novaTarefaTitulo);setNovaTarefaTitulo("");}} style={{...btnPri,fontSize:11.5,whiteSpace:"nowrap"}}>+ Criar tarefa</button>
            </div>
            <p style={{fontSize:10.5,color:"var(--text2)",margin:"0 0 14px"}}>A tarefa é criada como <strong>Pendente</strong> no quadro de Tarefas, vinculada a este processo.</p>

            {(tarefasDoProcesso||[]).filter(t=>!t.arquivada).length===0
              ? <div style={{fontSize:13,color:"var(--text2)"}}>Nenhuma tarefa ativa para este processo.</div>
              : (tarefasDoProcesso||[]).filter(t=>!t.arquivada).map(t=>{
                  const cfg = STATUS_TAREFA_CFG[t.status];
                  return (
                    <div key={t.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",border:"1px solid var(--border1)",borderRadius:6,padding:"9px 12px",marginBottom:8}}>
                      <div>
                        <p style={{fontSize:12.5,fontWeight:600,margin:"0 0 4px"}}>{t.titulo}</p>
                        <Pill bg={cfg.bg} color={cfg.color} label={cfg.label} sm/>
                      </div>
                      {t.status!=="concluido"
                        ? <button onClick={()=>onConcluirTarefaProc(t.id)} style={{...btnSec,fontSize:10.5,padding:"5px 10px",whiteSpace:"nowrap"}}>✓ Concluir</button>
                        : <button onClick={()=>onArquivarTarefaProc(t.id)} style={{...btnSec,fontSize:10.5,padding:"5px 10px",whiteSpace:"nowrap",color:"var(--text2)"}}>📦 Arquivar</button>
                      }
                    </div>
                  );
                })
            }

            {(tarefasDoProcesso||[]).filter(t=>t.arquivada).length>0 && (
              <div style={{marginTop:16}}>
                <p style={{fontSize:10.5,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"0 0 8px"}}>Concluídas e arquivadas</p>
                {(tarefasDoProcesso||[]).filter(t=>t.arquivada).map(t=>(
                  <div key={t.id} style={{fontSize:12,color:"var(--text2)",padding:"6px 0",borderBottom:"1px solid var(--border1)",textDecoration:"line-through"}}>{t.titulo}</div>
                ))}
              </div>
            )}
          </div>}
          {tab==="documentacao"&&<ChecklistDocumentacao processo={p} cliente={cliente} onUpdate={onChecklistUpdate} onSaveDriveLink={onSaveDriveLink}/>}
          {tab==="checklist"&&<ChecklistPanel processo={p} onUpdate={onChecklistUpdate}/>}
        </div>
        {/* Arquivamento — discreto, ao fim */}
        <div style={{marginTop:18,paddingTop:14,borderTop:"1px solid var(--border1)"}}>
          <label style={{display:"flex",alignItems:"center",gap:8,fontSize:11.5,color:"var(--text2)",cursor:"pointer"}}>
            <input type="checkbox" checked={!!p.arquivado} onChange={e=>onToggleArquivado(p.id, e.target.checked)} style={{width:15,height:15}}/>
            Arquivar este processo
          </label>
          {p.arquivado&&(
            <div style={{display:"flex",gap:8,marginTop:8}}>
              {[["baixado_definitivo","Baixado Definitivo"],["ag_prescricao","Ag. Prescrição"]].map(([v,l])=>(
                <button key={v} onClick={()=>onToggleArquivado(p.id, true, v)} style={{
                  fontSize:10.5,padding:"5px 12px",cursor:"pointer",borderRadius:5,fontWeight:600,
                  border:`1px solid ${p.situacaoArquivo===v?"var(--navy2)":"var(--border2)"}`,
                  background:p.situacaoArquivo===v?"var(--navy2)":"#fff",
                  color:p.situacaoArquivo===v?"#fff":"var(--text2)",
                }}>{l}</button>
              ))}
            </div>
          )}
        </div>

        <div style={{marginTop:20,display:"flex",gap:8,justifyContent:"flex-end",alignItems:"center"}}>
          {onExcluir&&<button onClick={()=>{onExcluir(p.id);onClose();}} style={{...btnSec,color:"var(--red)",borderColor:"#F3B8B8",marginRight:"auto"}}>🗑 Excluir processo</button>}
          <button onClick={()=>onSavePrazo(p)} style={{...btnSec,display:"flex",alignItems:"center",gap:6}}>⏱ Analisar prazo</button>
          <button onClick={()=>onEdit(p)} style={btnSec}>Editar</button>
          <button onClick={onClose} style={btnPri}>Fechar</button>
        </div>
      </div>
      {editandoDebito&&<ModalDebito proc={p} cliente={cliente} onSave={(info,parcelasGeradas)=>{onSaveDebito(p.id,info,parcelasGeradas);setEditandoDebito(false);}} onClose={()=>setEditandoDebito(false)}/>}
      {registrandoExito&&<ModalExito proc={p} cliente={cliente} onSave={registro=>{onRegistrarExito(p.id,registro);setRegistrandoExito(false);}} onClose={()=>setRegistrandoExito(false)}/>}
      {enviandoCobranca&&<ModalEnviarCobranca proc={p} cliente={cliente} exito={enviandoCobranca} onClose={()=>setEnviandoCobranca(null)}/>}
    </div>
  );
}

// ── Modal Form Processo (sem campo e-mail — fica no Cliente) ──
function PartesEditor({partes, setPartes, clientes}){
  const addParte = (polo) => setPartes(ps=>[...ps, {id:uid(), nome:"", polo, clienteId:null}]);
  const updParte = (id, campo, valor) => setPartes(ps=>ps.map(x=>x.id===id?{...x,[campo]:valor}:x));
  const delParte = (id) => setPartes(ps=>ps.filter(x=>x.id!==id));
  const autores = partes.filter(x=>x.polo==="autor");
  const reus = partes.filter(x=>x.polo==="reu");

  const Linha = ({parte}) => (
    <div style={{display:"flex",gap:6,alignItems:"center",marginBottom:6}}>
      <input value={parte.nome} onChange={e=>updParte(parte.id,"nome",e.target.value)} placeholder="Nome completo" style={{...inp,flex:1,fontSize:12,padding:"6px 9px"}}/>
      <select value={parte.clienteId||""} onChange={e=>updParte(parte.id,"clienteId",e.target.value?parseInt(e.target.value):null)} style={{...inp,width:130,fontSize:11,padding:"6px 7px"}}>
        <option value="">Não é cliente</option>
        {[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome.length>18?c.nome.slice(0,18)+"…":c.nome}</option>)}
      </select>
      <button type="button" onClick={()=>delParte(parte.id)} style={{background:"none",border:"none",cursor:"pointer",color:"var(--text3)",fontSize:15,padding:"0 4px",lineHeight:1}}>×</button>
    </div>
  );

  return (
    <div>
      <div style={{marginBottom:12}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
          <span style={{...lbl,margin:0}}>Polo ativo — Autor(es)/Requerente(s)</span>
          <button type="button" onClick={()=>addParte("autor")} style={{fontSize:10,padding:"3px 9px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>+ Adicionar</button>
        </div>
        {autores.length===0?<p style={{fontSize:11,color:"var(--text3)",margin:0}}>Nenhuma parte no polo ativo.</p>:autores.map(p=><Linha key={p.id} parte={p}/>)}
      </div>
      <div>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
          <span style={{...lbl,margin:0}}>Polo passivo — Réu(s)/Requerido(s)</span>
          <button type="button" onClick={()=>addParte("reu")} style={{fontSize:10,padding:"3px 9px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"none",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>+ Adicionar</button>
        </div>
        {reus.length===0?<p style={{fontSize:11,color:"var(--text3)",margin:0}}>Nenhuma parte no polo passivo.</p>:reus.map(p=><Linha key={p.id} parte={p}/>)}
      </div>
    </div>
  );
}

function ModalFormProc({processo,clientes,onSave,onClose,onNovoCliente,classificacoesCustom,onNovaClassificacao}){
