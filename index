    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.5)",zIndex:700,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
