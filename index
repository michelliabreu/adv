              </select>
            </div>
            <div>
              <span style={lbl}>Vara / Comarca</span>
              <select value={filtroVara} onChange={e=>setFiltroVara(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Todas</option>
                {varasDisponiveis.map(v=><option key={v} value={v}>{v.length>40?v.slice(0,40)+"…":v}</option>)}
              </select>
            </div>
            <div>
              <span style={lbl}>Responsável</span>
              <select value={filtroResponsavel} onChange={e=>setFiltroResponsavel(e.target.value)} style={{...inp,padding:"6px 8px",fontSize:12}}>
                <option value="">Todos</option>
                {responsaveisDisponiveis.map(r=><option key={r} value={r}>{r}</option>)}
              </select>
            </div>
          </div>
          {filtrosAtivos>0&&(
            <div style={{display:"flex",justifyContent:"flex-end",marginTop:10}}>
              <button onClick={limparFiltros} style={{...btnSec,fontSize:10.5,padding:"5px 12px"}}>Limpar filtros</button>
