            </div>
          </div>
          <div><span style={lbl}>Assunto</span><input value={f.assunto||""} onChange={e=>s("assunto",e.target.value)} style={inp} placeholder="Ex: Inventário, Execução de título, Ação de cobrança…"/></div>

          <div style={{border:"1px solid var(--border1)",borderRadius:7,padding:"12px 14px",background:"var(--bg2)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:modoMultiplo?12:0}}>
              <span style={{fontSize:11.5,fontWeight:600,color:"var(--text1)"}}>Partes do processo</span>
              {!modoMultiplo ? (
                <button type="button" onClick={ativarModoMultiplo} style={{fontSize:10,padding:"4px 10px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"#fff",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>+ Múltiplas partes (litisconsórcio)</button>
              ) : (
                <button type="button" onClick={()=>setModoMultiplo(false)} style={{fontSize:10,padding:"4px 10px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"#fff",color:"var(--text2)",fontWeight:600,whiteSpace:"nowrap"}}>Usar campo simples</button>
              )}
            </div>
            {modoMultiplo ? (
              <PartesEditor partes={f.partes||[]} setPartes={setPartes} clientes={clientes}/>
            ) : (
              <div style={{display:"flex",flexDirection:"column",gap:10}}>
                <div style={{display:"flex",justifyContent:"flex-end"}}>
                  <button type="button" onClick={()=>setF(x=>({...x,autor:x.reu,reu:x.autor}))} style={{fontSize:10,padding:"3px 9px",cursor:"pointer",borderRadius:4,border:"1px solid var(--border2)",background:"#fff",color:"var(--text2)",fontWeight:600,whiteSpace:"nowrap"}}>⇄ Inverter Autor/Réu</button>
                </div>
                <div><span style={lbl}>Autor / Requerente</span><input value={f.autor||""} onChange={e=>s("autor",e.target.value)} style={inp}/></div>
                <div><span style={lbl}>Réu / Requerido</span><input value={f.reu||""} onChange={e=>s("reu",e.target.value)} style={inp}/></div>
              </div>
            )}
          </div>

          <div><span style={lbl}>Vara / Órgão</span><input value={f.vara||""} onChange={e=>s("vara",e.target.value)} style={inp}/></div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Responsável</span><input value={f.responsavel||""} onChange={e=>s("responsavel",e.target.value)} style={inp}/></div>
            <div><span style={lbl}>Valor da causa (R$)</span><input type="number" step="0.01" value={f.valorCausa||""} onChange={e=>s("valorCausa",e.target.value)} style={inp} placeholder="0,00"/></div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr",gap:10}}>
            <div><span style={lbl}>Tipo</span><select value={f.tipo} onChange={e=>s("tipo",e.target.value)} style={{...inp,padding:"7px 8px"}}><option value="judicial">Judicial</option><option value="administrativo">Administrativo</option></select></div>
            <div>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:4}}>
                <span style={{...lbl,margin:0}}>Classificação</span>
                {!criandoClassificacao&&<button type="button" onClick={()=>setCriandoClassificacao(true)} style={{fontSize:9,padding:"1px 6px",cursor:"pointer",borderRadius:3,border:"1px solid var(--border2)",background:"none",color:"var(--accent)",fontWeight:600,whiteSpace:"nowrap"}}>+ Nova</button>}
              </div>
              {!criandoClassificacao ? (
                <select value={f.classificacao||""} onChange={e=>s("classificacao",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                  <option value="">Selecione…</option>
                  {CLASSIFICACOES_VALIDAS.map(k=><option key={k} value={k}>{CC[k].label}</option>)}
                  {(classificacoesCustom||[]).map(c=><option key={c} value={c}>{c}</option>)}
                </select>
              ) : (
                <div style={{display:"flex",gap:4}}>
                  <input autoFocus value={novaClassifTexto} onChange={e=>setNovaClassifTexto(e.target.value)} placeholder="Ex: Usucapião" style={{...inp,padding:"7px 8px",fontSize:12}} onKeyDown={e=>{if(e.key==="Enter"&&novaClassifTexto.trim()){onNovaClassificacao&&onNovaClassificacao(novaClassifTexto.trim());s("classificacao",novaClassifTexto.trim());setCriandoClassificacao(false);setNovaClassifTexto("");}}}/>
                  <button type="button" onClick={()=>{ if(novaClassifTexto.trim()){ onNovaClassificacao&&onNovaClassificacao(novaClassifTexto.trim()); s("classificacao",novaClassifTexto.trim()); } setCriandoClassificacao(false); setNovaClassifTexto(""); }} style={{...btnPri,fontSize:10,padding:"7px 9px",whiteSpace:"nowrap"}}>✓</button>
                  <button type="button" onClick={()=>{setCriandoClassificacao(false);setNovaClassifTexto("");}} style={{...btnSec,fontSize:10,padding:"7px 9px",whiteSpace:"nowrap"}}>×</button>
                </div>
              )}
            </div>
            <div><span style={lbl}>Status</span><select value={normalizarStatus(f.status)} onChange={e=>s("status",e.target.value)} style={{...inp,padding:"7px 8px"}}>{STATUS_VALIDOS.map(k=><option key={k} value={k}>{SC[k].label}</option>)}</select></div>
            <div>
              <span style={lbl}>Prazo <span style={{color:"var(--text3)",fontWeight:400,textTransform:"none",letterSpacing:0}}>(opcional)</span></span>
              <div style={{display:"flex",gap:6,alignItems:"center"}}>
                <input type="date" value={f.prazo||""} onChange={e=>s("prazo",e.target.value)} style={{...inp,padding:"7px 8px",flex:1}}/>
                {f.prazo&&<button type="button" onClick={()=>s("prazo","")} title="Remover prazo" style={{fontSize:11,padding:"7px 10px",cursor:"pointer",borderRadius:5,border:"1px solid var(--border2)",background:"#fff",color:"var(--text2)",whiteSpace:"nowrap"}}>Sem prazo</button>}
              </div>
            </div>
          </div>

          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div>
              <span style={lbl}>Arquivamento</span>
              <select value={f.arquivado ? (f.situacaoArquivo||"arquivado") : ""} onChange={e=>{
                const v=e.target.value;
                if(!v){ s("arquivado",false); s("situacaoArquivo",null); }
                else { setF(x=>({...x, arquivado:true, situacaoArquivo:v})); }
              }} style={{...inp,padding:"7px 8px"}}>
                <option value="">Não arquivado (ativo)</option>
                <option value="baixado_definitivo">Arquivado — Baixado definitivamente</option>
                <option value="ag_prescricao">Arquivado — Aguardando prescrição</option>
                <option value="arquivado">Arquivado — Outro motivo</option>
              </select>
            </div>
            <div><span style={lbl}>Link do Google Drive</span><input value={f.driveLink||""} onChange={e=>s("driveLink",e.target.value)} style={inp} placeholder="Cole o link da pasta…"/></div>
          </div>

          <div><span style={lbl}>Observações</span><textarea value={f.obs||""} onChange={e=>s("obs",e.target.value)} style={{...inp,minHeight:70,resize:"vertical",fontFamily:"inherit"}} placeholder="Anotações internas sobre o processo…"/></div>
        </div>
        <div style={{marginTop:20,display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={()=>{
            const partesLimpas = modoMultiplo ? (f.partes||[]).filter(x=>x.nome.trim()) : [];
            const autorFinal = partesLimpas.length ? nomesPorPolo({partes:partesLimpas},"autor").join(" e ") : f.autor;
            const reuFinal = partesLimpas.length ? nomesPorPolo({partes:partesLimpas},"reu").join(" e ") : f.reu;
            onSave({...f, partes: modoMultiplo ? partesLimpas : [], autor:autorFinal, reu:reuFinal});
          }} style={btnPri}>Salvar</button>
        </div>
      </div>
    </div>
  );
}

