function detectarPrazo(andamento){
  if(!andamento) return null;
  const txt=(andamento.desc||"").toLowerCase();
  for(const r of TABELA_PRAZOS){ if(r.palavras.some(p=>txt.includes(p))) return r; }
  return null;
}
function calcularVencimento(dataInicio,dias){
  if(!dataInicio||!dias) return null;
  const d=new Date(dataInicio+"T00:00:00");
  let c=0;
  while(c<dias){ d.setDate(d.getDate()+1); if(d.getDay()!==0&&d.getDay()!==6) c++; }
  return d.toISOString().slice(0,10);
}

// Índices de correção monetária aproximados (simplificado para fins de estimativa)
// Taxa SELIC acumulada mensal aproximada + correção — uso simplificado mensal composto
function calcularCorrecao(valorBase, dataBase, taxaMensal){
  if(!valorBase||!dataBase) return null;
  const meses = Math.max(0, Math.floor((hoje - new Date(dataBase+"T00:00:00")) / (864e5*30)));
  const fator = Math.pow(1 + (taxaMensal/100), meses);
  return parseFloat((valorBase * fator).toFixed(2));
}

