          </div>
          <div style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:10}}>
            <div><span style={lbl}>Número do processo</span><input value={f.numero||""} onChange={e=>{
              const novoNumero = e.target.value;
              setF(x=>{
                const detectado = x.sistema ? x.sistema : detectarSistemaProcessual(novoNumero);
                return {...x, numero:novoNumero, sistema: x.sistema || detectado};
              });
            }} style={inp}/></div>
            <div><span style={lbl}>Sistema</span>
              <select value={f.sistema||""} onChange={e=>s("sistema",e.target.value)} style={{...inp,padding:"7px 8px"}}>
