// ── Caixa de entrada inteligente (Visão Geral) ─────────────
function buscarProcessoPorTextoLivre(texto, processos){
  const txt = texto.toLowerCase();
  const matchNum = texto.match(/\d{7}-?\d{0,2}\.?\d{0,4}\.?\d\.?\d{2}\.?\d{4}/);
  if(matchNum){
    const num = matchNum[0].replace(/\D/g,"");
    const achado = processos.find(p=>p.numero.replace(/\D/g,"")===num);
    if(achado) return achado;
  }
  // tenta achar por nome de parte mencionado
  let melhor = null, melhorScore = 0;
  processos.forEach(p=>{
    const nomes = [p.autor||"", p.reu||""].join(" ").toLowerCase().split(/\s+/).filter(w=>w.length>3);
    const score = nomes.filter(n=>txt.includes(n)).length;
    if(score>melhorScore){ melhorScore=score; melhor=p; }
  });
  return melhorScore>0 ? melhor : null;
}

function CaixaEntradaIA({processos, clientes, setProcessos, setClientes, onAbrirProcesso}){
  const [texto, setTexto] = useState("");
  const [processando, setProcessando] = useState(false);
  const [erro, setErro] = useState("");
  const [proposta, setProposta] = useState(null); // { acao: "criar"|"atualizar", processoExistente, dados, novosAndamentos }

  const interpretar = async () => {
    if(!texto.trim()){ setErro("Cole ou digite alguma informação antes de processar."); return; }
    setErro(""); setProcessando(true); setProposta(null);

    const candidato = buscarProcessoPorTextoLivre(texto, processos);

    try {
      const contextoExistente = candidato
        ? `\n\nPROCESSO JÁ CADASTRADO QUE PODE SER O MESMO (verifique pelo número/partes):\nNúmero: ${candidato.numero}\nAutor: ${candidato.autor}\nRéu: ${candidato.reu}\nAssunto: ${candidato.assunto||"—"}\nÚltimos andamentos: ${(candidato.andamentos||[]).slice(-3).map(a=>`${a.data}: ${a.desc}`).join(" | ")}`
        : "\n\nNenhum processo correspondente foi encontrado no sistema.";

      let res;
      try {
        res = await fetch(IA_PROXY_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Authorization": "Bearer " + SUPABASE_KEY },
          body: JSON.stringify({
            model: "claude-sonnet-4-6",
            max_tokens: 2000,
            system: `Você organiza dados jurídicos colados por uma advogada brasileira. Retorne SOMENTE um JSON válido, sem texto adicional, sem markdown.

Decida se o texto colado descreve um PROCESSO NOVO (ainda não cadastrado) ou ATUALIZAÇÃO de um processo já existente (use o contexto fornecido abaixo para decidir).

Formato de saída:
{
  "acao": "criar" ou "atualizar",
  "numero": "número do processo se identificável, senão string vazia",
  "autor": "nome do autor/requerente, se identificável",
  "reu": "nome do réu/requerido, se identificável",
  "vara": "vara/órgão, se identificável",
  "assunto": "assunto/classe do processo, se identificável",
  "valorCausa": "valor numérico da causa sem formatação, ou vazio",
  "novosAndamentos": [{"data":"YYYY-MM-DD","desc":"..."}],
  "resumo": "frase curta explicando o que você entendeu e o que vai ser feito"
}

Datas devem estar em YYYY-MM-DD. Se não conseguir identificar uma data exata para um andamento, use a data de hoje (${hoje.toISOString().slice(0,10)}). Nunca invente número de processo, nomes ou valores que não estejam no texto. Se a ação for "atualizar", retorne apenas os campos que mudaram ou os novos andamentos — não repita dados que não mudaram.${contextoExistente}`,
            messages: [{role:"user", content: texto}]
          })
        });
      } catch(networkErr) {
        throw new Error("Não foi possível conectar ao serviço de IA — verifique sua conexão com a internet.");
      }
      if(!res.ok){
        let detalhe = "";
        try { const errBody = await res.json(); detalhe = errBody?.error?.message || ""; } catch(_){}
        throw new Error(`Erro HTTP ${res.status} ao chamar a IA.${detalhe?` Detalhe: ${detalhe}`:""}`);
      }
      const data = await res.json();
      const txt = data.content?.find(b=>b.type==="text")?.text || "";
      if(!txt) throw new Error("A IA retornou uma resposta vazia.");
      let parsed;
      try {
        parsed = JSON.parse(txt.replace(/```json|```/g,"").trim());
      } catch(parseErr) {
        throw new Error(`A resposta da IA não veio em formato JSON válido. Início da resposta: "${txt.slice(0,150)}"`);
      }

      setProposta({
        ...parsed,
        processoExistente: parsed.acao === "atualizar" ? candidato : null,
      });
    } catch(e) {
      setErro(e.message || "Não foi possível interpretar o texto. Tente novamente ou revise o conteúdo colado.");
    }
    setProcessando(false);
  };

  const confirmar = () => {
    if(!proposta) return;

    if(proposta.acao === "atualizar" && proposta.processoExistente){
      const id = proposta.processoExistente.id;
      setProcessos(ps=>ps.map(p=>{
        if(p.id!==id) return p;
        const atualizado = {...p};
        if(proposta.assunto) atualizado.assunto = proposta.assunto;
        if(proposta.valorCausa) atualizado.valorCausa = proposta.valorCausa;
        if(proposta.novosAndamentos?.length){
          atualizado.andamentos = [...(p.andamentos||[]), ...proposta.novosAndamentos.map(a=>({...a, fonte:"manual"}))]
            .sort((a,b)=>(a.data||"").localeCompare(b.data||""));
        }
        return atualizado;
      }));
      setTexto(""); 
      const idParaAbrir = id;
      setProposta(null);
      onAbrirProcesso({id: idParaAbrir});
    } else {
      const novoId = Date.now();
      setProcessos(ps=>[...ps, {
        id: novoId, clienteId: "", numero: proposta.numero||"", tipo:"judicial", classificacao:"",
        autor: proposta.autor||"", reu: proposta.reu||"", vara: proposta.vara||"",
        responsavel:"", status:"em_andamento", prazo:"", debito:null,
        assunto: proposta.assunto||"", valorCausa: proposta.valorCausa||"",
        andamentos: (proposta.novosAndamentos||[]).map(a=>({...a, fonte:"manual"})),
        documentos:[], checklist:{}, obs:"Criado via Caixa de Entrada Inteligente.",
      }]);
      setTexto("");
      setProposta(null);
      onAbrirProcesso({id: novoId});
    }
  };

  return (
    <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,padding:"16px 18px",marginBottom:16}}>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
        <span style={{fontSize:16}}>✨</span>
        <p style={{fontSize:13,fontWeight:700,color:"var(--text1)",margin:0}}>Caixa de entrada inteligente</p>
      </div>
      <p style={{fontSize:11.5,color:"var(--text2)",margin:"0 0 10px",lineHeight:1.5}}>
        Cole uma intimação, relatório de andamento ou dados de um caso novo. A IA identifica se deve criar um processo ou atualizar um já existente.
      </p>
      <textarea
        value={texto}
        onChange={e=>setTexto(e.target.value)}
        placeholder="Cole aqui o texto…"
        style={{width:"100%",minHeight:90,fontSize:12.5,padding:"10px 12px",borderRadius:7,border:"1px solid var(--border2)",resize:"vertical",boxSizing:"border-box",fontFamily:"inherit"}}
      />
      {erro && <div style={{marginTop:8,padding:"10px 12px",background:"var(--red-bg)",border:"1px solid #FCA5A5",borderRadius:6,fontSize:12,color:"var(--red)",lineHeight:1.5}}><strong>Erro:</strong> {erro}</div>}
      <div style={{display:"flex",justifyContent:"flex-end",marginTop:10}}>
        <button onClick={interpretar} disabled={processando} style={{...btnPri,opacity:processando?.7:1,fontSize:12.5,padding:"8px 18px"}}>
          {processando?"Analisando…":"✨ Interpretar com IA"}
        </button>
      </div>

      {proposta && (
        <div style={{marginTop:14,paddingTop:14,borderTop:"1px solid var(--border1)"}}>
          <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
            <Pill bg={proposta.acao==="criar"?"var(--green-bg)":"var(--accent-light)"} color={proposta.acao==="criar"?"var(--green)":"var(--accent)"} label={proposta.acao==="criar"?"Novo processo":"Atualizar processo existente"} sm/>
          </div>
          <p style={{fontSize:12.5,color:"var(--text1)",margin:"0 0 12px",lineHeight:1.5}}>{proposta.resumo}</p>

          {proposta.acao==="atualizar" && proposta.processoExistente && (
            <div style={{background:"var(--bg2)",borderRadius:6,padding:"10px 12px",marginBottom:10,fontSize:11.5}}>
              <p style={{margin:"0 0 3px",fontFamily:"monospace",color:"var(--text2)"}}>{proposta.processoExistente.numero}</p>
              <p style={{margin:0,fontWeight:600}}>{proposta.processoExistente.autor} vs. {proposta.processoExistente.reu}</p>
            </div>
          )}

          {proposta.acao==="criar" && (
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"8px 16px",marginBottom:10,fontSize:12}}>
              {proposta.numero&&<div><span style={{color:"var(--text2)"}}>Número: </span><span style={{fontFamily:"monospace"}}>{proposta.numero}</span></div>}
