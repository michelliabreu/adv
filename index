  const [editando, setEditando] = useState(null);
  const [novo, setNovo] = useState(false);
  const [modoView, setModoView] = useState("mes"); // "mes" | "lista"
  const [mesRef, setMesRef] = useState(()=>{ const d=new Date(hoje); d.setDate(1); return d; });
  const [diaSelecionado, setDiaSelecionado] = useState(()=>hoje.toISOString().slice(0,10));

  const salvar = form => {
    setAgenda(a => form.id ? a.map(x=>x.id===form.id?form:x) : [...a, {...form, id:Date.now()}]);
    setEditando(null); setNovo(false);
  };
  const nomeResp = id => equipe.find(m=>m.id===id)?.nome;
  const nomeCliente = id => clientes.find(c=>c.id===id)?.nome;
  const numProc = id => processos.find(p=>p.id===id)?.numero;
  const hojeStr = hoje.toISOString().slice(0,10);

  const compromissosPorDia = useMemo(()=>{
    const mapa = {};
    agenda.forEach(c=>{
      if(!c.dataHora) return;
      const dia = c.dataHora.slice(0,10);
      if(!mapa[dia]) mapa[dia] = [];
      mapa[dia].push(c);
    });
    Object.values(mapa).forEach(lista=>lista.sort((a,b)=>a.dataHora.localeCompare(b.dataHora)));
    return mapa;
  },[agenda]);

  // ── Grade do mês (planner) ──────────────────────────────
  const DIAS_SEMANA = ["Dom","Seg","Ter","Qua","Qui","Sex","Sáb"];
  const anoRef = mesRef.getFullYear(), mesIdx = mesRef.getMonth();
  const primeiroDia = new Date(anoRef, mesIdx, 1);
  const ultimoDia = new Date(anoRef, mesIdx+1, 0);
  const offsetInicio = primeiroDia.getDay(); // 0=domingo
  const totalDiasMes = ultimoDia.getDate();
  const celulas = [];
  for(let i=0;i<offsetInicio;i++) celulas.push(null);
  for(let d=1; d<=totalDiasMes; d++) celulas.push(d);
  while(celulas.length % 7 !== 0) celulas.push(null);

  const fmtDiaKey = (d) => `${anoRef}-${String(mesIdx+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
  const mudarMes = (delta) => setMesRef(m=>{ const d=new Date(m); d.setMonth(d.getMonth()+delta); return d; });

  const compromissosDoDiaSelecionado = (compromissosPorDia[diaSelecionado]||[]).slice();

  const Item = ({c}) => {
    const cfg = TIPO_AGENDA_CFG[c.tipo] || TIPO_AGENDA_CFG.outro;
    const d = c.dataHora ? Math.ceil((new Date(c.dataHora) - new Date()) / 864e5) : null;
    const urgente = d !== null && d <= 1 && d >= 0;
    return (
      <div onClick={()=>setEditando(c)} style={{background:"#fff",border:"1px solid var(--border1)",borderLeft:`3px solid ${cfg.color}`,borderRadius:8,padding:"12px 14px",cursor:"pointer",display:"flex",justifyContent:"space-between",alignItems:"center",gap:12,marginBottom:8}}>
        <div style={{flex:1,minWidth:0}}>
          <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:4,flexWrap:"wrap"}}>
            <Pill bg={cfg.bg} color={cfg.color} label={cfg.label} sm/>
            {c.confirmado ? <span style={{fontSize:10,color:"var(--green)"}}>✓ Confirmado</span> : <span style={{fontSize:10,color:"var(--amber)"}}>⏳ A confirmar</span>}
          </div>
          <p style={{fontSize:13,fontWeight:600,margin:"0 0 3px"}}>{c.titulo}</p>
          <div style={{display:"flex",gap:10,flexWrap:"wrap"}}>
            {c.clienteId && <span style={{fontSize:11,color:"var(--accent)"}}>👤 {nomeCliente(c.clienteId)}</span>}
            {c.procId && <span style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)"}}>{numProc(c.procId)?.slice(0,18)}…</span>}
            {c.responsavelId && <span style={{fontSize:11,color:"var(--text2)"}}>👷 {nomeResp(c.responsavelId)}</span>}
            {c.local && <span style={{fontSize:11,color:"var(--text2)"}}>📍 {c.local}</span>}
          </div>
        </div>
        <div style={{textAlign:"right",flexShrink:0}}>
          <p style={{fontSize:13,fontWeight:700,color:urgente?"var(--red)":"var(--navy2)",margin:"0 0 2px"}}>{fmtDataHoraCurta(c.dataHora)}</p>
          {d !== null && d >= 0 && <p style={{fontSize:10,color:urgente?"var(--red)":"var(--text2)",margin:0}}>{d===0?"Hoje":d===1?"Amanhã":`em ${d} dias`}</p>}
        </div>
      </div>
    );
  };

  // ── Visão Lista (mantida como opção secundária) ─────────
  const ordenada = [...agenda].sort((a,b)=>new Date(a.dataHora)-new Date(b.dataHora));
  const proximos = ordenada.filter(c => c.dataHora && c.dataHora.slice(0,10) >= hojeStr);
  const passados = ordenada.filter(c => c.dataHora && c.dataHora.slice(0,10) < hojeStr);

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16,flexWrap:"wrap",gap:10}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Agenda</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Audiências, reuniões e prazos</p>
        </div>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          <div style={{display:"flex",gap:0,background:"var(--bg2)",borderRadius:7,padding:3}}>
            {[["mes","📅 Mês"],["lista","☰ Lista"]].map(([k,l])=>(
              <button key={k} onClick={()=>setModoView(k)} style={{padding:"7px 14px",fontSize:11.5,fontWeight:600,border:"none",borderRadius:5,cursor:"pointer",background:modoView===k?"#fff":"transparent",color:modoView===k?"var(--accent)":"var(--text2)",boxShadow:modoView===k?"0 1px 2px rgba(15,17,23,.08)":"none"}}>{l}</button>
            ))}
          </div>
          <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Novo compromisso</button>
        </div>
      </div>

      {modoView === "mes" ? (
        <div style={{display:"grid",gridTemplateColumns:"1fr 320px",gap:16,alignItems:"start"}}>
          {/* Grade do planner */}
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,overflow:"hidden"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"14px 18px",borderBottom:"1px solid var(--border1)"}}>
              <button onClick={()=>mudarMes(-1)} style={{background:"none",border:"1px solid var(--border2)",borderRadius:6,width:30,height:30,cursor:"pointer",fontSize:14,color:"var(--text2)"}}>←</button>
              <span style={{fontSize:15,fontWeight:700,color:"var(--text1)",textTransform:"capitalize",letterSpacing:"-.01em"}}>{mesRef.toLocaleDateString("pt-BR",{month:"long",year:"numeric"})}</span>
              <div style={{display:"flex",gap:6}}>
                <button onClick={()=>{ const d=new Date(); d.setDate(1); setMesRef(d); setDiaSelecionado(hojeStr); }} style={{fontSize:10.5,padding:"5px 11px",cursor:"pointer",borderRadius:6,border:"1px solid var(--border2)",background:"#fff",color:"var(--accent)",fontWeight:600}}>Hoje</button>
                <button onClick={()=>mudarMes(1)} style={{background:"none",border:"1px solid var(--border2)",borderRadius:6,width:30,height:30,cursor:"pointer",fontSize:14,color:"var(--text2)"}}>→</button>
              </div>
            </div>

            <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",borderBottom:"1px solid var(--border1)"}}>
              {DIAS_SEMANA.map(d=><div key={d} style={{padding:"9px 0",textAlign:"center",fontSize:10,fontWeight:700,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".5px"}}>{d}</div>)}
            </div>

            <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)"}}>
              {celulas.map((d,i)=>{
                if(d===null) return <div key={i} style={{minHeight:92,borderRight:(i+1)%7!==0?"1px solid var(--border1)":"none",borderBottom:"1px solid var(--border1)",background:"var(--bg2)"}}/>;
                const diaKey = fmtDiaKey(d);
                const compromissosDia = compromissosPorDia[diaKey] || [];
                const isHoje = diaKey === hojeStr;
                const isSelecionado = diaKey === diaSelecionado;
                return (
                  <div
                    key={i}
                    onClick={()=>setDiaSelecionado(diaKey)}
                    style={{
                      minHeight:92, padding:"6px 7px", cursor:"pointer",
                      borderRight:(i+1)%7!==0?"1px solid var(--border1)":"none",
                      borderBottom:"1px solid var(--border1)",
                      background: isSelecionado?"var(--accent-light)":"#fff",
                      transition:"background .1s",
                    }}
                  >
                    <span style={{
                      display:"inline-flex",alignItems:"center",justifyContent:"center",
                      width:22,height:22,borderRadius:"50%",fontSize:11.5,fontWeight:isHoje?700:500,
                      background:isHoje?"var(--accent)":"transparent",
                      color:isHoje?"#fff":"var(--text1)",
                    }}>{d}</span>
                    <div style={{marginTop:4,display:"flex",flexDirection:"column",gap:2}}>
                      {compromissosDia.slice(0,2).map(c=>{
                        const cfg = TIPO_AGENDA_CFG[c.tipo]||TIPO_AGENDA_CFG.outro;
                        return (
                          <div key={c.id} style={{fontSize:9,padding:"1px 5px",borderRadius:3,background:cfg.bg,color:cfg.color,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",fontWeight:600}}>
                            {c.dataHora.slice(11,16)} {c.titulo}
                          </div>
                        );
                      })}
                      {compromissosDia.length>2&&<span style={{fontSize:9,color:"var(--text3)",paddingLeft:5}}>+{compromissosDia.length-2} mais</span>}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          {/* Painel lateral do dia selecionado */}
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,padding:"16px",position:"sticky",top:16}}>
            <p style={{fontSize:12,fontWeight:700,color:"var(--text1)",margin:"0 0 2px",textTransform:"capitalize"}}>
              {new Date(diaSelecionado+"T00:00:00").toLocaleDateString("pt-BR",{weekday:"long",day:"numeric",month:"long"})}
            </p>
            <p style={{fontSize:11,color:"var(--text2)",margin:"0 0 14px"}}>{compromissosDoDiaSelecionado.length} compromisso(s)</p>
            {compromissosDoDiaSelecionado.length===0 ? (
              <p style={{fontSize:12,color:"var(--text3)"}}>Nenhum compromisso neste dia.</p>
            ) : (
              <div style={{display:"flex",flexDirection:"column",gap:8}}>
                {compromissosDoDiaSelecionado.map(c=>{
                  const cfg = TIPO_AGENDA_CFG[c.tipo]||TIPO_AGENDA_CFG.outro;
                  return (
                    <div key={c.id} onClick={()=>setEditando(c)} style={{border:"1px solid var(--border1)",borderLeft:`3px solid ${cfg.color}`,borderRadius:7,padding:"9px 11px",cursor:"pointer"}}>
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:4}}>
                        <Pill bg={cfg.bg} color={cfg.color} label={cfg.label} sm/>
                        <span style={{fontSize:11,fontWeight:700,color:"var(--text1)"}}>{c.dataHora.slice(11,16)}</span>
                      </div>
                      <p style={{fontSize:12.5,fontWeight:600,margin:"0 0 3px"}}>{c.titulo}</p>
                      {c.clienteId && <p style={{fontSize:10.5,color:"var(--accent)",margin:"0 0 2px"}}>👤 {nomeCliente(c.clienteId)}</p>}
                      {c.local && <p style={{fontSize:10.5,color:"var(--text2)",margin:0}}>📍 {c.local}</p>}
                    </div>
                  );
                })}
              </div>
            )}
            <button onClick={()=>setNovo(true)} style={{...btnSec,width:"100%",fontSize:11.5,marginTop:14}}>+ Adicionar neste dia</button>
          </div>
        </div>
      ) : (
        <div>
          <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"0 0 10px"}}>Próximos ({proximos.length})</p>
          {proximos.length===0 ? <p style={{fontSize:12,color:"var(--text2)",marginBottom:20}}>Nenhum compromisso futuro.</p> : proximos.map(c=><Item key={c.id} c={c}/>)}

          {passados.length>0 && <>
            <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"20px 0 10px"}}>Anteriores ({passados.length})</p>
            {passados.slice().reverse().map(c=><Item key={c.id} c={c}/>)}
          </>}
        </div>
      )}

      {(editando||novo) && <ModalFormCompromisso compromisso={editando||(novo?{titulo:"",tipo:"reuniao_cliente",dataHora:`${diaSelecionado}T09:00`,procId:"",clienteId:"",responsavelId:"",local:"",confirmado:false,obs:""}:null)} equipe={equipe} processos={processos} clientes={clientes} onSave={salvar} onClose={()=>{setEditando(null);setNovo(false);}}/>}
    </div>
  );
}

// ── Modal Form Membro Equipe ───────────────────────────────
function ModalFormMembro({membro, onSave, onClose}){
  const e0={nome:"",cargo:"Advogada(o)",email:"",telefone:"",status:"ativo",dataEntrada:"",obs:""};
  const [f,setF]=useState(membro||e0);
  const s=(k,v)=>setF(x=>({...x,[k]:v}));
  return (
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.45)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:460,maxWidth:"100%",borderRadius:10,padding:"1.75rem",boxShadow:"0 25px 60px rgba(0,0,0,.3)"}}>
        <p style={{fontSize:15,fontWeight:700,margin:"0 0 18px",color:"var(--navy)"}}>{membro?"Editar membro":"Novo membro da equipe"}</p>
        <div style={{display:"flex",flexDirection:"column",gap:12}}>
          <div><span style={lbl}>Nome</span><input value={f.nome} onChange={e=>s("nome",e.target.value)} style={inp}/></div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Cargo/Função</span>
              <select value={f.cargo} onChange={e=>s("cargo",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                {Object.keys(CARGO_CFG).map(c=><option key={c} value={c}>{c}</option>)}
              </select>
            </div>
            <div><span style={lbl}>Status</span>
              <select value={f.status} onChange={e=>s("status",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                <option value="ativo">Ativo</option><option value="inativo">Inativo</option><option value="ferias">Férias/Licença</option>
              </select>
            </div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>E-mail</span><input type="email" value={f.email} onChange={e=>s("email",e.target.value)} style={inp}/></div>
            <div><span style={lbl}>Telefone</span><input value={f.telefone} onChange={e=>s("telefone",fmtTelefone(e.target.value))} style={inp}/></div>
          </div>
          <div><span style={lbl}>Data de entrada</span><input type="date" value={f.dataEntrada} onChange={e=>s("dataEntrada",e.target.value)} style={inp}/></div>
          <div><span style={lbl}>Observações</span><textarea value={f.obs} onChange={e=>s("obs",e.target.value)} style={{...inp,minHeight:60,resize:"vertical"}}/></div>
        </div>
        <div style={{marginTop:20,display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={()=>{if(!f.nome.trim()){alert("Informe o nome.");return;}onSave(f);}} style={btnPri}>Salvar</button>
        </div>
      </div>
    </div>
  );
}

// ── Página Equipe ──────────────────────────────────────────
function PaginaEquipe({equipe, setEquipe, tarefas, agenda}){
  const [editando, setEditando] = useState(null);
  const [novo, setNovo] = useState(false);
  const [selecionado, setSelecionado] = useState(null);

  const salvar = form => {
    setEquipe(eq => form.id ? eq.map(m=>m.id===form.id?form:m) : [...eq, {...form, id:Date.now()}]);
    setEditando(null); setNovo(false);
  };

  const tarefasDe = id => tarefas.filter(t=>t.responsavelId===id);
  const compromissosDe = id => agenda.filter(c=>c.responsavelId===id);

  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};

  return (
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Equipe</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>{equipe.length} colaborador(es)</p>
        </div>
        <button onClick={()=>setNovo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Novo membro</button>
      </div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:14}}>
        {equipe.map(m=>{
          const cCfg = CARGO_CFG[m.cargo] || CARGO_CFG.Outro;
          const sCfg = STATUS_EQUIPE_CFG[m.status];
          const nTarefas = tarefasDe(m.id).filter(t=>t.status!=="concluido").length;
          return (
            <div key={m.id} onClick={()=>setSelecionado(m)} style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:10,padding:"18px",cursor:"pointer",textAlign:"center"}}>
              <div style={{width:56,height:56,borderRadius:"50%",background:"var(--navy)",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,fontWeight:700,margin:"0 auto 12px"}}>{m.nome.charAt(0).toUpperCase()}</div>
              <p style={{fontSize:14,fontWeight:700,margin:"0 0 6px"}}>{m.nome}</p>
              <div style={{marginBottom:8}}><Pill bg={cCfg.bg} color={cCfg.color} label={m.cargo} sm/></div>
              <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:5,marginBottom:10}}>
                <span style={{width:6,height:6,borderRadius:"50%",background:sCfg.dot}}/>
                <span style={{fontSize:10,color:"var(--text2)"}}>{sCfg.label}</span>
              </div>
              <p style={{fontSize:11,color:"var(--text2)",margin:0}}>{nTarefas} tarefa(s) ativa(s)</p>
            </div>
          );
        })}
      </div>

      {(editando||novo) && <ModalFormMembro membro={editando} onSave={salvar} onClose={()=>{setEditando(null);setNovo(false);}}/>}

      {selecionado && (
        <div onClick={e=>e.target===e.currentTarget&&setSelecionado(null)} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.45)",zIndex:300,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
          <div style={{background:"#fff",width:560,maxWidth:"100%",maxHeight:"90vh",overflow:"auto",borderRadius:10,padding:"1.75rem",boxShadow:"0 25px 60px rgba(0,0,0,.3)"}}>
            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:18}}>
              <div style={{display:"flex",alignItems:"center",gap:12}}>
                <div style={{width:48,height:48,borderRadius:"50%",background:"var(--navy)",color:"#fff",display:"flex",alignItems:"center",justifyContent:"center",fontSize:18,fontWeight:700}}>{selecionado.nome.charAt(0).toUpperCase()}</div>
                <div>
                  <p style={{fontSize:16,fontWeight:700,margin:"0 0 2px",color:"var(--navy)"}}>{selecionado.nome}</p>
                  <p style={{fontSize:11.5,color:"var(--text2)",margin:0}}>{selecionado.cargo}</p>
                </div>
              </div>
              <button onClick={()=>setSelecionado(null)} style={{background:"none",border:"none",cursor:"pointer",fontSize:22,color:"var(--text2)",padding:0,lineHeight:1}}>×</button>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"10px 20px",marginBottom:16}}>
              {[["E-mail",selecionado.email||"—"],["Telefone",selecionado.telefone||"—"],["Data de entrada",fmtData(selecionado.dataEntrada)],["Status",STATUS_EQUIPE_CFG[selecionado.status]?.label]].map(([k,v])=>(
                <div key={k}><p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",margin:"0 0 3px",fontWeight:600}}>{k}</p><p style={{fontSize:13,margin:0}}>{v}</p></div>
              ))}
            </div>
            {selecionado.obs && <div style={{background:"var(--bg2)",borderRadius:6,padding:"10px 12px",fontSize:12,color:"var(--text2)",marginBottom:16}}>{selecionado.obs}</div>}
            <div style={{borderTop:"1px solid var(--border1)",paddingTop:14,marginBottom:14}}>
              <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"0 0 10px"}}>Tarefas atribuídas ({tarefasDe(selecionado.id).length})</p>
              <div style={{display:"flex",flexDirection:"column",gap:6}}>
                {tarefasDe(selecionado.id).map(t=>{
                  const cfg = STATUS_TAREFA_CFG[t.status];
                  return <div key={t.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",fontSize:12,padding:"6px 0",borderBottom:"1px solid var(--border1)"}}><span>{t.titulo}</span><Pill bg={cfg.bg} color={cfg.color} label={cfg.label} sm/></div>;
                })}
                {tarefasDe(selecionado.id).length===0 && <p style={{fontSize:12,color:"var(--text2)"}}>Nenhuma tarefa atribuída.</p>}
              </div>
            </div>
            <div>
              <p style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",color:"var(--text2)",margin:"0 0 10px"}}>Próximos compromissos ({compromissosDe(selecionado.id).length})</p>
              <div style={{display:"flex",flexDirection:"column",gap:6}}>
                {compromissosDe(selecionado.id).map(c=>(
                  <div key={c.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",fontSize:12,padding:"6px 0",borderBottom:"1px solid var(--border1)"}}><span>{c.titulo}</span><span style={{color:"var(--text2)",fontSize:11}}>{fmtDataHoraCurta(c.dataHora)}</span></div>
                ))}
                {compromissosDe(selecionado.id).length===0 && <p style={{fontSize:12,color:"var(--text2)"}}>Nenhum compromisso.</p>}
              </div>
            </div>
            <div style={{marginTop:20,display:"flex",gap:8,justifyContent:"flex-end"}}>
              <button onClick={()=>{setEditando(selecionado);setSelecionado(null);}} style={btnSec}>Editar</button>
              <button onClick={()=>setSelecionado(null)} style={btnPri}>Fechar</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
// ── Helpers de identificação de processo por texto ────────
function buscarProcessoPorTexto(texto, processos, clientes){
  const txt = texto.toLowerCase();
  // 1. Tenta achar número de processo explícito (padrão CNJ ou parcial)
  const matchNum = texto.match(/\d{7}-?\d{0,2}\.?\d{0,4}\.?\d\.?\d{2}\.?\d{4}/);
  if(matchNum){
    const num = matchNum[0].replace(/\D/g,"");
    const achadoPorNum = processos.find(p=>p.numero.replace(/\D/g,"").includes(num) || num.includes(p.numero.replace(/\D/g,"").slice(0,7)));
    if(achadoPorNum) return [achadoPorNum];
  }
  // 2. Tenta achar pelo nome do cliente/autor mencionado no texto
  const candidatos = [];
  clientes.forEach(c=>{
    const partesNome = c.nome.toLowerCase().split(/\s+/).filter(w=>w.length>3);
    const bateu = partesNome.some(parte=>txt.includes(parte));
    if(bateu){
      const procsDoCliente = processos.filter(p=>p.clienteId===c.id);
      procsDoCliente.forEach(p=>candidatos.push(p));
    }
  });
  // 3. Tenta achar pelo nome do réu
  processos.forEach(p=>{
    const partesReu = (p.reu||"").toLowerCase().split(/\s+/).filter(w=>w.length>3);
    if(partesReu.some(parte=>txt.includes(parte)) && !candidatos.includes(p)){
      candidatos.push(p);
    }
  });
  return candidatos;
}

function montarContextoProcesso(p, cliente){
  const andOrd = [...(p.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data));
  let ctx = `DADOS DO PROCESSO:\n`;
  ctx += `Número: ${p.numero}\n`;
  ctx += `Autor/Requerente: ${p.autor}\n`;
  ctx += `Réu/Requerido: ${p.reu}\n`;
  ctx += `Vara: ${p.vara}\n`;
  ctx += `Status: ${SC[normalizarStatus(p.status)]?.label || p.status}\n`;
  ctx += `Classificação: ${CC[p.classificacao]?.label || p.classificacao || "—"}\n`;
  if(cliente){
    ctx += `\nDADOS DO CLIENTE:\n`;
    ctx += `Nome: ${cliente.nome}\n`;
    if(cliente.cpf) ctx += `CPF/CNPJ: ${cliente.cpf}\n`;
    if(cliente.email) ctx += `E-mail: ${cliente.email}\n`;
    if(cliente.endereco) ctx += `Endereço: ${cliente.endereco}\n`;
  }
  if(p.debito?.valor){
    ctx += `\nDÉBITO ATUALIZADO: ${fmtBRL(p.debito.valor)}\n`;
  }
  if(p.prazoProcessual?.ativo){
    ctx += `\nPRAZO PROCESSUAL ATIVO: ${p.prazoProcessual.proximoAto} — parte responsável: ${p.prazoProcessual.parte} — vencimento ${fmtData(p.prazoProcessual.vencimento)} — base legal: ${p.prazoProcessual.base}\n`;
  }
  if(andOrd.length){
    ctx += `\nANDAMENTOS RECENTES (mais recente primeiro):\n`;
    andOrd.slice(0,8).forEach(a=>{ ctx += `- ${fmtData(a.data)}: ${a.desc}\n`; });
  }
  if(p.obs){
    ctx += `\nOBSERVAÇÕES INTERNAS: ${p.obs}\n`;
  }
  return ctx;
}

// ── Botão flutuante + painel de IA ─────────────────────────
function AssistenteIA({processos, clientes}){
  const [aberto, setAberto] = useState(false);
  const [etapa, setEtapa] = useState("input"); // input | confirmar | gerando | resultado
  const [pedido, setPedido] = useState("");
  const [candidatos, setCandidatos] = useState([]);
  const [processoSelecionado, setProcessoSelecionado] = useState(null);
  const [resultado, setResultado] = useState("");
  const [erro, setErro] = useState("");
  const [gerandoDocx, setGerandoDocx] = useState(false);

  const resetar = () => {
    setEtapa("input"); setPedido(""); setCandidatos([]); setProcessoSelecionado(null); setResultado(""); setErro("");
  };

  const fechar = () => { setAberto(false); resetar(); };

  const analisarPedido = () => {
    if(!pedido.trim()){ setErro("Descreva o que você precisa."); return; }
    setErro("");
    const achados = buscarProcessoPorTexto(pedido, processos, clientes);
    if(achados.length === 0){
      setCandidatos([]);
      setEtapa("confirmar");
    } else if(achados.length === 1){
      setProcessoSelecionado(achados[0]);
      setEtapa("confirmar");
    } else {
      setCandidatos(achados.slice(0,5));
      setEtapa("confirmar");
    }
  };

  const gerar = async () => {
    setEtapa("gerando");
    setErro("");
    try {
      const cliente = processoSelecionado ? clientes.find(c=>c.id===processoSelecionado.clienteId) : null;
      const contexto = processoSelecionado ? montarContextoProcesso(processoSelecionado, cliente) : "Nenhum processo específico vinculado a este pedido.";

      const systemPrompt = `Você é um assistente jurídico especializado em redigir peças processuais para uma advogada brasileira (OAB/RJ 155.134). Use linguagem técnica jurídica adequada, formatação de petição padrão (endereçamento, qualificação das partes quando disponível, fundamentação, pedidos), e cite dispositivos legais pertinentes (CPC, legislação especial) quando aplicável. Use os dados reais fornecidos abaixo — não invente números de processo, nomes ou valores que não constem no contexto. Quando um dado não estiver disponível, use um placeholder claro entre colchetes, como [DADO NÃO INFORMADO].

${contexto}`;

      const res = await fetch(IA_PROXY_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json", "Authorization": "Bearer " + SUPABASE_KEY },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 3000,
          system: systemPrompt,
          messages: [{ role: "user", content: pedido }]
        })
      });
      const data = await res.json();
      const texto = data.content?.find(b=>b.type==="text")?.text || "";
      if(!texto) throw new Error("Resposta vazia da IA");
      setResultado(texto);
      setEtapa("resultado");
    } catch(e){
      setErro("Não foi possível gerar o conteúdo agora. Tente novamente.");
      setEtapa("confirmar");
    }
  };

  const copiarTexto = () => {
    navigator.clipboard?.writeText(resultado);
  };

  const baixarDocx = async () => {
    setGerandoDocx(true);
    try {
      // Gera um .docx simples client-side via Blob com formatação RTF básica convertida,
      // já que não há acesso a backend de geração docx neste contexto standalone.
      // Aqui usamos uma abordagem HTML->Word compatível (Word abre arquivos .doc com HTML).
      const linhas = resultado.split("\n").map(l => l.trim()===""? "<p>&nbsp;</p>" : `<p style="margin:0 0 8pt 0;text-align:justify;">${l.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")}</p>`).join("");
      const htmlDoc = `<html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head><meta charset="utf-8"><title>Petição</title>
<style>body{font-family:Arial,sans-serif;font-size:12pt;}</style>
</head><body>${linhas}</body></html>`;
      const blob = new Blob(['\ufeff', htmlDoc], { type: 'application/msword' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `peticao_${processoSelecionado?processoSelecionado.numero.replace(/\D/g,"").slice(0,10):"documento"}.doc`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } finally {
      setGerandoDocx(false);
    }
  };

  return (
    <>
      {/* Botão flutuante */}
      {!aberto && (
        <button onClick={()=>setAberto(true)} style={{
          position:"fixed", bottom:24, right:24, zIndex:900,
          width:58, height:58, borderRadius:"50%",
          background:"linear-gradient(135deg, var(--navy2), var(--accent))",
          border:"none", cursor:"pointer", boxShadow:"0 6px 20px rgba(15,38,69,.35)",
          display:"flex", alignItems:"center", justifyContent:"center",
          fontSize:24, color:"#fff",
        }} title="Assistente de IA — gerar petições">
          ✨
        </button>
      )}

      {/* Painel */}
      {aberto && (
        <div style={{position:"fixed", inset:0, background:"rgba(15,38,69,.35)", zIndex:950, display:"flex", alignItems:"flex-end", justifyContent:"flex-end", padding:24}}>
          <div onClick={e=>e.stopPropagation()} style={{
            background:"#fff", width:440, maxWidth:"100%", maxHeight:"calc(100vh - 48px)",
            borderRadius:14, boxShadow:"0 25px 60px rgba(0,0,0,.3)",
            display:"flex", flexDirection:"column", overflow:"hidden",
          }}>
            {/* Header */}
            <div style={{background:"linear-gradient(135deg, var(--navy), var(--navy2))", padding:"16px 18px", display:"flex", alignItems:"center", justifyContent:"space-between"}}>
              <div style={{display:"flex", alignItems:"center", gap:10}}>
                <span style={{fontSize:18}}>✨</span>
                <div>
                  <p style={{fontSize:13, fontWeight:700, color:"#fff", margin:0}}>Assistente Jurídico</p>
                  <p style={{fontSize:10, color:"rgba(255,255,255,.6)", margin:0}}>Gere petições com dados do processo</p>
                </div>
              </div>
              <button onClick={fechar} style={{background:"none", border:"none", color:"rgba(255,255,255,.8)", fontSize:20, cursor:"pointer", lineHeight:1, padding:0}}>×</button>
            </div>

            {/* Corpo */}
            <div style={{flex:1, overflow:"auto", padding:18}}>
              {etapa === "input" && (
                <div>
                  <p style={{fontSize:12, color:"var(--text2)", marginBottom:10, lineHeight:1.5}}>
                    Descreva o que você precisa. Mencione o processo, número, ou nome do cliente para que eu já vincule os dados automaticamente.
                  </p>
                  <textarea
                    value={pedido}
                    onChange={e=>setPedido(e.target.value)}
                    placeholder="Ex: Fazer uma réplica para o processo da Beatriz Almeida contra o Banco Exemplar, rebatendo a tese de prescrição."
                    style={{width:"100%", minHeight:120, fontSize:13, padding:"10px 12px", borderRadius:8, border:"1px solid var(--border2)", resize:"vertical", boxSizing:"border-box", fontFamily:"inherit"}}
                    autoFocus
                  />
                  {erro && <p style={{fontSize:12, color:"var(--red)", marginTop:8}}>{erro}</p>}
                  <button onClick={analisarPedido} style={{...btnPri, width:"100%", marginTop:12, padding:"10px"}}>Continuar →</button>
                </div>
              )}

              {etapa === "confirmar" && (
                <div>
                  {processoSelecionado && candidatos.length === 0 && (
                    <div>
                      <p style={{fontSize:12, color:"var(--text2)", marginBottom:10}}>Encontrei este processo vinculado ao seu pedido:</p>
                      <div style={{background:"var(--accent-light)", border:"1px solid #C5DCF2", borderRadius:8, padding:"12px 14px", marginBottom:14}}>
                        <p style={{fontSize:11, fontFamily:"monospace", color:"var(--text2)", margin:"0 0 4px"}}>{processoSelecionado.numero}</p>
                        <p style={{fontSize:13, fontWeight:600, margin:"0 0 2px"}}>{processoSelecionado.autor}</p>
                        <p style={{fontSize:12, color:"var(--text2)", margin:0}}>vs. {processoSelecionado.reu}</p>
                      </div>
                      <div style={{display:"flex", gap:8}}>
                        <button onClick={()=>{setProcessoSelecionado(null);setCandidatos(processos.slice(0,0));setEtapa("input");setPedido(pedido);}} style={{...btnSec, flex:1, fontSize:11.5}}>Não é esse</button>
                        <button onClick={gerar} style={{...btnPri, flex:1, fontSize:11.5}}>Confirmar e gerar</button>
                      </div>
                    </div>
                  )}

                  {candidatos.length > 1 && (
                    <div>
                      <p style={{fontSize:12, color:"var(--text2)", marginBottom:10}}>Encontrei mais de um processo. Qual deles?</p>
                      <div style={{display:"flex", flexDirection:"column", gap:8, marginBottom:14}}>
                        {candidatos.map(p=>(
                          <div key={p.id} onClick={()=>{setProcessoSelecionado(p);setCandidatos([]);}} style={{border:"1px solid var(--border1)", borderRadius:8, padding:"10px 12px", cursor:"pointer"}}>
                            <p style={{fontSize:10.5, fontFamily:"monospace", color:"var(--text2)", margin:"0 0 3px"}}>{p.numero}</p>
                            <p style={{fontSize:12.5, fontWeight:600, margin:"0 0 2px"}}>{p.autor}</p>
                            <p style={{fontSize:11.5, color:"var(--text2)", margin:0}}>vs. {p.reu}</p>
                          </div>
                        ))}
                      </div>
                      <button onClick={()=>{setCandidatos([]);setEtapa("input");}} style={{...btnSec, width:"100%", fontSize:11.5}}>Nenhum desses — refazer pedido</button>
                    </div>
                  )}

                  {!processoSelecionado && candidatos.length === 0 && (
                    <div>
                      <div style={{background:"var(--amber-bg)", border:"1px solid #F5CE85", borderRadius:8, padding:"12px 14px", marginBottom:14, fontSize:12, color:"var(--amber)"}}>
                        ⚠ Não identifiquei automaticamente nenhum processo vinculado a este pedido. Você pode selecionar manualmente abaixo ou prosseguir sem vincular (a IA vai gerar um modelo genérico).
                      </div>
                      <select onChange={e=>{ const p = processos.find(x=>x.id===parseInt(e.target.value)); if(p) setProcessoSelecionado(p); }} style={{...inp, marginBottom:12}} defaultValue="">
                        <option value="" disabled>Selecionar processo manualmente…</option>
                        {processos.map(p=><option key={p.id} value={p.id}>{p.numero} — {p.autor.slice(0,30)}</option>)}
                      </select>
                      <div style={{display:"flex", gap:8}}>
                        <button onClick={()=>setEtapa("input")} style={{...btnSec, flex:1, fontSize:11.5}}>Voltar</button>
                        <button onClick={gerar} style={{...btnPri, flex:1, fontSize:11.5}}>Gerar sem vincular</button>
                      </div>
                    </div>
                  )}

                  {processoSelecionado && candidatos.length === 0 && erro && (
                    <p style={{fontSize:12, color:"var(--red)", marginTop:10}}>{erro}</p>
                  )}
                </div>
              )}

              {etapa === "gerando" && (
                <div style={{display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", padding:"40px 0"}}>
                  <div style={{width:36, height:36, border:"3px solid var(--border1)", borderTopColor:"var(--accent)", borderRadius:"50%", animation:"spin 0.8s linear infinite"}}/>
                  <p style={{fontSize:12.5, color:"var(--text2)", marginTop:14}}>Redigindo com base nos dados do processo…</p>
                  <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
                </div>
              )}

              {etapa === "resultado" && (
                <div>
                  {processoSelecionado && (
                    <div style={{background:"var(--bg2)", borderRadius:6, padding:"8px 12px", marginBottom:10, fontSize:11, color:"var(--text2)"}}>
                      Baseado no processo <strong style={{color:"var(--text1)"}}>{processoSelecionado.numero}</strong>
                    </div>
                  )}
                  <div style={{background:"var(--bg2)", border:"1px solid var(--border1)", borderRadius:8, padding:14, maxHeight:320, overflow:"auto", marginBottom:12}}>
                    <pre style={{fontSize:11.5, lineHeight:1.6, whiteSpace:"pre-wrap", fontFamily:"inherit", margin:0, color:"var(--text1)"}}>{resultado}</pre>
                  </div>
                  <div style={{display:"flex", gap:8, marginBottom:8}}>
                    <button onClick={copiarTexto} style={{...btnSec, flex:1, fontSize:11.5}}>📋 Copiar texto</button>
                    <button onClick={baixarDocx} disabled={gerandoDocx} style={{...btnPri, flex:1, fontSize:11.5, opacity:gerandoDocx?.7:1}}>{gerandoDocx?"Gerando…":"⬇ Baixar Word"}</button>
                  </div>
                  <button onClick={resetar} style={{...btnSec, width:"100%", fontSize:11.5}}>Novo pedido</button>
                  <p style={{fontSize:10, color:"var(--text3)", marginTop:10, lineHeight:1.4}}>⚠ Texto gerado por IA — revise integralmente antes de protocolar. Não substitui análise jurídica profissional.</p>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
    </>
  );
}
