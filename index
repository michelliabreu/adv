function PaginaFinanceiro({parcelas,setParcelas,processos}){
  const [novoAcordo,setNovoAcordo]=useState(false);
  const [filtroCli,setFiltroCli]=useState("");
  const [filtroSt,setFiltroSt]=useState("todos");
  const [selecionados,setSelecionados]=useState({});
  const [mesAtivo,setMesAtivo]=useState(()=>hoje.toISOString().slice(0,7)); // YYYY-MM, ou "todos"

  const mudarMes = (delta) => {
    if(mesAtivo==="todos") { setMesAtivo(hoje.toISOString().slice(0,7)); return; }
    const [y,m] = mesAtivo.split("-").map(Number);
    const d = new Date(y, m-1+delta, 1);
    setMesAtivo(`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,"0")}`);
  };
  const labelMes = mesAtivo==="todos" ? "Todos os meses" : new Date(mesAtivo+"-02").toLocaleDateString("pt-BR",{month:"long",year:"numeric"});

  const parcelasDoMes = mesAtivo==="todos" ? parcelas : parcelas.filter(p=>(p.vencimento||"").slice(0,7)===mesAtivo);

  const totalContrato=[...new Map(parcelas.map(p=>[`${p.procId}-${p.cliente}`,p.totalContrato])).values()].reduce((a,b)=>a+b,0);
  const totalRecebido=parcelasDoMes.filter(p=>p.pago).reduce((a,p)=>a+p.valor,0);
  const totalAberto=parcelasDoMes.filter(p=>!p.pago).reduce((a,p)=>a+p.valor,0);
  const totalVencido=parcelasDoMes.filter(p=>statusParcela(p)==="vencido").reduce((a,p)=>a+p.valor,0);
  const lista=useMemo(()=>{const q=filtroCli.toLowerCase();return parcelasDoMes.filter(p=>{const st=statusParcela(p);return(!q||p.cliente.toLowerCase().includes(q))&&(filtroSt==="todos"||st===filtroSt);}).sort((a,b)=>new Date(a.vencimento)-new Date(b.vencimento));},[parcelasDoMes,filtroCli,filtroSt]);
  const marcarPago=id=>setParcelas(ps=>ps.map(p=>p.id===id?{...p,pago:!p.pago}:p));
  const vencendoHoje=parcelas.filter(p=>!p.pago&&diasRest(p.vencimento)>=0&&diasRest(p.vencimento)<=7);
  const procNum=id=>processos.find(p=>p.id===id)?.numero?.slice(0,22)+"…"||`Proc. ${id}`;
  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};

  const idsVisiveis = lista.map(p=>p.id);
  const qtdSelecionados = idsVisiveis.filter(id=>selecionados[id]).length;
  const todosSelecionados = idsVisiveis.length>0 && qtdSelecionados===idsVisiveis.length;
  const algumSelecionado = qtdSelecionados>0;

  const toggleTodos = () => {
    if(todosSelecionados){
      setSelecionados(s=>{ const novo={...s}; idsVisiveis.forEach(id=>delete novo[id]); return novo; });
    } else {
      setSelecionados(s=>{ const novo={...s}; idsVisiveis.forEach(id=>novo[id]=true); return novo; });
    }
  };
  const toggleUm = id => setSelecionados(s=>({...s, [id]: !s[id]}));

  const marcarSelecionadosComo = (pago) => {
    const ids = idsVisiveis.filter(id=>selecionados[id]);
    setParcelas(ps=>ps.map(p=>ids.includes(p.id)?{...p,pago}:p));
  };
  const excluirSelecionados = () => {
    const ids = idsVisiveis.filter(id=>selecionados[id]);
    if(ids.length===0) return;
    if(!confirm(`Excluir ${ids.length} parcela(s) selecionada(s)? Esta ação não pode ser desfeita.`)) return;
    setParcelas(ps=>ps.filter(p=>!ids.includes(p.id)));
    setSelecionados(s=>{ const novo={...s}; ids.forEach(id=>delete novo[id]); return novo; });
  };
  const excluirUm = id => {
    if(!confirm("Excluir esta parcela? Esta ação não pode ser desfeita.")) return;
    setParcelas(ps=>ps.filter(p=>p.id!==id));
    setSelecionados(s=>{ const novo={...s}; delete novo[id]; return novo; });
  };

  return(
    <div>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end",marginBottom:16}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Financeiro</h1>
          <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Controle de honorários e parcelas</p>
        </div>
        <button onClick={()=>setNovoAcordo(true)} style={{...btnPri,padding:"9px 18px",fontSize:12.5}}>+ Novo acordo</button>
      </div>

      <div style={{display:"flex",alignItems:"center",justifyContent:"center",gap:14,marginBottom:16,background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"8px 14px"}}>
        <button onClick={()=>mudarMes(-1)} disabled={mesAtivo==="todos"} style={{background:"none",border:"1px solid var(--border2)",borderRadius:5,width:30,height:30,cursor:mesAtivo==="todos"?"default":"pointer",opacity:mesAtivo==="todos"?.3:1,fontSize:14,color:"var(--text2)"}}>←</button>
        <span style={{fontSize:13,fontWeight:700,color:"var(--navy)",textTransform:"capitalize",minWidth:160,textAlign:"center"}}>{labelMes}</span>
        <button onClick={()=>mudarMes(1)} disabled={mesAtivo==="todos"} style={{background:"none",border:"1px solid var(--border2)",borderRadius:5,width:30,height:30,cursor:mesAtivo==="todos"?"default":"pointer",opacity:mesAtivo==="todos"?.3:1,fontSize:14,color:"var(--text2)"}}>→</button>
        <span style={{width:1,height:20,background:"var(--border1)"}}/>
        <button onClick={()=>setMesAtivo("todos")} style={{fontSize:11,padding:"5px 12px",cursor:"pointer",borderRadius:5,border:"1px solid var(--border2)",background:mesAtivo==="todos"?"var(--navy2)":"#fff",color:mesAtivo==="todos"?"#fff":"var(--text2)",fontWeight:600}}>Ver tudo</button>
        {mesAtivo!=="todos"&&<button onClick={()=>setMesAtivo(hoje.toISOString().slice(0,7))} style={{fontSize:11,padding:"5px 12px",cursor:"pointer",borderRadius:5,border:"none",background:"none",color:"var(--accent)",fontWeight:600}}>Mês atual</button>}
      </div>

      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,marginBottom:16}}>
        <KpiCard label="Total contratado (geral)" value={fmtBRL(totalContrato)} color="var(--navy)" icon="📄"/>
        <KpiCard label={mesAtivo==="todos"?"Total recebido":"Recebido no mês"} value={fmtBRL(totalRecebido)} color="var(--green)" icon="✓"/>
        <KpiCard label={mesAtivo==="todos"?"Em aberto":"Em aberto no mês"} value={fmtBRL(totalAberto)} color="var(--accent)" icon="⏳"/>
        <KpiCard label="Vencido" value={fmtBRL(totalVencido)} color="var(--red)" icon="⚠"/>
      </div>
      {vencendoHoje.length>0&&<div style={{background:"var(--amber-bg)",borderLeft:"3px solid var(--amber)",borderRadius:6,padding:"10px 14px",marginBottom:14,fontSize:12,color:"var(--amber)"}}><strong style={{textTransform:"uppercase",letterSpacing:".5px",marginRight:8}}>Parcelas a vencer em até 7 dias:</strong>{vencendoHoje.map(p=><span key={p.id} style={{marginRight:12}}>{p.cliente} — parcela {p.parcela}/{p.totalParcelas} ({fmtData(p.vencimento)})</span>)}</div>}
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"8px 14px",display:"flex",justifyContent:"space-between",alignItems:"center",flexWrap:"wrap",gap:8,marginBottom:12}}>
        <div style={{display:"flex",gap:0}}>{[["todos","Todos"],["pendente","Pendente"],["aVencer","A vencer"],["vencido","Vencido"],["pago","Pago"]].map(([v,l])=><button key={v} onClick={()=>setFiltroSt(v)} style={{background:"none",border:"none",borderBottom:filtroSt===v?"2px solid var(--navy2)":"2px solid transparent",color:filtroSt===v?"var(--navy2)":"var(--text2)",padding:"5px 12px 7px",fontSize:11,fontWeight:filtroSt===v?700:500,cursor:"pointer",textTransform:"uppercase",letterSpacing:".5px"}}>{l}</button>)}</div>
        <input placeholder="Buscar cliente…" value={filtroCli} onChange={e=>setFiltroCli(e.target.value)} style={{fontSize:12,padding:"6px 11px",borderRadius:5,border:"1px solid var(--border2)",background:"#fff",color:"var(--text1)",width:200}}/>
      </div>

      {algumSelecionado && (
        <div style={{background:"var(--navy)",borderRadius:8,padding:"9px 14px",marginBottom:10,display:"flex",alignItems:"center",justifyContent:"space-between",gap:10,flexWrap:"wrap"}}>
          <span style={{fontSize:12,color:"#fff",fontWeight:600}}>{qtdSelecionados} parcela(s) selecionada(s)</span>
          <div style={{display:"flex",gap:8,flexWrap:"wrap"}}>
            <button onClick={()=>marcarSelecionadosComo(true)} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:"none",background:"var(--green)",color:"#fff",fontWeight:600}}>✓ Marcar como pago</button>
            <button onClick={()=>marcarSelecionadosComo(false)} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:"none",background:"rgba(255,255,255,.15)",color:"#fff",fontWeight:600}}>Marcar como pendente</button>
            <button onClick={excluirSelecionados} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:"1px solid var(--red)",background:"var(--red)",color:"#fff",fontWeight:600}}>🗑 Excluir selecionadas</button>
            <button onClick={()=>setSelecionados({})} style={{fontSize:11,padding:"6px 12px",cursor:"pointer",borderRadius:5,border:"none",background:"transparent",color:"rgba(255,255,255,.7)",fontWeight:600}}>Cancelar</button>
          </div>
        </div>
      )}

      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden"}}>
        <div style={{display:"grid",gridTemplateColumns:"34px 2fr 1.2fr .8fr .9fr .9fr .8fr 40px",padding:"9px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)",alignItems:"center"}}>
          <input type="checkbox" checked={todosSelecionados} onChange={toggleTodos} style={{width:15,height:15,cursor:"pointer"}}/>
          {["Processo / Cliente","Parcela","Valor","Vencimento","Status",""].map(h=><span key={h} style={hdr}>{h}</span>)}
        </div>
        {lista.length===0?<div style={{padding:"2.5rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhuma parcela encontrada.</div>:lista.map((p,i)=>{const st=statusParcela(p),cfg=PC[st];return(
          <div key={p.id} style={{display:"grid",gridTemplateColumns:"34px 2fr 1.2fr .8fr .9fr .9fr .8fr 40px",padding:"11px 14px",alignItems:"center",borderBottom:i<lista.length-1?"1px solid var(--border1)":"none",background:selecionados[p.id]?"var(--accent-light)":st==="vencido"?"rgba(185,28,28,.03)":st==="aVencer"?"rgba(180,83,9,.04)":"transparent"}}>
            <input type="checkbox" checked={!!selecionados[p.id]} onChange={()=>toggleUm(p.id)} style={{width:15,height:15,cursor:"pointer"}}/>
            <div><p style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 2px"}}>{procNum(p.procId)}</p><p style={{fontSize:13,fontWeight:600,margin:0}}>{p.cliente}</p></div>
            <div style={{fontSize:12,color:"var(--text2)"}}>{p.parcela} / {p.totalParcelas}</div>
            <div style={{fontSize:13,fontWeight:700}}>{fmtBRL(p.valor)}</div>
            <div style={{fontSize:12}}>{fmtData(p.vencimento)}</div>
            <div><Pill bg={cfg.bg} color={cfg.color} label={cfg.label} sm/></div>
            <div><button onClick={()=>marcarPago(p.id)} style={{fontSize:10,padding:"5px 11px",cursor:"pointer",borderRadius:5,border:`1px solid ${p.pago?"#ccc":"var(--navy2)"}`,background:p.pago?"var(--bg2)":"var(--navy2)",color:p.pago?"var(--text2)":"#fff",fontWeight:600,whiteSpace:"nowrap"}}>{p.pago?"Desfazer":"Pagar"}</button></div>
            <button onClick={()=>excluirUm(p.id)} title="Excluir parcela" style={{background:"none",border:"none",cursor:"pointer",color:"var(--text3)",fontSize:15,padding:0,lineHeight:1}}>🗑</button>
          </div>
        );})}
      </div>
      <p style={{fontSize:11,color:"var(--text2)",marginTop:8,textAlign:"right"}}>{lista.length} parcela(s)</p>
      {novoAcordo&&<ModalAcordo processos={processos} onSave={ps=>{setParcelas(x=>[...x,...ps]);setNovoAcordo(false);}} onClose={()=>setNovoAcordo(false)}/>}
    </div>
  );
}

function PaginaRelatorios({processos,parcelas,clientes}){
  const [clienteSel,setClienteSel]=useState("");
  const [preview,setPreview]=useState(false);
  const clienteObj = clientes.find(c=>String(c.id)===String(clienteSel));
  const clienteData=useMemo(()=>{if(!clienteSel)return null;return{procs:processos.filter(p=>String(p.clienteId)===String(clienteSel)),parts:parcelas.filter(p=>clienteObj&&p.cliente===clienteObj.nome)};},[clienteSel,processos,parcelas,clienteObj]);
  const gerarCorpoEmail=()=>{
    if(!clienteData||!clienteObj)return"";
    const{procs,parts}=clienteData;
    const mes=hoje.toLocaleDateString("pt-BR",{month:"long",year:"numeric"});
    let txt=`Prezado(a) ${clienteObj.nome},\n\nSegue o relatório mensal dos seus processos referente a ${mes}.\n\n━━ PROCESSOS ━━\n\n`;
    procs.forEach(p=>{
      txt+=`📋 Processo: ${p.numero}\n   Ação: ${p.autor} vs. ${p.reu}\n   Vara: ${p.vara}\n   Status: ${SC[normalizarStatus(p.status)]?.label}${isUrgProc(p)?` ⚠️ PRAZO EM ${diasRest(p.prazo)} DIAS`:""}\n   Próximo prazo: ${fmtData(p.prazo)}\n`;
      if(p.debito?.valor) txt+=`   💰 Débito atualizado: ${fmtBRL(p.debito.valor)}\n`;
      if(p.prazoProcessual?.ativo){const d=diasRest(p.prazoProcessual.vencimento);txt+=`   ⏱ Próximo ato: ${p.prazoProcessual.proximoAto} — ${p.prazoProcessual.parte} — vence ${fmtData(p.prazoProcessual.vencimento)} (${d<0?`${Math.abs(d)}d vencido`:d+"d restantes"})\n`;}
      const ands=[...(p.andamentos||[])].sort((a,b)=>b.data.localeCompare(a.data));
      if(ands[0])txt+=`   Último ato: ${fmtData(ands[0].data)} — ${ands[0].desc}\n`;
      txt+="\n";
    });
    if(parts.length){
      txt+=`━━ FINANCEIRO ━━\n\n`;
      const pago=parts.filter(x=>x.pago).reduce((a,x)=>a+x.valor,0);
      const aberto=parts.filter(x=>!x.pago).reduce((a,x)=>a+x.valor,0);
      txt+=`Total pago: ${fmtBRL(pago)}\nSaldo em aberto: ${fmtBRL(aberto)}\n\n`;
      const prox=parts.filter(x=>!x.pago).sort((a,b)=>new Date(a.vencimento)-new Date(b.vencimento)).slice(0,3);
      if(prox.length){txt+=`Próximas parcelas:\n`;prox.forEach(x=>txt+=`   • Parcela ${x.parcela}/${x.totalParcelas} — ${fmtBRL(x.valor)} — ${fmtData(x.vencimento)}\n`);}
      txt+="\n";
    }
    txt+=`Qualquer dúvida, estamos à disposição.\n\nAtenciosamente,\nMichelli Abreu Advocacia`;
    return txt;
  };
  const abrirGmail=()=>{if(!clienteData||!clienteObj)return;const mes=hoje.toLocaleDateString("pt-BR",{month:"long",year:"numeric"});window.open(`https://mail.google.com/mail/?view=cm&to=${encodeURIComponent(clienteObj.email||"")}&su=${encodeURIComponent(`Relatório Mensal — ${clienteObj.nome} — ${mes}`)}&body=${encodeURIComponent(gerarCorpoEmail())}`,"_blank");};
  const hdr={fontSize:10,textTransform:"uppercase",letterSpacing:".6px",color:"var(--text2)",fontWeight:700};
  return(
    <div>
      <div style={{marginBottom:16}}>
        <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Relatórios</h1>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Gere relatórios consolidados por cliente</p>
      </div>
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"1.25rem",marginBottom:16}}>
        <p style={{fontSize:10,textTransform:"uppercase",letterSpacing:".7px",color:"var(--text2)",margin:"0 0 12px",fontWeight:700}}>Gerar relatório por cliente</p>
        <div style={{display:"flex",gap:12,alignItems:"flex-end",flexWrap:"wrap"}}>
          <div style={{flex:1,minWidth:200}}><span style={lbl}>Selecione o cliente</span><select value={clienteSel} onChange={e=>setClienteSel(e.target.value)} style={{...inp,padding:"8px 10px"}}><option value="">Selecione…</option>{[...clientes].sort((a,b)=>a.nome.localeCompare(b.nome,"pt-BR")).map(c=><option key={c.id} value={c.id}>{c.nome}{c.email?` — ${c.email}`:""}</option>)}</select></div>
          <div style={{display:"flex",gap:8}}>
            <button onClick={()=>setPreview(!preview)} disabled={!clienteSel} style={{...btnSec,opacity:clienteSel?1:.5}}>👁 Pré-visualizar</button>
            <button onClick={abrirGmail} disabled={!clienteSel||!clienteObj?.email} style={{...btnPri,opacity:(clienteSel&&clienteObj?.email)?1:.5}}>✉ Abrir no Gmail</button>
          </div>
        </div>
        {clienteSel&&!clienteObj?.email&&<p style={{fontSize:11,color:"var(--amber)",margin:"8px 0 0"}}>⚠ Este cliente não possui e-mail cadastrado. Edite o cliente no CRM para habilitar o envio.</p>}
      </div>
      {preview&&clienteData&&(
        <div>
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden",marginBottom:10}}>
            <div style={{padding:"10px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)",display:"flex",justifyContent:"space-between"}}><span style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".6px"}}>Processos — {clienteObj?.nome}</span><span style={{fontSize:11,color:"var(--text2)"}}>{clienteData.procs.length} processo(s)</span></div>
            <div style={{display:"grid",gridTemplateColumns:"2fr 1fr 1fr 1fr",padding:"8px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)"}}>{["Processo","Vara","Prazo","Status"].map(h=><span key={h} style={hdr}>{h}</span>)}</div>
            {clienteData.procs.map((p,i)=>(
              <div key={p.id} style={{padding:"10px 14px",borderBottom:i<clienteData.procs.length-1?"1px solid var(--border1)":"none"}}>
                <div style={{display:"grid",gridTemplateColumns:"2fr 1fr 1fr 1fr",alignItems:"center",marginBottom:(p.prazoProcessual?.ativo||p.debito?.valor)?6:0}}>
                  <div><p style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 2px"}}>{p.numero}</p><p style={{fontSize:12,fontWeight:600,margin:0}}>vs. {p.reu}</p></div>
                  <div style={{fontSize:11,color:"var(--text2)"}}>{p.vara}</div>
                  <div style={{fontSize:12,color:isUrgProc(p)?"var(--red)":"var(--text1)"}}>{fmtData(p.prazo)}</div>
                  <div><Pill {...SC[normalizarStatus(p.status)]} sm/></div>
                </div>
                {p.debito?.valor&&<DebitoBadge debito={p.debito} compact={true}/>}
                {p.prazoProcessual?.ativo&&<PrazoBadge prazoInfo={p.prazoProcessual} compact={false}/>}
              </div>
            ))}
          </div>
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,overflow:"hidden"}}>
            <div style={{padding:"10px 14px",background:"var(--bg2)",borderBottom:"1px solid var(--border1)"}}><span style={{fontSize:11,fontWeight:700,textTransform:"uppercase",letterSpacing:".6px"}}>Corpo do e-mail</span></div>
            <pre style={{padding:"14px",fontSize:12,lineHeight:1.7,color:"var(--text1)",whiteSpace:"pre-wrap",fontFamily:"inherit",background:"transparent"}}>{gerarCorpoEmail()}</pre>
          </div>
        </div>
      )}
    </div>
  );
}

// ── Página Intimações (DJEN/CNJ) ───────────────────────────
function ModalCriarPrazoIntimacao({intimacao, onConfirm, onClose}){
  const sugestao = detectarPrazo({desc: intimacao.texto || intimacao.teor || ""});
  const [form,setForm] = useState({
    proximoAto: sugestao?.ato || "",
    parte: sugestao?.parte || "",
    diasPrazo: sugestao?.prazo ?? 15,
    base: sugestao?.base || "",
    dataInicio: (intimacao.dataDisponibilizacao || intimacao.data || hoje.toISOString().slice(0,10)).slice(0,10),
  });
  const s=(k,v)=>setForm(f=>({...f,[k]:v}));
  const venc = form.dataInicio && form.diasPrazo > 0 ? calcularVencimento(form.dataInicio, parseInt(form.diasPrazo)) : null;
  return (
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.5)",zIndex:500,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:480,maxWidth:"100%",borderRadius:10,padding:"1.5rem",boxShadow:"0 20px 50px rgba(0,0,0,.25)"}}>
        <p style={{fontSize:10,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".7px",margin:"0 0 10px",fontWeight:600}}>Criar prazo a partir da intimação</p>
        {sugestao
          ? <div style={{background:"var(--accent-light)",border:"1px solid #B8D4F0",borderRadius:5,padding:"8px 12px",marginBottom:12,fontSize:12,color:"var(--navy2)"}}>✦ Sugestão: <strong>{sugestao.ato}</strong> — {sugestao.prazo}d — {sugestao.parte}</div>
          : <div style={{background:"var(--amber-bg)",border:"1px solid #F5CE85",borderRadius:5,padding:"8px 12px",marginBottom:12,fontSize:12,color:"var(--amber)"}}>⚠ Não identifiquei automaticamente. Preencha manualmente.</div>
        }
        <div style={{display:"flex",flexDirection:"column",gap:10}}>
          <div><span style={lbl}>Próximo ato necessário</span><input value={form.proximoAto} onChange={e=>s("proximoAto",e.target.value)} style={inp}/></div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Parte responsável</span>
              <select value={form.parte} onChange={e=>s("parte",e.target.value)} style={{...inp,padding:"7px 8px"}}>
                <option value="">Selecione…</option>
                {["Autor","Réu","Ambas","Exequente","Executado","Intimado","Prejudicado"].map(o=><option key={o}>{o}</option>)}
              </select>
            </div>
            <div><span style={lbl}>Prazo (dias úteis)</span><input type="number" min="1" max="120" value={form.diasPrazo} onChange={e=>s("diasPrazo",e.target.value)} style={inp}/></div>
          </div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Data da intimação</span><input type="date" value={form.dataInicio} onChange={e=>s("dataInicio",e.target.value)} style={inp}/></div>
            <div><span style={lbl}>Vencimento</span><div style={{fontSize:13,fontWeight:600,padding:"8px 10px",background:"var(--bg2)",borderRadius:5,border:"1px solid var(--border1)"}}>{venc?fmtData(venc):"—"}</div></div>
          </div>
        </div>
        <div style={{marginTop:16,display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={()=>{if(!form.proximoAto||!form.parte)return;onConfirm({proximoAto:form.proximoAto,parte:form.parte,diasPrazo:parseInt(form.diasPrazo),base:form.base,vencimento:venc,ativo:true});}} style={btnPri}>Criar prazo</button>
        </div>
      </div>
    </div>
  );
}

function ModalCriarTarefaIntimacao({intimacao, equipe, onConfirm, onClose}){
  const [titulo,setTitulo] = useState("Analisar intimação e providenciar manifestação");
  const [responsavelId,setResponsavelId] = useState("");
  const [prazo,setPrazo] = useState("");
  return (
    <div onClick={e=>e.target===e.currentTarget&&onClose()} style={{position:"fixed",inset:0,background:"rgba(15,38,69,.5)",zIndex:500,display:"flex",alignItems:"center",justifyContent:"center",padding:"1rem"}}>
      <div style={{background:"#fff",width:440,maxWidth:"100%",borderRadius:10,padding:"1.5rem",boxShadow:"0 20px 50px rgba(0,0,0,.25)"}}>
        <p style={{fontSize:10,color:"var(--text2)",textTransform:"uppercase",letterSpacing:".7px",margin:"0 0 14px",fontWeight:600}}>Criar tarefa a partir da intimação</p>
        <div style={{display:"flex",flexDirection:"column",gap:10}}>
          <div><span style={lbl}>Título</span><input value={titulo} onChange={e=>setTitulo(e.target.value)} style={inp}/></div>
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
            <div><span style={lbl}>Responsável</span>
              <select value={responsavelId} onChange={e=>setResponsavelId(e.target.value)} style={{...inp,padding:"7px 8px"}}>
                <option value="">—</option>
                {equipe.map(m=><option key={m.id} value={m.id}>{m.nome}</option>)}
              </select>
            </div>
            <div><span style={lbl}>Prazo</span><input type="date" value={prazo} onChange={e=>setPrazo(e.target.value)} style={inp}/></div>
          </div>
        </div>
        <div style={{marginTop:16,display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button onClick={onClose} style={btnSec}>Cancelar</button>
          <button onClick={()=>{if(!titulo.trim())return;onConfirm({titulo,responsavelId:responsavelId?parseInt(responsavelId):"",prazo});}} style={btnPri}>Criar tarefa</button>
        </div>
      </div>
    </div>
  );
}

function PaginaIntimacoes({processos, clientes, equipe, setProcessos, setTarefas, publicacoes, setPublicacoes}){
  const [numeroOab, setNumeroOab] = useState("155134");
  const [ufOab, setUfOab] = useState("RJ");
  const [textoColado, setTextoColado] = useState("");
  const [interpretando, setInterpretando] = useState(false);
  const [erro, setErro] = useState("");
  const [vinculando, setVinculando] = useState({});
  const [criandoPrazoPara, setCriandoPrazoPara] = useState(null);
  const [criandoTarefaPara, setCriandoTarefaPara] = useState(null);
  const [filtroDataIni, setFiltroDataIni] = useState("");
  const [filtroDataFim, setFiltroDataFim] = useState("");
  const [filtroBusca, setFiltroBusca] = useState("");
  const [filtroStatus, setFiltroStatus] = useState("todas"); // todas | lidas | nao_lidas | vinculadas | nao_vinculadas

  const abrirSiteOficial = () => {
    const url = `https://comunica.pje.jus.br/consulta?numeroOab=${encodeURIComponent(numeroOab)}&ufOab=${encodeURIComponent(ufOab)}`;
    window.open(url, "_blank");
  };

  const interpretarColado = async () => {
    if(!textoColado.trim()){ setErro("Cole o texto da(s) publicação(ões) antes de interpretar."); return; }
    setInterpretando(true); setErro("");
    try {
      let res;
      try {
        res = await fetch(IA_PROXY_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Authorization": "Bearer " + SUPABASE_KEY },
          body: JSON.stringify({
            model: "claude-sonnet-4-6",
            max_tokens: 2000,
            system: `Você extrai dados estruturados de publicações do Diário de Justiça Eletrônico Nacional (DJEN) coladas em texto bruto, que pode conter uma ou várias intimações concatenadas, com formatação irregular (quebras de linha, espaçamento inconsistente).

Retorne SOMENTE um JSON válido (array), sem texto adicional, sem markdown, sem blocos de código. Cada item do array representa UMA intimação/publicação distinta, com esta estrutura exata:
[{"numeroProcesso":"NNNNNNN-DD.AAAA.J.TR.OOOO ou string vazia se não identificado","dataDisponibilizacao":"YYYY-MM-DD ou string vazia","tribunal":"sigla do tribunal se identificável, ex TJRJ, TRT1, ou string vazia","resumo":"resumo objetivo do teor em até 2 frases, em português, parafraseado nas suas próprias palavras","tipoAto":"uma palavra-chave entre: sentenca, despacho, decisao, intimacao, citacao, designacao_audiencia, outro"}]

Se o texto colado contiver apenas uma publicação, retorne um array com um único item. Se não conseguir identificar um campo, use string vazia — nunca invente.`,
            messages: [{role:"user", content: textoColado}]
          })
        });
      } catch(networkErr) {
        throw new Error("Não foi possível conectar ao serviço de IA — verifique sua conexão com a internet.");
      }
      if(!res.ok){
        let detalhe = "";
        try { const errBody = await res.json(); detalhe = errBody?.error?.message || ""; } catch(_){}
        throw new Error(`Erro HTTP ${res.status} ao chamar a IA.${detalhe?` Detalhe: ${detalhe}`:""}`);
      }
      const data = await res.json();
      const txt = data.content?.find(b=>b.type==="text")?.text || "";
      if(!txt) throw new Error("A IA retornou uma resposta vazia.");
      let parsed;
      try {
        parsed = JSON.parse(txt.replace(/```json|```/g,"").trim());
      } catch(parseErr) {
        throw new Error(`A resposta da IA não veio em JSON válido. Início: "${txt.slice(0,150)}"`);
      }
      if(!Array.isArray(parsed)) throw new Error("Formato inesperado — a IA não retornou uma lista de publicações.");
      const novas = parsed.map((item,i)=>({
        ...item,
        _localId: Date.now()+i,
        capturadaEm: new Date().toISOString(),
        lida: false,
        textoOriginal: textoColado,
      }));
      setPublicacoes(ps => [...novas, ...ps]);
      setTextoColado("");
    } catch(e) {
      setErro(e.message || "Não foi possível interpretar o texto colado. Verifique se copiou o conteúdo da publicação corretamente e tente novamente.");
    }
    setInterpretando(false);
  };

  const tentarAcharProcesso = (item) => {
    const numIntim = (item.numeroProcesso || "").replace(/\D/g,"");
    if(!numIntim) return null;
    return processos.find(p => p.numero.replace(/\D/g,"") === numIntim) || null;
  };

  const marcarLida = (id, lida=true) => {
    setPublicacoes(ps => ps.map(p => p._localId===id ? {...p, lida} : p));
  };
  const excluirPublicacao = (id) => {
    if(!confirm("Remover esta publicação da lista? Isso não desfaz nenhum prazo/tarefa já criado a partir dela.")) return;
    setPublicacoes(ps => ps.filter(p => p._localId!==id));
  };

  const vincularEAdicionarAndamento = (item, procId) => {
    if(!procId) return;
    const desc = `Intimação (DJEN): ${item.resumo || "Comunicação processual recebida"}`;
    const data = item.dataDisponibilizacao || hoje.toISOString().slice(0,10);
    setProcessos(ps=>ps.map(p=>p.id===procId ? {...p, andamentos:[...(p.andamentos||[]), {data, desc, fonte:"manual"}].sort((a,b)=>a.data.localeCompare(b.data))} : p));
  };

  const confirmarPrazo = (info) => {
    if(!criandoPrazoPara) return;
    const proc = tentarAcharProcesso(criandoPrazoPara) || (vinculando[criandoPrazoPara._localId] ? processos.find(p=>p.id===vinculando[criandoPrazoPara._localId]) : null);
    if(proc){
      setProcessos(ps=>ps.map(p=>p.id===proc.id?{...p,prazoProcessual:info}:p));
    }
    setCriandoPrazoPara(null);
  };

  const confirmarTarefa = (dados) => {
    if(!criandoTarefaPara) return;
    const proc = tentarAcharProcesso(criandoTarefaPara) || (vinculando[criandoTarefaPara._localId] ? processos.find(p=>p.id===vinculando[criandoTarefaPara._localId]) : null);
    setTarefas(ts=>[...ts, {
      id: Date.now(),
      titulo: dados.titulo,
      responsavelId: dados.responsavelId,
      procId: proc?.id || "",
      clienteId: proc?.clienteId || "",
      status: "pendente",
      prioridade: "alta",
      prazo: dados.prazo,
      desc: `Originada da intimação publicada em ${fmtData(criandoTarefaPara.dataDisponibilizacao)}`,
      arquivada: false,
    }]);
    setCriandoTarefaPara(null);
  };

  // Lista filtrada
  const publicacoesFiltradas = useMemo(() => {
    return publicacoes.filter(item => {
      if(filtroDataIni && item.dataDisponibilizacao && item.dataDisponibilizacao < filtroDataIni) return false;
      if(filtroDataFim && item.dataDisponibilizacao && item.dataDisponibilizacao > filtroDataFim) return false;
      if(filtroStatus==="lidas" && !item.lida) return false;
      if(filtroStatus==="nao_lidas" && item.lida) return false;
      if(filtroStatus==="vinculadas" && !tentarAcharProcesso(item)) return false;
      if(filtroStatus==="nao_vinculadas" && tentarAcharProcesso(item)) return false;
      if(filtroBusca){
        const q = filtroBusca.toLowerCase();
        const alvo = `${item.numeroProcesso||""} ${item.resumo||""} ${item.tribunal||""}`.toLowerCase();
        if(!alvo.includes(q)) return false;
      }
      return true;
    }).sort((a,b)=>(b.dataDisponibilizacao||"").localeCompare(a.dataDisponibilizacao||""));
  }, [publicacoes, filtroDataIni, filtroDataFim, filtroStatus, filtroBusca, processos]);

  return (
    <div>
      <div style={{marginBottom:16}}>
        <h1 style={{fontSize:22,fontWeight:700,color:"var(--text1)",margin:"0 0 3px",letterSpacing:"-.02em"}}>Intimações</h1>
        <p style={{fontSize:12.5,color:"var(--text2)",margin:0}}>Diário de Justiça Eletrônico Nacional (DJEN/CNJ)</p>
      </div>

      <div style={{background:"var(--amber-bg)",border:"1px solid #F5CE85",borderRadius:6,padding:"10px 14px",marginBottom:14,fontSize:11.5,color:"var(--amber)",lineHeight:1.5}}>
        ⚠️ A API pública do CNJ não permite consulta automática direta do navegador (bloqueio de segurança do próprio site do governo). O fluxo abaixo resolve isso em 2 passos: abra o site oficial, copie o que for relevante, e cole aqui para o sistema organizar automaticamente.
      </div>

      {/* Passo 1 */}
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"1.1rem",marginBottom:14}}>
        <p style={{fontSize:11,fontWeight:700,color:"var(--navy)",margin:"0 0 12px",textTransform:"uppercase",letterSpacing:".4px"}}>1. Consultar no site oficial</p>
        <div style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:10,marginBottom:12}}>
          <div><span style={lbl}>Número da OAB</span><input value={numeroOab} onChange={e=>setNumeroOab(e.target.value.replace(/\D/g,""))} style={inp} placeholder="155134"/></div>
          <div><span style={lbl}>UF</span>
            <select value={ufOab} onChange={e=>setUfOab(e.target.value)} style={{...inp,padding:"7px 8px"}}>
              {["RJ","SP","MG","RS","PR","BA","PE","CE","DF","ES","SC","GO","PA","AM"].map(u=><option key={u} value={u}>{u}</option>)}
            </select>
          </div>
        </div>
        <button onClick={abrirSiteOficial} style={{...btnPri,width:"100%",padding:"10px",display:"flex",alignItems:"center",justifyContent:"center",gap:8}}>
          🔗 Abrir comunica.pje.jus.br com esses dados
        </button>
      </div>

      {/* Passo 2 */}
      <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"1.1rem",marginBottom:16}}>
        <p style={{fontSize:11,fontWeight:700,color:"var(--navy)",margin:"0 0 6px",textTransform:"uppercase",letterSpacing:".4px"}}>2. Colar a(s) publicação(ões) encontrada(s)</p>
        <p style={{fontSize:11.5,color:"var(--text2)",margin:"0 0 12px",lineHeight:1.5}}>Selecione e copie o texto da publicação no site oficial (pode colar várias de uma vez) e cole abaixo. A IA identifica processo, data e resumo automaticamente.</p>
        <textarea value={textoColado} onChange={e=>setTextoColado(e.target.value)} placeholder="Cole aqui o texto da publicação…" style={{width:"100%",minHeight:140,fontSize:12,padding:"10px",borderRadius:6,border:"1px solid var(--border2)",resize:"vertical",boxSizing:"border-box",fontFamily:"inherit",marginBottom:10}}/>
        {erro && <p style={{fontSize:12,color:"var(--red)",marginBottom:10}}>{erro}</p>}
        <button onClick={interpretarColado} disabled={interpretando} style={{...btnPri,width:"100%",padding:"10px",opacity:interpretando?.7:1}}>
          {interpretando ? "Interpretando…" : "✨ Interpretar com IA"}
        </button>
      </div>

      {/* Lista de publicações capturadas, com filtros */}
      <div style={{borderTop:"1px solid var(--border1)",paddingTop:18,marginTop:6}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12,flexWrap:"wrap",gap:8}}>
          <p style={{fontSize:13,fontWeight:700,color:"var(--navy)",margin:0}}>📋 Publicações capturadas ({publicacoes.length})</p>
        </div>

        {publicacoes.length > 0 && (
          <div style={{background:"#fff",border:"1px solid var(--border1)",borderRadius:8,padding:"12px 14px",marginBottom:14}}>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1.4fr 1fr",gap:10}}>
              <div><span style={lbl}>De</span><input type="date" value={filtroDataIni} onChange={e=>setFiltroDataIni(e.target.value)} style={{...inp,fontSize:12,padding:"6px 9px"}}/></div>
              <div><span style={lbl}>Até</span><input type="date" value={filtroDataFim} onChange={e=>setFiltroDataFim(e.target.value)} style={{...inp,fontSize:12,padding:"6px 9px"}}/></div>
              <div><span style={lbl}>Buscar</span><input value={filtroBusca} onChange={e=>setFiltroBusca(e.target.value)} placeholder="Nº processo, tribunal, conteúdo…" style={{...inp,fontSize:12,padding:"6px 9px"}}/></div>
              <div><span style={lbl}>Status</span>
                <select value={filtroStatus} onChange={e=>setFiltroStatus(e.target.value)} style={{...inp,fontSize:12,padding:"6px 9px"}}>
                  <option value="todas">Todas</option>
                  <option value="nao_lidas">Não lidas</option>
                  <option value="lidas">Lidas</option>
                  <option value="vinculadas">Vinculadas a processo</option>
                  <option value="nao_vinculadas">Não vinculadas</option>
                </select>
              </div>
            </div>
            {(filtroDataIni||filtroDataFim||filtroBusca||filtroStatus!=="todas") && (
              <button onClick={()=>{setFiltroDataIni("");setFiltroDataFim("");setFiltroBusca("");setFiltroStatus("todas");}} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--accent)",fontWeight:600,padding:0,marginTop:8}}>× Limpar filtros</button>
            )}
          </div>
        )}

        {publicacoes.length === 0 && (
          <div style={{background:"var(--bg2)",borderRadius:8,padding:"2rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhuma publicação capturada ainda. Cole o texto de uma intimação acima para começar.</div>
        )}

        {publicacoes.length > 0 && publicacoesFiltradas.length === 0 && (
          <div style={{background:"var(--bg2)",borderRadius:8,padding:"2rem",textAlign:"center",color:"var(--text2)",fontSize:13}}>Nenhuma publicação corresponde aos filtros aplicados.</div>
        )}

        {publicacoesFiltradas.length > 0 && (
          <div>
            <p style={{fontSize:11.5,color:"var(--text2)",marginBottom:10}}>{publicacoesFiltradas.length} de {publicacoes.length} publicação(ões)</p>
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              {publicacoesFiltradas.map((item)=>{
                const id = item._localId;
                const procVinculado = tentarAcharProcesso(item);
                const lida = !!item.lida;
                return (
                  <div key={id} style={{background:"#fff",border:"1px solid var(--border1)",borderLeft:`3px solid ${lida?"var(--border2)":"var(--accent)"}`,borderRadius:8,padding:"14px 16px",opacity:lida?.75:1}}>
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",gap:10,marginBottom:8}}>
                      <div>
                        <p style={{fontSize:11,fontFamily:"monospace",color:"var(--text2)",margin:"0 0 3px"}}>{item.numeroProcesso || "Processo não identificado"}</p>
                        <p style={{fontSize:10.5,color:"var(--text2)",margin:0}}>{item.tribunal || ""} {item.dataDisponibilizacao?`· Disponibilizado em ${fmtData(item.dataDisponibilizacao)}`:"· Data não identificada"}</p>
                      </div>
                      <div style={{display:"flex",gap:6,flexWrap:"wrap",justifyContent:"flex-end"}}>
                        {item.tipoAto && item.tipoAto!=="outro" && <Pill bg="var(--amber-bg)" color="var(--amber)" label={item.tipoAto.replace("_"," ")} sm/>}
                        {procVinculado
                          ? <Pill bg="var(--green-bg)" color="var(--green)" label="Processo identificado" sm/>
                          : <Pill bg="var(--bg2)" color="var(--text2)" label="Vincular manualmente" sm/>
                        }
                      </div>
                    </div>
                    <p style={{fontSize:12.5,color:"var(--text1)",lineHeight:1.5,margin:"0 0 12px"}}>{item.resumo || "Sem resumo disponível."}</p>

                    {!procVinculado && (
                      <div style={{marginBottom:10}}>
                        <select value={vinculando[id]||""} onChange={e=>setVinculando(v=>({...v,[id]:e.target.value?parseInt(e.target.value):""}))} style={{...inp,fontSize:11.5,padding:"6px 9px"}}>
                          <option value="">Vincular a um processo do sistema…</option>
                          {processos.map(p=><option key={p.id} value={p.id}>{p.numero} — {p.autor.slice(0,30)}</option>)}
                        </select>
                      </div>
                    )}

                    <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
                      <button onClick={()=>{
                        const procId = procVinculado?.id || vinculando[id];
                        if(!procId){ alert("Selecione um processo para vincular esta intimação antes."); return; }
                        vincularEAdicionarAndamento(item, procId);
                        marcarLida(id, true);
                      }} style={{...btnSec,fontSize:11,padding:"6px 12px"}}>+ Adicionar ao histórico do processo</button>

                      <button onClick={()=>{
                        if(!procVinculado && !vinculando[id]){ alert("Selecione um processo para vincular esta intimação antes."); return; }
                        setCriandoPrazoPara({...item, desc:item.resumo});
                      }} style={{...btnSec,fontSize:11,padding:"6px 12px",borderColor:"#C4B5FD",color:"var(--purple)",background:"var(--purple-bg)"}}>⏱ Criar prazo</button>

                      <button onClick={()=>{
                        if(!procVinculado && !vinculando[id]){ alert("Selecione um processo para vincular esta intimação antes."); return; }
                        setCriandoTarefaPara(item);
                      }} style={{...btnSec,fontSize:11,padding:"6px 12px"}}>✅ Criar tarefa</button>

                      <button onClick={()=>marcarLida(id, !lida)} style={{...btnSec,fontSize:11,padding:"6px 12px",color:"var(--text2)"}}>{lida?"Marcar como não lida":"Marcar como lida"}</button>

                      <button onClick={()=>excluirPublicacao(id)} style={{background:"none",border:"none",cursor:"pointer",fontSize:11,color:"var(--text3)",padding:"6px 8px",marginLeft:"auto"}}>🗑 Remover</button>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      {criandoPrazoPara && <ModalCriarPrazoIntimacao intimacao={criandoPrazoPara} onConfirm={confirmarPrazo} onClose={()=>setCriandoPrazoPara(null)}/>}
