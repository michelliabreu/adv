// Mapa de segmento de Justiça (J) do número CNJ para prefixo de índice DataJud
// Formato CNJ: NNNNNNN-DD.AAAA.J.TR.OOOO
const SEGMENTO_DATAJUD = {
  "1": "trf",   // Justiça Federal
  "2": "trt",   // Justiça do Trabalho
  "3": "tse",   // Justiça Eleitoral (raramente usado nesse contexto)
  "4": "stm",   // Justiça Militar da União
  "5": "tjmrs", // Justiça Militar Estadual
  "8": "tj",    // Justiça Estadual
  "9": "trf",   // Justiça Federal (variação)
};

// Mapeia o número do tribunal (TR) de cada segmento para o sufixo do índice público.
// Cobertura dos tribunais mais comuns na carteira; pode ser ampliada conforme necessário.
function detectarIndiceDataJud(numero){
  const limpo = (numero||"").replace(/\D/g,"");
  if(limpo.length < 20) return "api_publica_tjrj"; // fallback se número incompleto
  // Posições no número CNJ de 20 dígitos: NNNNNNNDDAAAAJTROOOO
  const segmento = limpo.charAt(13); // J
  const tribunal = limpo.slice(14,16); // TR

  if(segmento === "8"){
    // Justiça Estadual — tribunal 19 = TJRJ
    if(tribunal === "19") return "api_publica_tjrj";
    return `api_publica_tjrj`; // fallback — ampliar mapa conforme outros estados surgirem na carteira
  }
  if(segmento === "5" || segmento === "2"){
    // Justiça do Trabalho — tribunal 01 = TRT1 (RJ)
    return `api_publica_trt${parseInt(tribunal)}`;
  }
  if(segmento === "1" || segmento === "4" || segmento === "9"){
    // Justiça Federal — tribunal 02 = TRF2 (RJ/ES)
    return `api_publica_trf${parseInt(tribunal)}`;
  }
  return "api_publica_tjrj";
}

// Detecta o sistema processual (PJe / eProc / outro) a partir do segmento de Justiça do número CNJ.
// Justiça Federal e Justiça do Trabalho costumam usar eProc/PJe-JT; Justiça Estadual do RJ usa PJe.
const SISTEMAS_PROCESSUAIS = ["PJe", "eProc", "DAC", "SEEU", "Físico", "Outro"];
function detectarSistemaProcessual(numero){
  const limpo = (numero||"").replace(/\D/g,"");
  if(limpo.length < 20) return "";
  const segmento = limpo.charAt(13); // J — segmento de Justiça
  if(segmento === "8") return "PJe";       // Justiça Estadual (TJRJ)
  if(segmento === "1" || segmento === "4" || segmento === "9") return "eProc"; // Justiça Federal
  if(segmento === "5" || segmento === "2") return "PJe";  // Justiça do Trabalho usa PJe (variação PJe-JT)
  return "";
}

async function buscarDataJud(numero){
  const indice = detectarIndiceDataJud(numero);
  let res;
  try {
    res = await fetch(`https://api-publica.datajud.cnj.jus.br/${indice}/_search`,{method:"POST",headers:{"Authorization":"APIKey cDZHYzlZa0JadVREZDJCendFbXNYR1NtYXNzY3BqZVM=","Content-Type":"application/json"},body:JSON.stringify({query:{match:{numeroProcesso:numero.trim()}},size:1})});
  } catch(networkErr) {
    throw new Error("Não foi possível conectar ao DataJud — o navegador bloqueou a requisição (CORS) ou não há conexão com a internet.");
  }
  if(res.status===401||res.status===403) throw new Error("Chave de API do DataJud inválida ou expirada. Gere uma chave própria em datajud.cnj.jus.br e atualize o código.");
  if(!res.ok) throw new Error(`Erro HTTP ${res.status} ao consultar o índice ${indice}.`);
  const data=await res.json();
  const hit=data?.hits?.hits?.[0]?._source;
  if(!hit)throw new Error(`Processo não encontrado no índice ${indice}. Confira o número ou se o tribunal está correto.`);
  return hit;
}
